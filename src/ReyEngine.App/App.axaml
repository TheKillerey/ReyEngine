<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="ReyEngine.App.App"
             RequestedThemeVariant="Dark">

  <!-- M39: theme system — palette/brushes in Themes/ReyColors.axaml, control styles in
       Themes/ReyTheme.axaml. Views consume tokens via DynamicResource only. -->
  <Application.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceInclude Source="avares://ReyEngine.App/Themes/ReyColors.axaml" />
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </Application.Resources>

  <Application.Styles>
    <FluentTheme />
    <StyleInclude Source="avares://ReyEngine.App/Themes/ReyTheme.axaml" />
  </Application.Styles>

</Application>
