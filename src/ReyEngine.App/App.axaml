<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="ReyEngine.App.App"
             RequestedThemeVariant="Dark">

  <!-- M39/M72: theme system — swappable palettes in Themes/Palettes (same keys each), control styles in
       Themes/ReyTheme.axaml. Views consume tokens via DynamicResource only; ThemeService swaps
       MergedDictionaries[0] live at runtime. The include below is only the pre-settings default. -->
  <Application.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceInclude Source="avares://ReyEngine.App/Themes/Palettes/Crimson.axaml" />
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </Application.Resources>

  <Application.Styles>
    <FluentTheme />
    <StyleInclude Source="avares://ReyEngine.App/Themes/ReyTheme.axaml" />
  </Application.Styles>

</Application>
