<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:ReyEngine.App.Views"
        xmlns:vm="clr-namespace:ReyEngine.App.ViewModels"
        x:Class="ReyEngine.App.Views.AudioBankEditorWindow"
        x:DataType="vm:AudioBankEditorViewModel"
        Title="ReyEngine — Audio Bank Editor" Width="820" Height="620"
        WindowStartupLocation="CenterOwner"
        ExtendClientAreaToDecorationsHint="True"
        Background="{DynamicResource ReyBgBrush}">
  <DockPanel>
    <views:ReyTitleBar DockPanel.Dock="Top" />

    <!-- header -->
    <Border DockPanel.Dock="Top" Background="{DynamicResource ReyHeaderBrush}"
            BorderBrush="{DynamicResource ReyBorderBrush}" BorderThickness="0,0,0,1" Padding="12,6">
      <StackPanel Spacing="3">
        <StackPanel Orientation="Horizontal" Spacing="8">
          <TextBlock Text="🔊" FontSize="13" VerticalAlignment="Center" />
          <TextBlock Text="{Binding Title}" FontSize="13" FontWeight="Bold" VerticalAlignment="Center"
                     TextTrimming="CharacterEllipsis" />
          <Ellipse Width="7" Height="7" Fill="{DynamicResource ReyAccent2Brush}" VerticalAlignment="Center"
                   IsVisible="{Binding IsDirty}" ToolTip.Tip="Unsaved changes" />
        </StackPanel>
        <TextBlock Text="{Binding Subtitle}" FontSize="10" Foreground="{DynamicResource ReyTextDimBrush}" />
      </StackPanel>
    </Border>

    <!-- toolbar -->
    <Border DockPanel.Dock="Top" Background="{DynamicResource ReyPanelBrush}"
            BorderBrush="{DynamicResource ReyBorderBrush}" BorderThickness="0,0,0,1" Padding="8,5">
      <WrapPanel>
        <Button Classes="tool" Content="▶ Play" Command="{Binding PlayCommand}" IsEnabled="{Binding HasSelection}" Margin="0,0,4,0" />
        <Button Classes="tool" Content="■ Stop" Command="{Binding StopCommand}" Margin="0,0,10,0" />
        <Button Classes="tool" Content="⬇ Export…" Command="{Binding ExportCommand}" IsEnabled="{Binding HasSelection}" Margin="0,0,4,0"
                ToolTip.Tip="Save the selected sound as a .wem file" />
        <Button Classes="tool" Content="⬆ Replace…" Command="{Binding ImportCommand}" IsEnabled="{Binding HasSelection}" Margin="0,0,10,0"
                ToolTip.Tip="Swap the selected sound's audio for an imported .wem" />
        <Button Classes="tool" Content="＋ Add…" Command="{Binding AddCommand}" Margin="0,0,4,0"
                ToolTip.Tip="Import a .wem as a new entry with an id you choose" />
        <Button Classes="tool" Content="✎ Change Id…" Command="{Binding RenameCommand}" IsEnabled="{Binding HasSelection}" Margin="0,0,4,0"
                ToolTip.Tip="Wwise sounds have no names — the id IS the name. Changing it re-points which event plays this audio." />
        <Button Classes="tool" Content="⧉ Duplicate…" Command="{Binding DuplicateCommand}" IsEnabled="{Binding HasSelection}" Margin="0,0,4,0" />
        <Button Classes="tool" Content="🗑 Delete" Command="{Binding DeleteCommand}" IsEnabled="{Binding HasSelection}" Margin="0,0,10,0" />
        <Button Classes="tool" Content="⧉ Copy" Command="{Binding CopyCommand}" IsEnabled="{Binding HasSelection}" Margin="0,0,4,0"
                ToolTip.Tip="Copy this sound — paste it here or into another open bank" />
        <Button Classes="tool" Content="📋 Paste New" Command="{Binding PasteCommand}" Margin="0,0,4,0" />
        <Button Classes="tool" Content="📋 Paste Into" Command="{Binding PasteIntoCommand}" IsEnabled="{Binding HasSelection}" Margin="0,0,10,0"
                ToolTip.Tip="Overwrite the selected sound with the copied audio" />
        <Button Classes="primary" Content="💾 Save" Command="{Binding SaveCommand}" IsEnabled="{Binding IsDirty}" />
      </WrapPanel>
    </Border>

    <!-- status -->
    <Border DockPanel.Dock="Bottom" Background="{DynamicResource ReyHeaderBrush}"
            BorderBrush="{DynamicResource ReyBorderBrush}" BorderThickness="0,1,0,0" Padding="12,6">
      <TextBlock Text="{Binding Status}" FontSize="11" Foreground="{DynamicResource ReyTextDimBrush}" TextWrapping="Wrap" />
    </Border>

    <DockPanel>
      <!-- read-only banner -->
      <Border DockPanel.Dock="Top" Background="#26FF5555" Padding="10,6" IsVisible="{Binding HasReadOnlyReason}">
        <TextBlock Text="{Binding ReadOnlyReason}" Foreground="#FF7B72" FontSize="11" TextWrapping="Wrap" />
      </Border>

      <!-- column header -->
      <Border DockPanel.Dock="Top" Background="{DynamicResource ReyPanelAltBrush}" Padding="10,3">
        <Grid ColumnDefinitions="120,90,170,*">
          <TextBlock Grid.Column="0" Text="WWISE ID" FontSize="9" FontWeight="SemiBold" Foreground="{DynamicResource ReyTextDimBrush}" />
          <TextBlock Grid.Column="1" Text="SIZE" FontSize="9" FontWeight="SemiBold" Foreground="{DynamicResource ReyTextDimBrush}" />
          <TextBlock Grid.Column="2" Text="FORMAT" FontSize="9" FontWeight="SemiBold" Foreground="{DynamicResource ReyTextDimBrush}" />
          <TextBlock Grid.Column="3" Text="PLAYED BY / STATE" FontSize="9" FontWeight="SemiBold" Foreground="{DynamicResource ReyTextDimBrush}" />
        </Grid>
      </Border>

      <ListBox ItemsSource="{Binding Rows}" SelectedItem="{Binding Selected}" Background="Transparent">
        <ListBox.ItemTemplate>
          <DataTemplate x:DataType="vm:AudioEntryRowViewModel">
            <Grid ColumnDefinitions="120,90,170,*" Margin="0,1">
              <TextBlock Grid.Column="0" Text="{Binding Id}" FontSize="11" FontFamily="Consolas,monospace" VerticalAlignment="Center" />
              <TextBlock Grid.Column="1" Text="{Binding SizeText}" FontSize="10" VerticalAlignment="Center"
                         Foreground="{DynamicResource ReyTextDimBrush}" />
              <TextBlock Grid.Column="2" Text="{Binding InfoText}" FontSize="10" VerticalAlignment="Center"
                         Foreground="{DynamicResource ReyTextDimBrush}" TextTrimming="CharacterEllipsis" />
              <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <TextBlock Text="{Binding UsedBy}" FontSize="10" Foreground="{DynamicResource ReyAccentBrush}"
                           IsVisible="{Binding HasUsedBy}" TextTrimming="CharacterEllipsis" ToolTip.Tip="{Binding UsedBy}" />
                <Border Background="{DynamicResource ReyAccent2Brush}" CornerRadius="3" Padding="5,1"
                        IsVisible="{Binding IsChanged}">
                  <TextBlock Text="{Binding StateText}" FontSize="9" Foreground="#08221E" />
                </Border>
              </StackPanel>
            </Grid>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>
    </DockPanel>
  </DockPanel>
</Window>
