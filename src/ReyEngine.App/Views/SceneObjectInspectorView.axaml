<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="ReyEngine.App.Views.SceneObjectInspectorView">
  <!-- M50: Unity/Unreal-style scene-object inspector — Transform / Details / Materials for whatever is
       selected in the outliner or viewport. Lives in the RIGHT panel (moved out of the left outliner). -->
  <StackPanel Spacing="8">

    <!-- TRANSFORM (single mesh) -->
    <Border Classes="card" IsVisible="{Binding IsSingleSelect}">
      <StackPanel Spacing="4">
        <TextBlock Classes="cardTitle" Text="TRANSFORM" />
        <TextBlock Text="{Binding SelectedMapMesh.Name}" FontSize="11" Foreground="{DynamicResource ReyAccentBrush}" TextTrimming="CharacterEllipsis" />

        <TextBlock Text="Position" FontSize="9" Foreground="{DynamicResource ReyTextDimBrush}" Margin="0,2,0,0" />
        <Grid ColumnDefinitions="Auto,*,Auto,*,Auto,*">
          <TextBlock Grid.Column="0" Text="X" FontSize="10" VerticalAlignment="Center" Margin="0,0,3,0" Foreground="#E5645B" />
          <TextBox Grid.Column="1" Text="{Binding MeshMoveX}" FontSize="10" Padding="3,1" />
          <TextBlock Grid.Column="2" Text="Y" FontSize="10" VerticalAlignment="Center" Margin="5,0,3,0" Foreground="#53C67A" />
          <TextBox Grid.Column="3" Text="{Binding MeshMoveY}" FontSize="10" Padding="3,1" />
          <TextBlock Grid.Column="4" Text="Z" FontSize="10" VerticalAlignment="Center" Margin="5,0,3,0" Foreground="#4C9FE8" />
          <TextBox Grid.Column="5" Text="{Binding MeshMoveZ}" FontSize="10" Padding="3,1" />
        </Grid>

        <TextBlock Text="Rotation (degrees)" FontSize="9" Foreground="{DynamicResource ReyTextDimBrush}" Margin="0,2,0,0" />
        <Grid ColumnDefinitions="Auto,*,Auto,*,Auto,*">
          <TextBlock Grid.Column="0" Text="X" FontSize="10" VerticalAlignment="Center" Margin="0,0,3,0" Foreground="#E5645B" />
          <TextBox Grid.Column="1" Text="{Binding MeshRotateX}" FontSize="10" Padding="3,1" />
          <TextBlock Grid.Column="2" Text="Y" FontSize="10" VerticalAlignment="Center" Margin="5,0,3,0" Foreground="#53C67A" />
          <TextBox Grid.Column="3" Text="{Binding MeshRotateY}" FontSize="10" Padding="3,1" />
          <TextBlock Grid.Column="4" Text="Z" FontSize="10" VerticalAlignment="Center" Margin="5,0,3,0" Foreground="#4C9FE8" />
          <TextBox Grid.Column="5" Text="{Binding MeshRotateZ}" FontSize="10" Padding="3,1" />
        </Grid>

        <TextBlock Text="Scale" FontSize="9" Foreground="{DynamicResource ReyTextDimBrush}" Margin="0,2,0,0" />
        <Grid ColumnDefinitions="Auto,*,Auto,*,Auto,*">
          <TextBlock Grid.Column="0" Text="X" FontSize="10" VerticalAlignment="Center" Margin="0,0,3,0" Foreground="#E5645B" />
          <TextBox Grid.Column="1" Text="{Binding MeshScaleX}" FontSize="10" Padding="3,1" />
          <TextBlock Grid.Column="2" Text="Y" FontSize="10" VerticalAlignment="Center" Margin="5,0,3,0" Foreground="#53C67A" />
          <TextBox Grid.Column="3" Text="{Binding MeshScaleY}" FontSize="10" Padding="3,1" />
          <TextBlock Grid.Column="4" Text="Z" FontSize="10" VerticalAlignment="Center" Margin="5,0,3,0" Foreground="#4C9FE8" />
          <TextBox Grid.Column="5" Text="{Binding MeshScaleZ}" FontSize="10" Padding="3,1" />
        </Grid>

        <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,2,0,0">
          <Button Content="Apply" Command="{Binding ApplyMeshMoveCommand}" FontSize="11" Padding="8,2"
                  ToolTip.Tip="Apply position/rotation/scale live in the viewport" />
          <Button Content="Reset" Command="{Binding ResetMeshTransformCommand}" FontSize="11" Padding="8,2"
                  ToolTip.Tip="Restore this mesh's original transform" />
          <Button Classes="primary" Content="Save to Mod" Command="{Binding SaveMeshMovesCommand}" FontSize="11" Padding="8,2"
                  IsEnabled="{Binding HasMapMoves}" />
        </StackPanel>
        <ToggleButton Classes="vp" Content="⇅ Flip Normals" IsChecked="{Binding SelectedMeshNormalsFlipped, Mode=OneWay}"
                      Command="{Binding FlipMeshNormalsCommand}" FontSize="11" Padding="8,2" Margin="0,2,0,0"
                      HorizontalAlignment="Left"
                      ToolTip.Tip="Flip this mesh's vertex normals (live preview). For two-sided (cullEnable=false) materials the two-sided lighting already lights both faces, so flipping darkens instead of fixing." />
      </StackPanel>
    </Border>

    <!-- BATCH TRANSFORM (multi select) -->
    <Border Classes="card" IsVisible="{Binding IsMultiSelect}">
      <StackPanel Spacing="4">
        <TextBlock Classes="cardTitle" Text="BATCH TRANSFORM" />
        <TextBlock Text="{Binding SelectionStatus}" FontSize="11" Foreground="{DynamicResource ReyAccentBrush}" />
        <TextBlock Text="Rotate/scale act around the selection center. Move is a world delta added to every mesh."
                   FontSize="9" Foreground="{DynamicResource ReyTextDimBrush}" TextWrapping="Wrap" />

        <TextBlock Text="Move Δ (world)" FontSize="9" Foreground="{DynamicResource ReyTextDimBrush}" Margin="0,2,0,0" />
        <Grid ColumnDefinitions="Auto,*,Auto,*,Auto,*">
          <TextBlock Grid.Column="0" Text="X" FontSize="10" VerticalAlignment="Center" Margin="0,0,3,0" Foreground="#E5645B" />
          <TextBox Grid.Column="1" Text="{Binding BatchMoveX}" FontSize="10" Padding="3,1" />
          <TextBlock Grid.Column="2" Text="Y" FontSize="10" VerticalAlignment="Center" Margin="5,0,3,0" Foreground="#53C67A" />
          <TextBox Grid.Column="3" Text="{Binding BatchMoveY}" FontSize="10" Padding="3,1" />
          <TextBlock Grid.Column="4" Text="Z" FontSize="10" VerticalAlignment="Center" Margin="5,0,3,0" Foreground="#4C9FE8" />
          <TextBox Grid.Column="5" Text="{Binding BatchMoveZ}" FontSize="10" Padding="3,1" />
        </Grid>
        <Button Content="Move Selection" Command="{Binding ApplyBatchMoveCommand}" FontSize="11" Padding="8,2" HorizontalAlignment="Left" />

        <TextBlock Text="Rotate Δ (degrees, about center)" FontSize="9" Foreground="{DynamicResource ReyTextDimBrush}" Margin="0,4,0,0" />
        <Grid ColumnDefinitions="Auto,*,Auto,*,Auto,*">
          <TextBlock Grid.Column="0" Text="X" FontSize="10" VerticalAlignment="Center" Margin="0,0,3,0" Foreground="#E5645B" />
          <TextBox Grid.Column="1" Text="{Binding BatchRotateX}" FontSize="10" Padding="3,1" />
          <TextBlock Grid.Column="2" Text="Y" FontSize="10" VerticalAlignment="Center" Margin="5,0,3,0" Foreground="#53C67A" />
          <TextBox Grid.Column="3" Text="{Binding BatchRotateY}" FontSize="10" Padding="3,1" />
          <TextBlock Grid.Column="4" Text="Z" FontSize="10" VerticalAlignment="Center" Margin="5,0,3,0" Foreground="#4C9FE8" />
          <TextBox Grid.Column="5" Text="{Binding BatchRotateZ}" FontSize="10" Padding="3,1" />
        </Grid>
        <Button Content="Rotate Selection" Command="{Binding ApplyBatchRotateCommand}" FontSize="11" Padding="8,2" HorizontalAlignment="Left" />

        <TextBlock Text="Scale Δ (about center)" FontSize="9" Foreground="{DynamicResource ReyTextDimBrush}" Margin="0,4,0,0" />
        <Grid ColumnDefinitions="Auto,*,Auto,*,Auto,*">
          <TextBlock Grid.Column="0" Text="X" FontSize="10" VerticalAlignment="Center" Margin="0,0,3,0" Foreground="#E5645B" />
          <TextBox Grid.Column="1" Text="{Binding BatchScaleX}" FontSize="10" Padding="3,1" />
          <TextBlock Grid.Column="2" Text="Y" FontSize="10" VerticalAlignment="Center" Margin="5,0,3,0" Foreground="#53C67A" />
          <TextBox Grid.Column="3" Text="{Binding BatchScaleY}" FontSize="10" Padding="3,1" />
          <TextBlock Grid.Column="4" Text="Z" FontSize="10" VerticalAlignment="Center" Margin="5,0,3,0" Foreground="#4C9FE8" />
          <TextBox Grid.Column="5" Text="{Binding BatchScaleZ}" FontSize="10" Padding="3,1" />
        </Grid>
        <Button Content="Scale Selection" Command="{Binding ApplyBatchScaleCommand}" FontSize="11" Padding="8,2" HorizontalAlignment="Left" />

        <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,4,0,0">
          <Button Content="Reset Selected" Command="{Binding ResetSelectedCommand}" FontSize="11" Padding="8,2"
                  ToolTip.Tip="Restore every selected mesh to its original transform" />
          <Button Content="Clear Selection" Command="{Binding ClearSelectionCommand}" FontSize="11" Padding="8,2" />
          <Button Classes="primary" Content="Save to Mod" Command="{Binding SaveMeshMovesCommand}" FontSize="11" Padding="8,2"
                  IsEnabled="{Binding HasMapMoves}" />
        </StackPanel>
      </StackPanel>
    </Border>

    <!-- MATERIALS — the materials assigned to the selected mesh (Unity Mesh-Renderer style) -->
    <Border Classes="card" IsVisible="{Binding HasSelectedMeshMaterials}">
      <StackPanel Spacing="3">
        <TextBlock Classes="cardTitle" Text="MATERIALS" />
        <ItemsControl ItemsSource="{Binding SelectedMeshMaterials}">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <Button Background="Transparent" BorderThickness="0" Padding="4,2"
                      HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                      Command="{Binding $parent[ItemsControl].DataContext.EditSelectedMaterialCommand}"
                      CommandParameter="{Binding}"
                      ToolTip.Tip="Open this material in the Materials editor">
                <StackPanel>
                  <StackPanel Orientation="Horizontal" Spacing="6">
                    <TextBlock Text="🎨" FontSize="10" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding Name}" FontSize="11" Foreground="{DynamicResource ReyTextBrush}"
                               TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                  </StackPanel>
                  <TextBlock Text="{Binding Detail}" FontSize="9" Opacity="0.55" Margin="20,0,0,0"
                             TextTrimming="CharacterEllipsis" />
                </StackPanel>
              </Button>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </StackPanel>
    </Border>

    <!-- M105: MAP LAYERS — assign the selected meshes to dragon layers / a baron visibility
         controller. Edits preview live and save with "Save to Mod". -->
    <Border Classes="card" IsVisible="{Binding HasLayerSelection}">
      <StackPanel Spacing="4">
        <TextBlock Classes="cardTitle" Text="MAP LAYERS" />
        <TextBlock Text="{Binding LayerSummary}" FontSize="9" Foreground="{DynamicResource ReyAccentBrush}" TextWrapping="Wrap" />

        <TextBlock Text="Dragon layers (mesh shows when its layer is active)" FontSize="9"
                   Foreground="{DynamicResource ReyTextDimBrush}" Margin="0,2,0,0" />
        <ItemsControl ItemsSource="{Binding DragonLayerBits}">
          <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <CheckBox Content="{Binding Name}" IsChecked="{Binding IsOn}" FontSize="10" Margin="0,0,8,2" />
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>

        <TextBlock Text="Visibility controller (baron pit states, timed events)" FontSize="9"
                   Foreground="{DynamicResource ReyTextDimBrush}" Margin="0,4,0,0" />
        <ComboBox ItemsSource="{Binding LayerControllerChoices}" SelectedIndex="{Binding SelectedLayerControllerIndex}"
                  FontSize="10" HorizontalAlignment="Stretch"
                  ToolTip.Tip="Controllers come from this map's .bin files. 'None' keeps the mesh purely on the dragon-layer mask." />

        <CheckBox Content="Disable backface culling (two-sided)" IsChecked="{Binding MeshBackfaceDisabled}" FontSize="10"
                  Margin="0,2,0,0" ToolTip.Tip="The mapgeo's own per-mesh backface flag (M102)" />

        <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,4,0,0">
          <Button Content="All Layers" Command="{Binding SetLayersAllCommand}" FontSize="10" Padding="8,2"
                  ToolTip.Tip="Mask 255 — visible on every dragon configuration" />
          <Button Content="Reset Edits" Command="{Binding ResetLayerEditsCommand}" FontSize="10" Padding="8,2"
                  ToolTip.Tip="Discard pending layer edits on the selected meshes (back to the file's values)" />
          <Button Classes="primary" Content="Save to Mod" Command="{Binding SaveMeshMovesCommand}" FontSize="10" Padding="8,2"
                  IsEnabled="{Binding HasMapMoves}" />
        </StackPanel>
      </StackPanel>
    </Border>

    <!-- MESH DETAILS — read-only mapgeo diagnostics, collapsed by default. Everything editable lives
         above (Transform card, Map Layers card, Materials); these rows have no writable .bin field. -->
    <Expander IsExpanded="False" IsVisible="{Binding MeshDetails.HasMesh}" FontSize="11">
      <Expander.Header>
        <StackPanel Orientation="Horizontal" Spacing="6">
          <TextBlock Text="MESH DETAILS (read-only)" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource ReyTextDimBrush}" VerticalAlignment="Center" />
          <TextBlock Text="{Binding MeshDetails.Title}" FontSize="11" Foreground="{DynamicResource ReyAccentBrush}"
                     TextTrimming="CharacterEllipsis" MaxWidth="160" VerticalAlignment="Center" />
        </StackPanel>
      </Expander.Header>
      <ItemsControl ItemsSource="{Binding MeshDetails.Rows}" Margin="2,0">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <Grid ColumnDefinitions="120,*" Margin="0,1">
              <TextBlock Grid.Column="0" Text="{Binding Label}" FontSize="10" Foreground="{DynamicResource ReyTextDimBrush}" VerticalAlignment="Top" />
              <TextBlock Grid.Column="1" Text="{Binding Value}" FontSize="10" TextWrapping="Wrap"
                         Foreground="{DynamicResource ReyTextBrush}" />
            </Grid>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </Expander>

    <!-- MOVE PARTICLE (selected placed particle) -->
    <Border Classes="card" IsVisible="{Binding SelectedParticleNode, Converter={x:Static ObjectConverters.IsNotNull}}">
      <StackPanel Spacing="3">
        <Grid ColumnDefinitions="*,Auto,Auto">
          <TextBlock Classes="cardTitle" Grid.Column="0" Text="PARTICLE" VerticalAlignment="Center" />
          <Button Classes="tool" Grid.Column="1" Content="🎯 Focus" Command="{Binding FocusSelectedPlaceableCommand}"
                  FontSize="10" Padding="6,1" Margin="0,0,4,0" ToolTip.Tip="Frame the camera on this particle" />
          <ToggleButton Classes="vp" Grid.Column="2" Content="▶ Play VFX" IsChecked="{Binding PlayParticlePreview}" FontSize="10" Padding="6,1"
                        ToolTip.Tip="Simulate and play this particle system live in the viewport" />
        </Grid>
        <TextBlock Text="{Binding SelectedParticleNode.Name}" FontSize="11" Foreground="{DynamicResource ReyAccentBrush}" TextTrimming="CharacterEllipsis" />
        <TextBlock Text="Position" FontSize="9" Foreground="{DynamicResource ReyTextDimBrush}" Margin="0,2,0,0" />
        <Grid ColumnDefinitions="14,*,14,*,14,*">
          <TextBlock Grid.Column="0" Text="X" FontSize="10" Foreground="#E5645B" VerticalAlignment="Center" />
          <TextBox Grid.Column="1" Text="{Binding ParticleMoveX}" FontSize="10" Padding="3,1" />
          <TextBlock Grid.Column="2" Text="Y" FontSize="10" Foreground="#53C67A" VerticalAlignment="Center" Margin="3,0,0,0" />
          <TextBox Grid.Column="3" Text="{Binding ParticleMoveY}" FontSize="10" Padding="3,1" />
          <TextBlock Grid.Column="4" Text="Z" FontSize="10" Foreground="#4C9FE8" VerticalAlignment="Center" Margin="3,0,0,0" />
          <TextBox Grid.Column="5" Text="{Binding ParticleMoveZ}" FontSize="10" Padding="3,1" />
        </Grid>
        <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,2,0,0">
          <Button Content="Apply" Command="{Binding ApplyParticleMoveCommand}" FontSize="11" Padding="8,2"
                  ToolTip.Tip="Move the particle to this position live in the viewport" />
          <Button Content="Reset" Command="{Binding ResetParticleMoveCommand}" FontSize="11" Padding="8,2" />
          <Button Classes="primary" Content="Save to Mod" Command="{Binding SaveParticleMovesCommand}" FontSize="11" Padding="8,2"
                  IsEnabled="{Binding HasParticleMoves}" />
        </StackPanel>
      </StackPanel>
    </Border>

    <!-- SOUND (MapAudio placement) — M56: resolve the Wwise event through the map's banks and play it -->
    <Border Classes="card" IsVisible="{Binding SelectedSound, Converter={x:Static ObjectConverters.IsNotNull}}">
      <StackPanel Spacing="4">
        <Grid ColumnDefinitions="*,Auto">
          <TextBlock Classes="cardTitle" Grid.Column="0" Text="SOUND" VerticalAlignment="Center" />
          <Button Classes="tool" Grid.Column="1" Content="🎯 Focus" Command="{Binding FocusSelectedPlaceableCommand}"
                  FontSize="10" Padding="6,1" ToolTip.Tip="Frame the camera on this sound" />
        </Grid>
        <TextBlock Text="{Binding SelectedSound.Name}" FontSize="11" Foreground="{DynamicResource ReyAccentBrush}" TextTrimming="CharacterEllipsis" />
        <TextBlock Text="{Binding SelectedSound.EventName}" FontSize="10" Foreground="{DynamicResource ReyTextDimBrush}"
                   FontFamily="Cascadia Mono, Consolas, monospace" TextWrapping="Wrap" />
        <StackPanel Orientation="Horizontal" Spacing="6">
          <Button Classes="primary" Content="▶ Play" Command="{Binding PlaySelectedSoundCommand}" FontSize="11" Padding="10,2"
                  ToolTip.Tip="Resolve the Wwise event through the map's banks, decode the wem (vgmstream) and play it" />
          <Button Classes="tool" Content="⏹ Stop All" Command="{Binding StopAllSoundsCommand}" FontSize="11" Padding="8,2" />
        </StackPanel>
        <Button Classes="tool" Content="🔁 Replace wem…" Command="{Binding ReplaceSelectedSoundWemCommand}"
                FontSize="11" Padding="8,2" HorizontalAlignment="Left"
                ToolTip.Tip="Import a .wem to replace this sound's audio; rebuilds the bank and saves it to the project override (Build Package ships it)" />
        <TextBlock Text="{Binding AudioStatus}" FontSize="9" Foreground="{DynamicResource ReyAccentBrush}" TextWrapping="Wrap"
                   IsVisible="{Binding AudioStatus, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
      </StackPanel>
    </Border>

    <!-- M79: ADDED MESH (imported, queued for append) — material picker + gizmo hint + save/remove -->
    <Border Classes="card" IsVisible="{Binding SelectedAddedMesh, Converter={x:Static ObjectConverters.IsNotNull}}">
      <StackPanel Spacing="4">
        <Grid ColumnDefinitions="*,Auto">
          <TextBlock Classes="cardTitle" Grid.Column="0" Text="ADDED MESH" VerticalAlignment="Center" />
          <Button Classes="tool" Grid.Column="1" Content="🎯 Focus" Command="{Binding FocusSelectedPlaceableCommand}"
                  FontSize="10" Padding="6,1" ToolTip.Tip="Frame the camera on this mesh" />
        </Grid>
        <TextBlock Text="{Binding SelectedAddedMesh.Name}" FontSize="11" Foreground="{DynamicResource ReyAccentBrush}" TextTrimming="CharacterEllipsis" />
        <TextBlock Text="{Binding SelectedAddedMesh.Info}" FontSize="10" Foreground="{DynamicResource ReyTextDimBrush}" TextWrapping="Wrap" />
        <TextBlock Text="Material" FontSize="10" Foreground="{DynamicResource ReyTextDimBrush}" Margin="0,4,0,0" />
        <ComboBox ItemsSource="{Binding MapMaterialNames}" SelectedItem="{Binding SelectedAddedMesh.Material}"
                  HorizontalAlignment="Stretch" FontSize="10"
                  ToolTip.Tip="Which of the map's existing materials this mesh uses. It must exist in the materials.bin." />
        <TextBlock Text="Move / rotate / scale it with the viewport gizmo (Move·Rotate·Scale tools)." FontSize="9"
                   Foreground="{DynamicResource ReyTextDimBrush}" TextWrapping="Wrap" Margin="0,2,0,0" />
        <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,2,0,0">
          <Button Classes="primary" Content="Save to Mod" Command="{Binding SaveMeshMovesCommand}" FontSize="11" Padding="8,2"
                  ToolTip.Tip="Append every queued mesh to the mapgeo, regenerate bucket grids, and write the project override" />
          <Button Classes="tool" Content="🗑 Remove" Command="{Binding RemoveAddedMeshCommand}" CommandParameter="{Binding SelectedAddedMesh}"
                  FontSize="11" Padding="8,2" />
        </StackPanel>
      </StackPanel>
    </Border>

    <!-- PLACEABLE INFO (props / probes) -->
    <Border Classes="card"
            IsVisible="{Binding SelectedPlaceableInfo, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
      <StackPanel Spacing="3">
        <Grid ColumnDefinitions="*,Auto">
          <TextBlock Classes="cardTitle" Grid.Column="0" Text="PLACEABLE" VerticalAlignment="Center" />
          <Button Classes="tool" Grid.Column="1" Content="🎯 Focus" Command="{Binding FocusSelectedPlaceableCommand}"
                  FontSize="10" Padding="6,1" ToolTip.Tip="Frame the camera on this object" />
        </Grid>
        <TextBlock Text="{Binding SelectedPlaceableInfo}" FontSize="10" Foreground="{DynamicResource ReyTextBrush}" TextWrapping="Wrap" />
      </StackPanel>
    </Border>
  </StackPanel>
</UserControl>
