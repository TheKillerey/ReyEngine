<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:ReyEngine.App.ViewModels"
             xmlns:conv="clr-namespace:ReyEngine.App.Converters"
             x:Class="ReyEngine.App.Views.MapOutlinerView">
  <UserControl.Resources>
    <conv:BoolToBrushConverter x:Key="SelectionHighlight" TrueBrush="#3336E2C2" FalseBrush="Transparent" />
  </UserControl.Resources>

  <!-- M51: ONE unified hierarchy (Unity/Unreal style) — plain folders (Meshes / Particles / Mobs /
       Probes) in a single tree; select any object type here. No per-category collapse sections. -->
  <DockPanel IsVisible="{Binding MapContent.HasMap}">
    <TextBlock DockPanel.Dock="Top" Text="{Binding MapContent.MapName}" Foreground="{DynamicResource ReyAccentBrush}"
               FontSize="11" FontWeight="SemiBold" Margin="8,4,8,2" />

    <!-- scene-level visibility layers -->
    <StackPanel DockPanel.Dock="Top" Margin="8,2,8,4" Spacing="3">
      <TextBlock Classes="cardTitle" Text="VISIBILITY LAYERS" />
      <Grid ColumnDefinitions="*,*">
        <StackPanel Grid.Column="0" Margin="0,0,3,0">
          <TextBlock Text="Dragon" FontSize="9" Foreground="{DynamicResource ReyTextDimBrush}" />
          <ComboBox ItemsSource="{Binding DragonOptions}" SelectedIndex="{Binding SelectedDragonIndex}"
                    FontSize="10" HorizontalAlignment="Stretch" />
        </StackPanel>
        <StackPanel Grid.Column="1" Margin="3,0,0,0">
          <TextBlock Text="Baron" FontSize="9" Foreground="{DynamicResource ReyTextDimBrush}" />
          <ComboBox ItemsSource="{Binding BaronOptions}" SelectedIndex="{Binding SelectedBaronIndex}"
                    FontSize="10" HorizontalAlignment="Stretch"
                    ToolTip.Tip="Baron pit state. Resolves the map's visibility controllers (Base/Cup/Tunnel/Upgraded) and hides meshes that don't belong to the selected state." />
        </StackPanel>
      </Grid>
    </StackPanel>

    <!-- view toggles (what renders in the viewport) -->
    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="3" Margin="8,0,8,4">
      <ToggleButton Classes="vp" Content="✨ Particles" IsChecked="{Binding ShowParticles}" FontSize="9" Padding="6,1"
                    ToolTip.Tip="Show particle markers in the viewport" />
      <ToggleButton Classes="vp" Content="▶ Play All" IsChecked="{Binding PlayAllParticles}" FontSize="9" Padding="6,1"
                    ToolTip.Tip="Simulate and play every placed particle system live (capped for performance)" />
      <ToggleButton Classes="vp" Content="🎭 Props" IsChecked="{Binding ShowPropMeshes}" FontSize="9" Padding="6,1"
                    ToolTip.Tip="Render the actual prop meshes (Baron, dragons, camps…) at their placements" />
      <ToggleButton Classes="vp" Content="▶ Anim" IsChecked="{Binding PlayPropAnimations}" FontSize="9" Padding="6,1"
                    IsEnabled="{Binding ShowPropMeshes}"
                    ToolTip.Tip="Play each prop's idle animation (Baron breathing, camps shuffling…). Needs Props enabled." />
    </StackPanel>

    <!-- the hierarchy -->
    <TreeView x:Name="MapContentTree"
              ItemsSource="{Binding MapContent.OutlinerRoots}" SelectedItem="{Binding SelectedOutlinerItem, Mode=TwoWay}"
              Background="Transparent" BorderThickness="0" Padding="4,0">
      <TreeView.DataTemplates>
        <TreeDataTemplate DataType="vm:OutlinerFolderViewModel" ItemsSource="{Binding Items}">
          <StackPanel Orientation="Horizontal" Spacing="5">
            <TextBlock Text="{Binding Icon}" FontSize="10" VerticalAlignment="Center" />
            <TextBlock Text="{Binding Name}" FontSize="11" FontWeight="SemiBold"
                       Foreground="{DynamicResource ReyAccentBrush}" VerticalAlignment="Center" />
          </StackPanel>
        </TreeDataTemplate>

        <TreeDataTemplate DataType="vm:MapLayerGroupViewModel" ItemsSource="{Binding Meshes}">
          <StackPanel Orientation="Horizontal" Spacing="5">
            <TextBlock Text="🗂" FontSize="10" VerticalAlignment="Center" />
            <TextBlock Text="{Binding Name}" FontSize="10" FontWeight="SemiBold"
                       Foreground="{DynamicResource ReyTextBrush}" VerticalAlignment="Center" />
          </StackPanel>
        </TreeDataTemplate>
        <DataTemplate DataType="vm:MapPieceViewModel">
          <Border Background="{Binding IsSelected, Converter={StaticResource SelectionHighlight}}"
                  CornerRadius="2" Padding="3,0" Margin="-3,0">
            <StackPanel Orientation="Horizontal" Spacing="5">
              <TextBlock Text="🧊" FontSize="9" VerticalAlignment="Center" />
              <TextBlock Text="{Binding Name}" FontSize="10" Foreground="{DynamicResource ReyTextBrush}"
                         TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
            </StackPanel>
          </Border>
        </DataTemplate>

        <TreeDataTemplate DataType="vm:ParticleSystemGroupViewModel" ItemsSource="{Binding Placements}">
          <StackPanel Orientation="Horizontal" Spacing="5">
            <TextBlock Text="✨" FontSize="9" VerticalAlignment="Center" />
            <TextBlock Text="{Binding Header}" FontSize="10" FontWeight="SemiBold"
                       Foreground="{DynamicResource ReyTextBrush}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
          </StackPanel>
        </TreeDataTemplate>
        <DataTemplate DataType="vm:ParticlePlacementViewModel">
          <StackPanel Orientation="Horizontal" Spacing="5">
            <TextBlock Text="✦" FontSize="9" Foreground="#36E2C2" VerticalAlignment="Center" />
            <TextBlock Text="{Binding Name}" FontSize="10" Foreground="{DynamicResource ReyTextDimBrush}"
                       TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
          </StackPanel>
        </DataTemplate>

        <TreeDataTemplate DataType="vm:AnimatedPropGroupViewModel" ItemsSource="{Binding Props}">
          <StackPanel Orientation="Horizontal" Spacing="5">
            <TextBlock Text="🎭" FontSize="9" VerticalAlignment="Center" />
            <TextBlock Text="{Binding Header}" FontSize="10" FontWeight="SemiBold"
                       Foreground="{DynamicResource ReyTextBrush}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
          </StackPanel>
        </TreeDataTemplate>
        <DataTemplate DataType="vm:AnimatedPropViewModel">
          <StackPanel Orientation="Horizontal" Spacing="5">
            <TextBlock Text="🐾" FontSize="9" VerticalAlignment="Center" />
            <TextBlock Text="{Binding Name}" FontSize="10" Foreground="{DynamicResource ReyTextDimBrush}"
                       TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
          </StackPanel>
        </DataTemplate>

        <DataTemplate DataType="vm:CubemapProbeViewModel">
          <StackPanel Orientation="Horizontal" Spacing="5">
            <TextBlock Text="🪞" FontSize="9" VerticalAlignment="Center" />
            <TextBlock Text="{Binding Name}" FontSize="10" Foreground="{DynamicResource ReyTextDimBrush}"
                       TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
          </StackPanel>
        </DataTemplate>
      </TreeView.DataTemplates>
    </TreeView>
  </DockPanel>
</UserControl>
