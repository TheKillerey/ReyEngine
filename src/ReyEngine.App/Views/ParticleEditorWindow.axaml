<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:ReyEngine.App.Views"
        xmlns:vm="clr-namespace:ReyEngine.App.ViewModels"
        x:Class="ReyEngine.App.Views.ParticleEditorWindow"
        x:DataType="vm:ParticleEditorViewModel"
        Title="ReyEngine — Particle Editor" Width="1360" Height="860"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource ReyBgBrush}">
  <!-- M46: the Particle Editor lives in its own window (the main layout has no room for it) -->
  <views:ParticleEditorView />
</Window>
