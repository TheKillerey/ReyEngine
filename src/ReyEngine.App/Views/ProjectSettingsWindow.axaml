<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="ReyEngine.App.Views.ProjectSettingsWindow"
        Title="Project Settings"
        Width="540" Height="640"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource ReyBgBrush}"
        Foreground="{DynamicResource ReyTextBrush}"
        FontFamily="Inter, Segoe UI, sans-serif">
  <ScrollViewer>
    <StackPanel Margin="18" Spacing="8">
      <TextBlock Text="MOD METADATA (.fantome)" FontSize="11" FontWeight="SemiBold"
                 Foreground="{DynamicResource ReyTextDimBrush}" />

      <TextBlock Text="Name" FontSize="11" Foreground="{DynamicResource ReyTextDimBrush}" />
      <TextBox Text="{Binding ModName}" Watermark="My Mod Name" />

      <TextBlock Text="Author" FontSize="11" Foreground="{DynamicResource ReyTextDimBrush}" />
      <TextBox Text="{Binding Author}" Watermark="Your name" />

      <TextBlock Text="Version" FontSize="11" Foreground="{DynamicResource ReyTextDimBrush}" />
      <TextBox Text="{Binding Version}" Watermark="1.0.0" Width="160" HorizontalAlignment="Left" />

      <TextBlock Text="Description" FontSize="11" Foreground="{DynamicResource ReyTextDimBrush}" />
      <TextBox Text="{Binding Description}" AcceptsReturn="True" Height="64" TextWrapping="Wrap" />

      <TextBlock Text="Heart URL (optional)" FontSize="11" Foreground="{DynamicResource ReyTextDimBrush}" />
      <TextBox Text="{Binding Heart}" Watermark="https://…" />

      <TextBlock Text="Home URL (optional)" FontSize="11" Foreground="{DynamicResource ReyTextDimBrush}" />
      <TextBox Text="{Binding Home}" Watermark="https://…" />

      <TextBlock Text="Thumbnail (PNG/JPG)" FontSize="11" Foreground="{DynamicResource ReyTextDimBrush}" />
      <StackPanel Orientation="Horizontal" Spacing="6">
        <TextBox Text="{Binding ThumbnailPath}" Width="380" />
        <Button Content="Browse…" Command="{Binding BrowseThumbnailCommand}" />
      </StackPanel>

      <Border Height="1" Background="{DynamicResource ReyBorderBrush}" Margin="0,8" />
      <TextBlock Text="PATHS" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource ReyTextDimBrush}" />

      <TextBlock Text="Game folder (powers reference fallback)" FontSize="11" Foreground="{DynamicResource ReyTextDimBrush}" />
      <StackPanel Orientation="Horizontal" Spacing="6">
        <TextBox Text="{Binding GameDirectory}" Width="380" />
        <Button Content="Browse…" Command="{Binding BrowseGameCommand}" />
      </StackPanel>

      <TextBlock Text="Build output folder" FontSize="11" Foreground="{DynamicResource ReyTextDimBrush}" />
      <StackPanel Orientation="Horizontal" Spacing="6">
        <TextBox Text="{Binding OutputDirectory}" Width="380" />
        <Button Content="Browse…" Command="{Binding BrowseOutputCommand}" />
      </StackPanel>

      <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right" Margin="0,12,0,0">
        <Button Content="Cancel" Command="{Binding CancelCommand}" Padding="14,5" />
        <Button Content="Save" Command="{Binding SaveCommand}" Padding="18,5"
                Background="{DynamicResource ReyAccentBrush}" Foreground="#08221E" />
      </StackPanel>
    </StackPanel>
  </ScrollViewer>
</Window>
