<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:ReyEngine.App.Views"
        xmlns:vm="clr-namespace:ReyEngine.App.ViewModels"
        x:Class="ReyEngine.App.Views.SettingsWindow"
        Title="ReyEngine — Settings"
        Width="880" Height="640"
        WindowStartupLocation="CenterOwner"
        ExtendClientAreaToDecorationsHint="True"
        Background="{DynamicResource ReyBgBrush}"
        Foreground="{DynamicResource ReyTextBrush}"
        FontFamily="Inter, Segoe UI, sans-serif">

  <!-- M72: modern settings dialog — left sidebar navigation + card sections + footer actions -->
  <DockPanel>
    <local:ReyTitleBar DockPanel.Dock="Top" />

    <!-- header -->
    <Border DockPanel.Dock="Top" Padding="24,18,24,12">
      <TextBlock Text="Settings" FontSize="19" FontWeight="Bold"
                 Foreground="{DynamicResource ReyTextBrightBrush}" />
    </Border>

    <!-- footer -->
    <Border DockPanel.Dock="Bottom" BorderBrush="{DynamicResource ReyBorderSoftBrush}"
            BorderThickness="0,1,0,0" Padding="24,12">
      <Grid ColumnDefinitions="Auto,*,Auto,Auto">
        <Button Grid.Column="0" Classes="tool" Content="↺ Reset to Defaults" Command="{Binding ResetDefaultsCommand}" />
        <Button Grid.Column="2" Classes="tool" Content="Cancel" Command="{Binding CancelCommand}" Padding="18,7" />
        <Button Grid.Column="3" Classes="success" Content="✓ Save Settings" Command="{Binding SaveCommand}" Margin="10,0,0,0" />
      </Grid>
    </Border>

    <Grid ColumnDefinitions="212,*" Margin="14,0,0,0">

      <!-- ── sidebar navigation ─────────────────────────────────────────── -->
      <ListBox Grid.Column="0" Classes="settingsNav" Margin="4,4,10,10"
               SelectedIndex="{Binding SelectedSection}">
        <ListBoxItem>
          <StackPanel Orientation="Horizontal" Spacing="10">
            <TextBlock Text="⚙" FontSize="13" Width="18" TextAlignment="Center" />
            <TextBlock Text="General" VerticalAlignment="Center" />
          </StackPanel>
        </ListBoxItem>
        <ListBoxItem>
          <StackPanel Orientation="Horizontal" Spacing="10">
            <TextBlock Text="🎥" FontSize="13" Width="18" TextAlignment="Center" />
            <TextBlock Text="Camera" VerticalAlignment="Center" />
          </StackPanel>
        </ListBoxItem>
        <ListBoxItem>
          <StackPanel Orientation="Horizontal" Spacing="10">
            <TextBlock Text="⌨" FontSize="13" Width="18" TextAlignment="Center" />
            <TextBlock Text="Controls" VerticalAlignment="Center" />
          </StackPanel>
        </ListBoxItem>
        <ListBoxItem>
          <StackPanel Orientation="Horizontal" Spacing="10">
            <TextBlock Text="🎨" FontSize="13" Width="18" TextAlignment="Center" />
            <TextBlock Text="Theme" VerticalAlignment="Center" />
          </StackPanel>
        </ListBoxItem>
        <ListBoxItem>
          <StackPanel Orientation="Horizontal" Spacing="10">
            <TextBlock Text="🗺" FontSize="13" Width="18" TextAlignment="Center" />
            <TextBlock Text="Preview" VerticalAlignment="Center" />
          </StackPanel>
        </ListBoxItem>
      </ListBox>

      <!-- ── content ────────────────────────────────────────────────────── -->
      <ScrollViewer Grid.Column="1" Padding="4,4,24,10">
       <Panel>

        <!-- GENERAL -->
        <StackPanel Spacing="14" IsVisible="{Binding ShowGeneral}">
          <Border Classes="settingsCard">
            <StackPanel Spacing="8">
              <TextBlock Classes="settingsTitle" Text="VIEWPORT DEFAULTS" />
              <TextBlock Classes="settingsDesc"
                         Text="Applied whenever content loads. Per-session toggles in the viewport toolbar override these until the next load." />
              <CheckBox Content="Cull backfaces by default" IsChecked="{Binding CullBackfacesDefault}"
                        FontSize="12" Margin="0,4,0,0" />
              <TextBlock Classes="settingsDesc"
                         Text="Respects each material's cullEnable flag on load. Turn off to force two-sided rendering everywhere." />
            </StackPanel>
          </Border>
        </StackPanel>

        <!-- CAMERA -->
        <StackPanel Spacing="14" IsVisible="{Binding ShowCamera}">
          <Border Classes="settingsCard">
            <StackPanel Spacing="12">
              <TextBlock Classes="settingsTitle" Text="SENSITIVITY" />
              <TextBlock Classes="settingsDesc"
                         Text="Multipliers on the viewport camera feel — 1.00× is the built-in default." />
              <StackPanel Spacing="2">
                <Grid ColumnDefinitions="*,Auto"><TextBlock Grid.Column="0" Text="Mouse Look" FontSize="12"/><TextBlock Grid.Column="1" Classes="mono" Text="{Binding MouseLookSensitivity, StringFormat='{}{0:0.00}×'}"/></Grid>
                <Slider Minimum="0.2" Maximum="3.0" Value="{Binding MouseLookSensitivity}" />
              </StackPanel>
              <StackPanel Spacing="2">
                <Grid ColumnDefinitions="*,Auto"><TextBlock Grid.Column="0" Text="Orbit" FontSize="12"/><TextBlock Grid.Column="1" Classes="mono" Text="{Binding OrbitSensitivity, StringFormat='{}{0:0.00}×'}"/></Grid>
                <Slider Minimum="0.2" Maximum="3.0" Value="{Binding OrbitSensitivity}" />
              </StackPanel>
              <StackPanel Spacing="2">
                <Grid ColumnDefinitions="*,Auto"><TextBlock Grid.Column="0" Text="Pan" FontSize="12"/><TextBlock Grid.Column="1" Classes="mono" Text="{Binding PanSensitivity, StringFormat='{}{0:0.00}×'}"/></Grid>
                <Slider Minimum="0.2" Maximum="3.0" Value="{Binding PanSensitivity}" />
              </StackPanel>
              <StackPanel Spacing="2">
                <Grid ColumnDefinitions="*,Auto"><TextBlock Grid.Column="0" Text="Zoom" FontSize="12"/><TextBlock Grid.Column="1" Classes="mono" Text="{Binding ZoomSensitivity, StringFormat='{}{0:0.00}×'}"/></Grid>
                <Slider Minimum="0.2" Maximum="3.0" Value="{Binding ZoomSensitivity}" />
              </StackPanel>
              <CheckBox Content="Invert look Y axis" IsChecked="{Binding InvertLookY}" FontSize="12" />
            </StackPanel>
          </Border>

          <Border Classes="settingsCard">
            <StackPanel Spacing="8">
              <TextBlock Classes="settingsTitle" Text="MOVEMENT" />
              <Grid ColumnDefinitions="*,Auto"><TextBlock Grid.Column="0" Text="Base fly speed" FontSize="12"/><TextBlock Grid.Column="1" Classes="mono" Text="{Binding FlySpeed, StringFormat='{}{0:0} u/s'}"/></Grid>
              <Slider Minimum="100" Maximum="5000" Value="{Binding FlySpeed}" />
              <TextBlock Classes="settingsDesc"
                         Text="Starting WASD speed; the mouse wheel still scales it live while flying." />
            </StackPanel>
          </Border>
        </StackPanel>

        <!-- CONTROLS -->
        <StackPanel Spacing="14" IsVisible="{Binding ShowControls}">
          <Border Classes="settingsCard">
            <StackPanel Spacing="8">
              <TextBlock Classes="settingsTitle" Text="VIEWPORT KEYBINDS" />
              <TextBlock Classes="settingsDesc"
                         Text="Hold the left mouse button to fly with these keys. Click a binding, then press the key to reassign it." />
              <ItemsControl ItemsSource="{Binding Keybinds}" Margin="0,4,0,0">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Grid ColumnDefinitions="*,180" Margin="0,3">
                      <TextBlock Grid.Column="0" Text="{Binding Label}" FontSize="12"
                                 Foreground="{DynamicResource ReyTextBrush}" VerticalAlignment="Center" />
                      <ToggleButton Grid.Column="1" Classes="vp" IsChecked="{Binding IsCapturing, Mode=OneWay}"
                                    Content="{Binding Display}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                    Command="{Binding $parent[ItemsControl].DataContext.StartCaptureCommand}"
                                    CommandParameter="{Binding}" />
                    </Grid>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </Border>

          <Border Classes="settingsCard">
            <StackPanel Spacing="8">
              <TextBlock Classes="settingsTitle" Text="FIXED SHORTCUTS" />
              <StackPanel Spacing="4">
                <Grid ColumnDefinitions="*,Auto"><TextBlock Grid.Column="0" Text="Undo / Redo" FontSize="12"/><TextBlock Grid.Column="1" Classes="mono" Text="Ctrl+Z / Ctrl+Y"/></Grid>
                <Grid ColumnDefinitions="*,Auto"><TextBlock Grid.Column="0" Text="Orbit around pivot" FontSize="12"/><TextBlock Grid.Column="1" Classes="mono" Text="Alt + LMB"/></Grid>
                <Grid ColumnDefinitions="*,Auto"><TextBlock Grid.Column="0" Text="Pan" FontSize="12"/><TextBlock Grid.Column="1" Classes="mono" Text="Middle Mouse"/></Grid>
                <Grid ColumnDefinitions="*,Auto"><TextBlock Grid.Column="0" Text="Zoom / Fly speed" FontSize="12"/><TextBlock Grid.Column="1" Classes="mono" Text="Wheel / LMB+Wheel"/></Grid>
                <Grid ColumnDefinitions="*,Auto"><TextBlock Grid.Column="0" Text="Open Settings" FontSize="12"/><TextBlock Grid.Column="1" Classes="mono" Text="Ctrl+,"/></Grid>
              </StackPanel>
            </StackPanel>
          </Border>
        </StackPanel>

        <!-- THEME -->
        <StackPanel Spacing="14" IsVisible="{Binding ShowTheme}">
          <Border Classes="settingsCard">
            <StackPanel Spacing="10">
              <TextBlock Classes="settingsTitle" Text="EDITOR THEME" />
              <TextBlock Classes="settingsDesc"
                         Text="Click a theme to preview it live across the whole editor. Save keeps it; Cancel reverts." />
              <ItemsControl ItemsSource="{Binding Themes}" Margin="0,6,0,0">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate>
                    <WrapPanel />
                  </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="vm:ThemeItemViewModel">
                    <Button Classes="themeCard" Classes.selected="{Binding IsSelected}" Width="188" Margin="0,0,12,12"
                            Command="{Binding $parent[ItemsControl].DataContext.SelectThemeCommand}"
                            CommandParameter="{Binding}">
                      <StackPanel Spacing="8">
                        <!-- swatch preview: surface tile with an accent bar -->
                        <Border Height="52" CornerRadius="6" Background="{Binding Surface}"
                                BorderBrush="{DynamicResource ReyBorderBrush}" BorderThickness="1">
                          <StackPanel Margin="8" Spacing="4" VerticalAlignment="Center">
                            <Border Height="8" Width="64" CornerRadius="4" Background="{Binding Accent}" HorizontalAlignment="Left" />
                            <Border Height="5" Width="104" CornerRadius="2.5" Background="#33FFFFFF" HorizontalAlignment="Left" />
                            <Border Height="5" Width="84" CornerRadius="2.5" Background="#22FFFFFF" HorizontalAlignment="Left" />
                          </StackPanel>
                        </Border>
                        <StackPanel Spacing="1">
                          <TextBlock Text="{Binding Name}" FontSize="12.5" FontWeight="SemiBold"
                                     Foreground="{DynamicResource ReyTextBrightBrush}" />
                          <TextBlock Text="{Binding Tagline}" FontSize="10.5"
                                     Foreground="{DynamicResource ReyTextDimBrush}" />
                        </StackPanel>
                      </StackPanel>
                    </Button>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </Border>
        </StackPanel>

        <!-- PREVIEW (M88) -->
        <StackPanel Spacing="14" IsVisible="{Binding ShowPreview}">
          <Border Classes="settingsCard">
            <StackPanel Spacing="10">
              <TextBlock Classes="settingsTitle" Text="MODEL PREVIEW BACKDROP" />
              <TextBlock Classes="settingsDesc"
                         Text="Render a classic (NVR) League map behind previewed characters, lit by the map's own lights — so a skin looks like it does in-game. Point this at a LEVELS\Map folder containing Scene\room.nvr." />
              <CheckBox Content="Show map backdrop in the model preview"
                        IsChecked="{Binding PreviewBackgroundEnabled}" Margin="0,4,0,0" />
              <TextBlock Classes="settingsDesc" Text="Map folder" Margin="0,4,0,0" />
              <Grid ColumnDefinitions="*,Auto">
                <TextBox Grid.Column="0" Text="{Binding PreviewBackgroundMapFolder}"
                         Watermark="e.g. K:\LeagueSandbox\League_Sandbox_Client\LEVELS\Map8" />
                <Button Grid.Column="1" Content="Browse…" Margin="8,0,0,0" Click="OnBrowsePreviewMap" />
              </Grid>
            </StackPanel>
          </Border>
        </StackPanel>

       </Panel>
      </ScrollViewer>
    </Grid>
  </DockPanel>
</Window>
