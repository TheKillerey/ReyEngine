<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:ReyEngine.App.Views"
        xmlns:vm="clr-namespace:ReyEngine.App.ViewModels"
        xmlns:conv="clr-namespace:ReyEngine.App.Converters"
        x:Class="ReyEngine.App.Views.MainWindow"
        Title="{Binding Title}"
        Width="1500" Height="900"
        MinWidth="1000" MinHeight="640"
        Background="{DynamicResource ReyBgBrush}"
        Foreground="{DynamicResource ReyTextBrush}"
        FontFamily="Inter, Segoe UI, sans-serif">

  <Window.Resources>
    <conv:LogLevelToBrushConverter x:Key="LevelToBrush" />
    <conv:BoolToBrushConverter x:Key="SelectionHighlight" TrueBrush="#3336E2C2" FalseBrush="Transparent" />
  </Window.Resources>

  <DockPanel>

    <!-- ============ TOP MENU ============ -->
    <Grid DockPanel.Dock="Top" ColumnDefinitions="Auto,*" Background="{DynamicResource ReyHeaderBrush}">
      <Image x:Name="LogoImage" Grid.Column="0" Height="24" Margin="10,3,6,3"
             VerticalAlignment="Center" ToolTip.Tip="ReyEngine" />
    <Menu Grid.Column="1" Background="Transparent">
      <MenuItem Header="_File">
        <MenuItem Header="Open Project Folder…" Command="{Binding OpenProjectFolderCommand}" />
        <MenuItem Header="Open Recent" ItemsSource="{Binding RecentProjectList}">
          <MenuItem.ItemContainerTheme>
            <ControlTheme TargetType="MenuItem">
              <Setter Property="Header" Value="{Binding Name}" />
              <Setter Property="Command" Value="{Binding $parent[Menu].DataContext.OpenRecentProjectCommand}" />
              <Setter Property="CommandParameter" Value="{Binding Path}" />
            </ControlTheme>
          </MenuItem.ItemContainerTheme>
        </MenuItem>
        <MenuItem Header="New Project…" Command="{Binding NewProjectCommand}" />
        <MenuItem Header="Open Project…" Command="{Binding OpenProjectCommand}" />
        <MenuItem Header="Save Project" Command="{Binding SaveProjectCommand}" />
        <MenuItem Header="Save Project As…" Command="{Binding SaveProjectAsCommand}" />
        <Separator />
        <MenuItem Header="Open WAD (inspect)…" Command="{Binding OpenWadCommand}" />
        <MenuItem Header="Export Selected…" Command="{Binding ExportSelectedCommand}" />
        <Separator />
        <MenuItem Header="Exit" Command="{Binding ExitCommand}" />
      </MenuItem>
      <MenuItem Header="_Edit">
        <MenuItem Header="{Binding UndoLabel}" Command="{Binding UndoCommand}" IsEnabled="{Binding CanUndo}" InputGesture="Ctrl+Z" />
        <MenuItem Header="{Binding RedoLabel}" Command="{Binding RedoCommand}" IsEnabled="{Binding CanRedo}" InputGesture="Ctrl+Y" />
        <Separator />
        <MenuItem Header="Clear Console" Command="{Binding ClearConsoleCommand}" />
      </MenuItem>
      <MenuItem Header="_View">
        <MenuItem Header="Reload WAD" Command="{Binding ReloadWadCommand}" />
      </MenuItem>
      <MenuItem Header="_Tools">
        <MenuItem Header="Sync Hashes (CommunityDragon)" Command="{Binding SyncHashesCommand}" />
        <MenuItem Header="Reload Local Hashes" Command="{Binding ReloadLocalHashesCommand}" />
        <Separator />
        <MenuItem Header="Hash Lookup" Command="{Binding HashLookupCommand}" />
        <MenuItem Header="Assign Skeleton…" Command="{Binding AssignSkeletonCommand}" />
        <MenuItem Header="Assign Animation…" Command="{Binding AssignAnimationCommand}" />
        <MenuItem Header="Scan Riot Shaders" Command="{Binding ScanRiotShadersCommand}" />
        <MenuItem Header="Export Shader Dump…" Command="{Binding ExportShaderDumpCommand}" />
        <MenuItem Header="Map Material Diagnostics" Command="{Binding MapMaterialDiagnosticsCommand}"
                  ToolTip.Tip="Scan the loaded map's bins + mapgeo and write an honest diagnostics report (classes, unknown fields, lighting/lightmap/visibility) to .reyengine/reports/" />
        <MenuItem Header="Build Package" Command="{Binding BuildPackageCommand}" />
      </MenuItem>
      <MenuItem Header="_Project">
        <MenuItem Header="Build Package" Command="{Binding BuildPackageCommand}" />
        <MenuItem Header="Open Build Folder" Command="{Binding OpenBuildFolderCommand}" />
        <Separator />
        <MenuItem Header="Export .fantome…" Command="{Binding ExportFantomeCommand}" />
        <Separator />
        <MenuItem Header="Project Settings…" Command="{Binding OpenProjectSettingsCommand}" />
        <MenuItem Header="Manage Riot References…" Command="{Binding ManageRiotReferencesCommand}" />
        <MenuItem Header="Set Game Folder…" Command="{Binding SetGameFolderCommand}" />
        <MenuItem Header="Sync Hashes" Command="{Binding SyncHashesCommand}" />
      </MenuItem>
      <MenuItem Header="_Help">
        <MenuItem Header="About ReyEngine" IsEnabled="False" />
      </MenuItem>
    </Menu>
    </Grid>

    <!-- ============ TOOLBAR ============ -->
    <Border DockPanel.Dock="Top"
            Background="{DynamicResource ReyHeaderBrush}"
            BorderBrush="{DynamicResource ReyBorderBrush}"
            BorderThickness="0,1,0,1" Padding="8,6">
      <StackPanel Orientation="Horizontal">
        <Button Classes="tool" Content="Import" Command="{Binding OpenWadCommand}" />
        <Button Classes="tool" Content="Export" Command="{Binding ExportSelectedCommand}" />
        <Button Classes="tool" Content="Reload WAD" Command="{Binding ReloadWadCommand}" />
        <Button Classes="tool" Content="Sync Hashes" Command="{Binding SyncHashesCommand}" />
        <Button Classes="tool" Content="Build Package" Command="{Binding BuildPackageCommand}" />
        <Button Classes="tool" Content="Shader Preview" Command="{Binding ShaderPreviewCommand}" />
        <Border Width="1" Background="{DynamicResource ReyBorderBrush}" Margin="6,2" />
        <TextBox Width="240" VerticalAlignment="Center" Margin="0,0,4,0"
                 Watermark="path or string to hash"
                 Text="{Binding HashInput, Mode=TwoWay}" />
        <Button Classes="tool" Content="Hash Lookup" Command="{Binding HashLookupCommand}" />
      </StackPanel>
    </Border>

    <!-- ============ INSPECTION-MODE BANNER (M11) ============ -->
    <Border DockPanel.Dock="Top" Background="#2A2113" BorderBrush="#FFB454" BorderThickness="0,0,0,1"
            Padding="10,4" IsVisible="{Binding InspectionMode}">
      <TextBlock Text="🔍 Single-WAD inspection mode — open a project folder (File ▸ Open Project Folder) to edit and build mods."
                 Foreground="#FFD9A0" FontSize="11" />
    </Border>

    <!-- ============ STATUS BAR ============ -->
    <Border DockPanel.Dock="Bottom"
            Background="{DynamicResource ReyHeaderBrush}"
            BorderBrush="{DynamicResource ReyBorderBrush}"
            BorderThickness="0,1,0,0" Padding="10,4">
      <DockPanel>
        <TextBlock DockPanel.Dock="Right" Text="{Binding SelectionStatus}" Foreground="{DynamicResource ReyAccentBrush}"
                   FontSize="11" IsVisible="{Binding SelectionStatus, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
        <TextBlock Text="{Binding Status}" Foreground="{DynamicResource ReyTextDimBrush}" FontSize="11" />
      </DockPanel>
    </Border>

    <!-- ============ MAIN AREA ============ -->
    <Grid ColumnDefinitions="290,4,*,4,360">

      <!-- LEFT: MAP CONTENT (World Outliner) -->
      <Border Grid.Column="0" Background="{DynamicResource ReyPanelBrush}">
        <DockPanel>
          <TextBlock Classes="panelHeader" DockPanel.Dock="Top" Text="MAP CONTENT" />
          <TextBlock DockPanel.Dock="Top" Text="{Binding MapContent.Summary}"
                     Foreground="{DynamicResource ReyTextDimBrush}" FontSize="10" Margin="8,2,8,4" TextWrapping="Wrap" />

          <!-- project maps -->
          <ScrollViewer DockPanel.Dock="Top" MaxHeight="180">
            <ItemsControl ItemsSource="{Binding MapContent.Maps}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Button Classes="tool" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Margin="6,1"
                          Command="{Binding $parent[ItemsControl].DataContext.MapContent.OpenCommand}"
                          CommandParameter="{Binding}">
                    <StackPanel Orientation="Horizontal" Spacing="5">
                      <TextBlock Text="🗺" FontSize="11" />
                      <TextBlock Text="{Binding Name}" FontSize="11" TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                  </Button>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>

          <Border DockPanel.Dock="Top" Height="1" Background="{DynamicResource ReyBorderBrush}" Margin="0,6"
                  IsVisible="{Binding MapContent.HasMap}" />
          <TextBlock DockPanel.Dock="Top" Text="{Binding MapContent.MapName}" Foreground="{DynamicResource ReyAccentBrush}"
                     FontSize="11" FontWeight="SemiBold" Margin="8,0,8,2" IsVisible="{Binding MapContent.HasMap}" />

          <!-- dragon / baron visibility layer selectors -->
          <StackPanel DockPanel.Dock="Top" Margin="8,2,8,4" Spacing="3" IsVisible="{Binding MapContent.HasMap}">
            <TextBlock Text="VISIBILITY LAYERS" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource ReyTextDimBrush}" />
            <Grid ColumnDefinitions="*,*">
              <StackPanel Grid.Column="0" Margin="0,0,3,0">
                <TextBlock Text="Dragon" FontSize="9" Foreground="{DynamicResource ReyTextDimBrush}" />
                <ComboBox ItemsSource="{Binding DragonOptions}" SelectedIndex="{Binding SelectedDragonIndex}"
                          FontSize="10" HorizontalAlignment="Stretch" />
              </StackPanel>
              <StackPanel Grid.Column="1" Margin="3,0,0,0">
                <TextBlock Text="Baron" FontSize="9" Foreground="{DynamicResource ReyTextDimBrush}" />
                <ComboBox ItemsSource="{Binding BaronOptions}" SelectedIndex="{Binding SelectedBaronIndex}"
                          FontSize="10" HorizontalAlignment="Stretch"
                          ToolTip.Tip="Baron pit state. Resolves the map's visibility controllers (Base/Cup/Tunnel/Upgraded) and hides meshes that don't belong to the selected state." />
              </StackPanel>
            </Grid>
          </StackPanel>

          <!-- BATCH transform panel (M30) — shown when 2+ meshes are selected -->
          <Border DockPanel.Dock="Bottom" Background="{DynamicResource ReyPanelAltBrush}" Padding="8,6" Margin="0,4,0,0"
                  IsVisible="{Binding IsMultiSelect}">
            <StackPanel Spacing="4">
              <TextBlock Text="BATCH TRANSFORM" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource ReyTextDimBrush}" />
              <TextBlock Text="{Binding SelectionStatus}" FontSize="11" Foreground="{DynamicResource ReyAccentBrush}" />
              <TextBlock Text="Rotate/scale act around the selection center. Move is a world delta added to every mesh."
                         FontSize="9" Foreground="{DynamicResource ReyTextDimBrush}" TextWrapping="Wrap" />

              <TextBlock Text="Move Δ (world)" FontSize="9" Foreground="{DynamicResource ReyTextDimBrush}" Margin="0,2,0,0" />
              <Grid ColumnDefinitions="Auto,*,Auto,*,Auto,*" RowDefinitions="Auto">
                <TextBlock Grid.Column="0" Text="X" FontSize="10" VerticalAlignment="Center" Margin="0,0,3,0" Foreground="{DynamicResource ReyTextDimBrush}" />
                <TextBox Grid.Column="1" Text="{Binding BatchMoveX}" FontSize="10" Padding="3,1" />
                <TextBlock Grid.Column="2" Text="Y" FontSize="10" VerticalAlignment="Center" Margin="5,0,3,0" Foreground="{DynamicResource ReyTextDimBrush}" />
                <TextBox Grid.Column="3" Text="{Binding BatchMoveY}" FontSize="10" Padding="3,1" />
                <TextBlock Grid.Column="4" Text="Z" FontSize="10" VerticalAlignment="Center" Margin="5,0,3,0" Foreground="{DynamicResource ReyTextDimBrush}" />
                <TextBox Grid.Column="5" Text="{Binding BatchMoveZ}" FontSize="10" Padding="3,1" />
              </Grid>
              <Button Content="Move Selection" Command="{Binding ApplyBatchMoveCommand}" FontSize="11" Padding="8,2" HorizontalAlignment="Left" />

              <TextBlock Text="Rotate Δ (degrees, about center)" FontSize="9" Foreground="{DynamicResource ReyTextDimBrush}" Margin="0,4,0,0" />
              <Grid ColumnDefinitions="Auto,*,Auto,*,Auto,*" RowDefinitions="Auto">
                <TextBlock Grid.Column="0" Text="X" FontSize="10" VerticalAlignment="Center" Margin="0,0,3,0" Foreground="{DynamicResource ReyTextDimBrush}" />
                <TextBox Grid.Column="1" Text="{Binding BatchRotateX}" FontSize="10" Padding="3,1" />
                <TextBlock Grid.Column="2" Text="Y" FontSize="10" VerticalAlignment="Center" Margin="5,0,3,0" Foreground="{DynamicResource ReyTextDimBrush}" />
                <TextBox Grid.Column="3" Text="{Binding BatchRotateY}" FontSize="10" Padding="3,1" />
                <TextBlock Grid.Column="4" Text="Z" FontSize="10" VerticalAlignment="Center" Margin="5,0,3,0" Foreground="{DynamicResource ReyTextDimBrush}" />
                <TextBox Grid.Column="5" Text="{Binding BatchRotateZ}" FontSize="10" Padding="3,1" />
              </Grid>
              <Button Content="Rotate Selection" Command="{Binding ApplyBatchRotateCommand}" FontSize="11" Padding="8,2" HorizontalAlignment="Left" />

              <TextBlock Text="Scale Δ (about center)" FontSize="9" Foreground="{DynamicResource ReyTextDimBrush}" Margin="0,4,0,0" />
              <Grid ColumnDefinitions="Auto,*,Auto,*,Auto,*" RowDefinitions="Auto">
                <TextBlock Grid.Column="0" Text="X" FontSize="10" VerticalAlignment="Center" Margin="0,0,3,0" Foreground="{DynamicResource ReyTextDimBrush}" />
                <TextBox Grid.Column="1" Text="{Binding BatchScaleX}" FontSize="10" Padding="3,1" />
                <TextBlock Grid.Column="2" Text="Y" FontSize="10" VerticalAlignment="Center" Margin="5,0,3,0" Foreground="{DynamicResource ReyTextDimBrush}" />
                <TextBox Grid.Column="3" Text="{Binding BatchScaleY}" FontSize="10" Padding="3,1" />
                <TextBlock Grid.Column="4" Text="Z" FontSize="10" VerticalAlignment="Center" Margin="5,0,3,0" Foreground="{DynamicResource ReyTextDimBrush}" />
                <TextBox Grid.Column="5" Text="{Binding BatchScaleZ}" FontSize="10" Padding="3,1" />
              </Grid>
              <Button Content="Scale Selection" Command="{Binding ApplyBatchScaleCommand}" FontSize="11" Padding="8,2" HorizontalAlignment="Left" />

              <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,4,0,0">
                <Button Content="Reset Selected" Command="{Binding ResetSelectedCommand}" FontSize="11" Padding="8,2"
                        ToolTip.Tip="Restore every selected mesh to its original transform" />
                <Button Content="Clear Selection" Command="{Binding ClearSelectionCommand}" FontSize="11" Padding="8,2" />
                <Button Content="Save to Mod" Command="{Binding SaveMeshMovesCommand}" FontSize="11" Padding="8,2"
                        IsEnabled="{Binding HasMapMoves}"
                        Background="{DynamicResource ReyAccentBrush}" Foreground="#08221E" />
              </StackPanel>
            </StackPanel>
          </Border>

          <!-- mesh transform panel (move / rotate / scale — shown when exactly ONE mesh is selected) -->
          <Border DockPanel.Dock="Bottom" Background="{DynamicResource ReyPanelAltBrush}" Padding="8,6" Margin="0,4,0,0"
                  IsVisible="{Binding IsSingleSelect}">
            <StackPanel Spacing="4">
              <TextBlock Text="TRANSFORM MESH" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource ReyTextDimBrush}" />
              <TextBlock Text="{Binding SelectedMapMesh.Name}" FontSize="11" Foreground="{DynamicResource ReyAccentBrush}" TextTrimming="CharacterEllipsis" />

              <TextBlock Text="Position" FontSize="9" Foreground="{DynamicResource ReyTextDimBrush}" Margin="0,2,0,0" />
              <Grid ColumnDefinitions="Auto,*,Auto,*,Auto,*" RowDefinitions="Auto">
                <TextBlock Grid.Column="0" Text="X" FontSize="10" VerticalAlignment="Center" Margin="0,0,3,0" Foreground="{DynamicResource ReyTextDimBrush}" />
                <TextBox Grid.Column="1" Text="{Binding MeshMoveX}" FontSize="10" Padding="3,1" />
                <TextBlock Grid.Column="2" Text="Y" FontSize="10" VerticalAlignment="Center" Margin="5,0,3,0" Foreground="{DynamicResource ReyTextDimBrush}" />
                <TextBox Grid.Column="3" Text="{Binding MeshMoveY}" FontSize="10" Padding="3,1" />
                <TextBlock Grid.Column="4" Text="Z" FontSize="10" VerticalAlignment="Center" Margin="5,0,3,0" Foreground="{DynamicResource ReyTextDimBrush}" />
                <TextBox Grid.Column="5" Text="{Binding MeshMoveZ}" FontSize="10" Padding="3,1" />
              </Grid>

              <TextBlock Text="Rotation (degrees)" FontSize="9" Foreground="{DynamicResource ReyTextDimBrush}" Margin="0,2,0,0" />
              <Grid ColumnDefinitions="Auto,*,Auto,*,Auto,*" RowDefinitions="Auto">
                <TextBlock Grid.Column="0" Text="X" FontSize="10" VerticalAlignment="Center" Margin="0,0,3,0" Foreground="{DynamicResource ReyTextDimBrush}" />
                <TextBox Grid.Column="1" Text="{Binding MeshRotateX}" FontSize="10" Padding="3,1" />
                <TextBlock Grid.Column="2" Text="Y" FontSize="10" VerticalAlignment="Center" Margin="5,0,3,0" Foreground="{DynamicResource ReyTextDimBrush}" />
                <TextBox Grid.Column="3" Text="{Binding MeshRotateY}" FontSize="10" Padding="3,1" />
                <TextBlock Grid.Column="4" Text="Z" FontSize="10" VerticalAlignment="Center" Margin="5,0,3,0" Foreground="{DynamicResource ReyTextDimBrush}" />
                <TextBox Grid.Column="5" Text="{Binding MeshRotateZ}" FontSize="10" Padding="3,1" />
              </Grid>

              <TextBlock Text="Scale" FontSize="9" Foreground="{DynamicResource ReyTextDimBrush}" Margin="0,2,0,0" />
              <Grid ColumnDefinitions="Auto,*,Auto,*,Auto,*" RowDefinitions="Auto">
                <TextBlock Grid.Column="0" Text="X" FontSize="10" VerticalAlignment="Center" Margin="0,0,3,0" Foreground="{DynamicResource ReyTextDimBrush}" />
                <TextBox Grid.Column="1" Text="{Binding MeshScaleX}" FontSize="10" Padding="3,1" />
                <TextBlock Grid.Column="2" Text="Y" FontSize="10" VerticalAlignment="Center" Margin="5,0,3,0" Foreground="{DynamicResource ReyTextDimBrush}" />
                <TextBox Grid.Column="3" Text="{Binding MeshScaleY}" FontSize="10" Padding="3,1" />
                <TextBlock Grid.Column="4" Text="Z" FontSize="10" VerticalAlignment="Center" Margin="5,0,3,0" Foreground="{DynamicResource ReyTextDimBrush}" />
                <TextBox Grid.Column="5" Text="{Binding MeshScaleZ}" FontSize="10" Padding="3,1" />
              </Grid>

              <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,2,0,0">
                <Button Content="Apply" Command="{Binding ApplyMeshMoveCommand}" FontSize="11" Padding="8,2"
                        ToolTip.Tip="Apply position/rotation/scale live in the viewport" />
                <Button Content="Reset" Command="{Binding ResetMeshTransformCommand}" FontSize="11" Padding="8,2"
                        ToolTip.Tip="Restore this mesh's original transform" />
                <Button Content="Save to Mod" Command="{Binding SaveMeshMovesCommand}" FontSize="11" Padding="8,2"
                        IsEnabled="{Binding HasMapMoves}"
                        Background="{DynamicResource ReyAccentBrush}" Foreground="#08221E" />
              </StackPanel>
            </StackPanel>
          </Border>

          <!-- Mesh Details (M33) — read-only metadata for the selected mapgeo mesh -->
          <Expander DockPanel.Dock="Bottom" Margin="0,4,0,0" IsExpanded="True"
                    IsVisible="{Binding MeshDetails.HasMesh}" FontSize="11">
            <Expander.Header>
              <StackPanel Orientation="Horizontal" Spacing="6">
                <TextBlock Text="MESH DETAILS" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource ReyTextDimBrush}" VerticalAlignment="Center" />
                <TextBlock Text="{Binding MeshDetails.Title}" FontSize="11" Foreground="{DynamicResource ReyAccentBrush}"
                           TextTrimming="CharacterEllipsis" MaxWidth="170" VerticalAlignment="Center" />
              </StackPanel>
            </Expander.Header>
            <ScrollViewer MaxHeight="260" HorizontalScrollBarVisibility="Disabled">
              <ItemsControl ItemsSource="{Binding MeshDetails.Rows}" Margin="2,0">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Grid ColumnDefinitions="120,*" Margin="0,1">
                      <TextBlock Grid.Column="0" Text="{Binding Label}" FontSize="10" Foreground="{DynamicResource ReyTextDimBrush}" VerticalAlignment="Top" />
                      <TextBlock Grid.Column="1" Text="{Binding Value}" FontSize="10" TextWrapping="Wrap"
                                 Foreground="{DynamicResource ReyTextBrush}" />
                    </Grid>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </ScrollViewer>
          </Expander>

          <!-- Meshes → Layer Groups → mesh names.  Ctrl+click a mesh row toggles multi-select (M30). -->
          <TreeView x:Name="MapContentTree"
                    ItemsSource="{Binding MapContent.LayerGroups}" SelectedItem="{Binding SelectedTreeItem, Mode=TwoWay}"
                    Background="Transparent" BorderThickness="0" Padding="4,0">
            <TreeView.DataTemplates>
              <TreeDataTemplate DataType="vm:MapLayerGroupViewModel" ItemsSource="{Binding Meshes}">
                <StackPanel Orientation="Horizontal" Spacing="5">
                  <TextBlock Text="🗂" FontSize="10" VerticalAlignment="Center" />
                  <TextBlock Text="{Binding Name}" FontSize="11" FontWeight="SemiBold"
                             Foreground="{DynamicResource ReyAccentBrush}" VerticalAlignment="Center" />
                </StackPanel>
              </TreeDataTemplate>
              <DataTemplate DataType="vm:MapPieceViewModel">
                <Border Background="{Binding IsSelected, Converter={StaticResource SelectionHighlight}}"
                        CornerRadius="2" Padding="3,0" Margin="-3,0">
                  <StackPanel Orientation="Horizontal" Spacing="5">
                    <TextBlock Text="🧊" FontSize="9" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding Name}" FontSize="10" Foreground="{DynamicResource ReyTextBrush}"
                               TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                  </StackPanel>
                </Border>
              </DataTemplate>
            </TreeView.DataTemplates>
          </TreeView>
        </DockPanel>
      </Border>

      <GridSplitter Grid.Column="1" Background="{DynamicResource ReyBorderBrush}" />

      <!-- CENTER: Viewport + Console -->
      <Grid Grid.Column="2" RowDefinitions="*,4,300,4,170">
        <Border Grid.Row="0" Background="{DynamicResource ReyBgBrush}">
          <Grid>
            <views:ViewportControl x:Name="Viewport"
                Mesh="{Binding CurrentMesh}"
                ModelTextures="{Binding CurrentModelTextures}"
                ModelMaskTextures="{Binding CurrentModelMaskTextures}"
                ModelGradientTextures="{Binding CurrentModelGradientTextures}"
                ModelEmissiveTextures="{Binding CurrentModelEmissiveTextures}"
                ModelMatCapTextures="{Binding CurrentModelMatCapTextures}"
                ModelMatCapMaskTextures="{Binding CurrentModelMatCapMaskTextures}"
                ModelSubmeshVisible="{Binding CurrentModelSubmeshVisible}"
                ModelSubmeshMaterials="{Binding CurrentModelSubmeshMaterials}"
                MeshVerticesRevision="{Binding MeshVerticesRevision}"
                SelectionBoxes="{Binding SelectionBoxes}"
                GroupBoundsMin="{Binding GroupBoundsMin}"
                GroupBoundsMax="{Binding GroupBoundsMax}"
                GizmoPivot="{Binding GizmoPivot}"
                Skeleton="{Binding CurrentSkeleton}"
                AnimationClip="{Binding CurrentAnimation}"
                AnimationTime="{Binding AnimationTime}"
                Wireframe="{Binding ShowWireframe}"
                ShowBones="{Binding ShowBones}"
                ShowBounds="{Binding ShowBounds}"
                PreviewMode="{Binding PreviewMode}" />

            <!-- transparent surface that forwards pointer input to the viewport camera -->
            <Border x:Name="ViewportInput" Background="Transparent"
                    Focusable="True"
                    PointerPressed="OnViewportPointerPressed"
                    PointerMoved="OnViewportPointerMoved"
                    PointerReleased="OnViewportPointerReleased"
                    PointerWheelChanged="OnViewportPointerWheel"
                    KeyDown="OnViewportKeyDown"
                    KeyUp="OnViewportKeyUp" />

            <!-- view toggles (above the input surface so they stay clickable) -->
            <StackPanel Orientation="Horizontal" Spacing="4" Margin="10"
                        HorizontalAlignment="Right" VerticalAlignment="Top">
              <Button Content="↶" FontSize="13" Padding="7,2" Command="{Binding UndoCommand}"
                      IsEnabled="{Binding CanUndo}" ToolTip.Tip="{Binding UndoLabel}" />
              <Button Content="↷" FontSize="13" Padding="7,2" Command="{Binding RedoCommand}"
                      IsEnabled="{Binding CanRedo}" ToolTip.Tip="{Binding RedoLabel}" />
              <ComboBox SelectedIndex="{Binding PreviewMode}" FontSize="11" MinWidth="120" VerticalAlignment="Center"
                        ToolTip.Tip="Preview shading mode">
                <ComboBoxItem>Basic</ComboBoxItem>
                <ComboBoxItem>Riot Approx</ComboBoxItem>
                <ComboBoxItem>Debug · Base</ComboBoxItem>
                <ComboBoxItem>Debug · Alpha</ComboBoxItem>
                <ComboBoxItem>Debug · Normals</ComboBoxItem>
                <ComboBoxItem>Debug · Mask</ComboBoxItem>
                <ComboBoxItem>Debug · Emissive</ComboBoxItem>
                <ComboBoxItem>Debug · MatCap</ComboBoxItem>
                <ComboBoxItem>Debug · UV Checker</ComboBoxItem>
                <ComboBoxItem>Debug · Specular</ComboBoxItem>
                <ComboBoxItem>Debug · Vertex Color</ComboBoxItem>
              </ComboBox>
              <ToggleButton Content="Wireframe" IsChecked="{Binding ShowWireframe}" FontSize="11" Padding="8,3" />
              <ToggleButton Content="Bones" IsChecked="{Binding ShowBones}" FontSize="11" Padding="8,3" />
              <ToggleButton Content="Bounds" IsChecked="{Binding ShowBounds}" FontSize="11" Padding="8,3" />
              <Button Content="Frame" Click="OnFrameClick" FontSize="11" Padding="8,3" />
            </StackPanel>

            <Border Background="#66000000" CornerRadius="4" Padding="8,3"
                    HorizontalAlignment="Left" VerticalAlignment="Top" Margin="10" IsHitTestVisible="False">
              <TextBlock Text="VIEWPORT  ·  LMB orbit · Shift+LMB pan · wheel zoom"
                         FontSize="10" Foreground="{DynamicResource ReyTextDimBrush}" />
            </Border>
          </Grid>
        </Border>

        <GridSplitter Grid.Row="1" Background="{DynamicResource ReyBorderBrush}" />

        <!-- CONTENT BROWSER (Unreal/Windows-style: folder tree + tiles) -->
        <Border Grid.Row="2" Background="{DynamicResource ReyPanelBrush}">
          <DockPanel>
            <Grid DockPanel.Dock="Top" ColumnDefinitions="Auto,Auto,*,Auto">
              <TextBlock Classes="panelHeader" Text="CONTENT BROWSER" VerticalAlignment="Center" />
              <Button Grid.Column="1" Classes="tool" Content="↑ Up" Margin="6,4"
                      Command="{Binding ContentBrowser.GoUpCommand}" IsEnabled="{Binding ContentBrowser.CanGoUp}" />
              <TextBlock Grid.Column="2" Text="{Binding ContentBrowser.LocationText}" VerticalAlignment="Center"
                         Foreground="{DynamicResource ReyTextDimBrush}" FontSize="11" FontFamily="Cascadia Mono, Consolas, monospace"
                         TextTrimming="CharacterEllipsis" />
              <TextBox Grid.Column="3" Width="150" Watermark="Filter…" Text="{Binding ContentBrowser.Filter}"
                       FontSize="11" Margin="6,4,8,4" Padding="4,2" />
            </Grid>
            <Grid ColumnDefinitions="200,4,*">
              <TreeView Grid.Column="0" ItemsSource="{Binding ContentBrowser.FolderRoots}"
                        SelectedItem="{Binding ContentBrowser.SelectedFolder, Mode=TwoWay}"
                        Background="Transparent" BorderThickness="0">
                <TreeView.ItemTemplate>
                  <TreeDataTemplate ItemsSource="{Binding Folders}">
                    <StackPanel Orientation="Horizontal" Spacing="5">
                      <TextBlock Text="{Binding Icon}" FontSize="12" VerticalAlignment="Center" />
                      <TextBlock Text="{Binding Name}" FontSize="12" Foreground="{DynamicResource ReyTextBrush}" VerticalAlignment="Center" />
                    </StackPanel>
                  </TreeDataTemplate>
                </TreeView.ItemTemplate>
              </TreeView>
              <GridSplitter Grid.Column="1" Background="{DynamicResource ReyBorderBrush}" />
              <ScrollViewer Grid.Column="2" Padding="6,4">
                <ItemsControl ItemsSource="{Binding ContentBrowser.Items}">
                  <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
                  </ItemsControl.ItemsPanel>
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Button Width="94" Height="82" Margin="4" Padding="2" Background="Transparent"
                              Command="{Binding $parent[ItemsControl].DataContext.ContentBrowser.OpenCommand}"
                              CommandParameter="{Binding}" ToolTip.Tip="{Binding Name}">
                        <Button.ContextMenu>
                          <ContextMenu>
                            <MenuItem Header="Copy Asset To Project" Command="{Binding $parent[Window].DataContext.CopyAssetToProjectCommand}" />
                            <MenuItem Header="Replace Selected Asset…" Command="{Binding $parent[Window].DataContext.ReplaceSelectedCommand}" />
                            <MenuItem Header="Revert Asset" Command="{Binding $parent[Window].DataContext.RevertSelectedCommand}" />
                            <Separator />
                            <MenuItem Header="Export…" Command="{Binding $parent[Window].DataContext.ExportSelectedCommand}" />
                            <MenuItem Header="Copy Resolved Path" Command="{Binding $parent[Window].DataContext.CopyResolvedPathCommand}" />
                            <MenuItem Header="Copy Hash" Command="{Binding $parent[Window].DataContext.CopyHashCommand}" />
                          </ContextMenu>
                        </Button.ContextMenu>
                        <StackPanel>
                          <Border Background="{DynamicResource ReyPanelAltBrush}" CornerRadius="4" Width="58" Height="42" HorizontalAlignment="Center">
                            <Grid>
                              <TextBlock Text="{Binding Icon}" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center" />
                              <TextBlock Text="{Binding Kind}" FontSize="7" FontWeight="SemiBold" HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                         Margin="0,0,3,2" Foreground="{DynamicResource ReyAccentBrush}" />
                            </Grid>
                          </Border>
                          <StackPanel Orientation="Horizontal" Spacing="2" HorizontalAlignment="Center" Margin="0,3,0,0">
                            <TextBlock Text="🔒" FontSize="8" VerticalAlignment="Center" IsVisible="{Binding IsReadOnly}" />
                            <TextBlock Text="⚠" FontSize="8" Foreground="#FFB454" VerticalAlignment="Center" IsVisible="{Binding HasConflict}" />
                            <Ellipse Width="6" Height="6" VerticalAlignment="Center" Fill="{DynamicResource ReyAccent2Brush}" IsVisible="{Binding IsModified}" />
                            <TextBlock Text="{Binding Name}" FontSize="9" Foreground="{DynamicResource ReyTextBrush}"
                                       TextTrimming="CharacterEllipsis" MaxWidth="78" VerticalAlignment="Center" />
                          </StackPanel>
                        </StackPanel>
                      </Button>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </ScrollViewer>
            </Grid>
          </DockPanel>
        </Border>

        <GridSplitter Grid.Row="3" Background="{DynamicResource ReyBorderBrush}" />

        <Border Grid.Row="4" Background="{DynamicResource ReyPanelBrush}">
          <DockPanel>
            <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto">
              <TextBlock Classes="panelHeader" Text="CONSOLE · IMPORT LOG" />
              <Button Grid.Column="1" Classes="tool" Content="Clear"
                      Command="{Binding ClearConsoleCommand}" Margin="0,4,8,0" />
            </Grid>
            <ListBox Classes="console" ItemsSource="{Binding Console.Entries}"
                     Background="Transparent" BorderThickness="0" Padding="6,0">
              <ListBox.ItemTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding}"
                             FontFamily="Cascadia Mono, Consolas, monospace" FontSize="12"
                             Foreground="{Binding Level, Converter={StaticResource LevelToBrush}}" />
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>
          </DockPanel>
        </Border>
      </Grid>

      <GridSplitter Grid.Column="3" Background="{DynamicResource ReyBorderBrush}" />

      <!-- RIGHT: Inspector -->
      <Border Grid.Column="4" Background="{DynamicResource ReyPanelBrush}">
        <DockPanel>
          <TextBlock Classes="panelHeader" DockPanel.Dock="Top" Text="INSPECTOR" />
          <ScrollViewer>
            <StackPanel Margin="12" Spacing="10">
              <TextBlock Text="{Binding Inspector.Title}" Foreground="{DynamicResource ReyTextBrush}"
                         FontSize="15" FontWeight="SemiBold" TextWrapping="Wrap" />
              <Border Background="{DynamicResource ReyPanelAltBrush}" CornerRadius="3"
                      Padding="6,2" HorizontalAlignment="Left">
                <TextBlock Text="{Binding Inspector.Subtitle}" Foreground="{DynamicResource ReyAccentBrush}" FontSize="11" />
              </Border>

              <!-- project asset status -->
              <StackPanel Orientation="Horizontal" Spacing="6">
                <Ellipse Width="8" Height="8" VerticalAlignment="Center"
                         Fill="{DynamicResource ReyAccent2Brush}" IsVisible="{Binding Inspector.IsModified}" />
                <TextBlock Text="{Binding Inspector.AssetStatus}" FontSize="11"
                           Foreground="{DynamicResource ReyTextDimBrush}" VerticalAlignment="Center" />
              </StackPanel>
              <TextBlock Text="{Binding Inspector.AssetSource}" FontSize="10"
                         Foreground="{DynamicResource ReyAccent2Brush}" IsVisible="{Binding Inspector.IsModified}" />

              <!-- texture preview -->
              <Border Background="{DynamicResource ReyBgBrush}" CornerRadius="4" Padding="8"
                      IsVisible="{Binding Inspector.HasPreview}">
                <Image Source="{Binding Inspector.PreviewImage}" Stretch="Uniform" MaxHeight="340" />
              </Border>

              <TextBlock Text="{Binding Inspector.Details}" Foreground="{DynamicResource ReyTextDimBrush}"
                         FontFamily="Cascadia Mono, Consolas, monospace" FontSize="11" TextWrapping="Wrap" />

              <!-- note (e.g. bin placeholder) -->
              <Border Background="{DynamicResource ReyPanelAltBrush}" CornerRadius="4" Padding="8"
                      IsVisible="{Binding Inspector.HasNote}">
                <TextBlock Text="{Binding Inspector.Note}" Foreground="{DynamicResource ReyAccent2Brush}"
                           FontSize="11" TextWrapping="Wrap" />
              </Border>

              <!-- INSPECTOR TABS (M8): Overview / Materials / Raw BIN Tree -->
              <TabControl SelectedIndex="{Binding InspectorTab}" IsVisible="{Binding HasInspectorBody}" Padding="0" Margin="0,4,0,0">
                <TabItem FontSize="12">
                  <TabItem.Header><TextBlock Text="Overview" FontSize="12" /></TabItem.Header>
                  <StackPanel Spacing="10" Margin="0,8,0,0">

              <!-- mesh stats (SKN) -->
              <StackPanel Spacing="8" IsVisible="{Binding MeshInspector.HasMesh}">
                <Border Height="1" Background="{DynamicResource ReyBorderBrush}" />
                <TextBlock Text="MESH" Foreground="{DynamicResource ReyTextDimBrush}" FontSize="11" FontWeight="SemiBold" />
                <TextBlock Text="{Binding MeshInspector.Stats}" Foreground="{DynamicResource ReyTextDimBrush}"
                           FontFamily="Cascadia Mono, Consolas, monospace" FontSize="11" />
                <TextBlock Text="{Binding MeshInspector.SkeletonStatus}" Foreground="{DynamicResource ReyAccentBrush}" FontSize="11" />
                <Button Classes="tool" Content="Assign Skeleton…" HorizontalAlignment="Left"
                        Command="{Binding AssignSkeletonCommand}" />
                <TextBlock Text="Submeshes / materials" Foreground="{DynamicResource ReyTextDimBrush}" FontSize="11" />
                <TextBlock Text="{Binding MeshInspector.SubMeshes}" Foreground="{DynamicResource ReyTextBrush}"
                           FontFamily="Cascadia Mono, Consolas, monospace" FontSize="11" TextWrapping="Wrap" />
              </StackPanel>

              <!-- animation -->
              <StackPanel Spacing="6" IsVisible="{Binding MeshInspector.HasMesh}">
                <Border Height="1" Background="{DynamicResource ReyBorderBrush}" />
                <TextBlock Text="ANIMATION" Foreground="{DynamicResource ReyTextDimBrush}" FontSize="11" FontWeight="SemiBold" />
                <TextBlock Text="{Binding Animation.SkeletonStatus}" Foreground="{DynamicResource ReyAccentBrush}" FontSize="11" />

                <ComboBox HorizontalAlignment="Stretch" PlaceholderText="Select animation…"
                          ItemsSource="{Binding Animation.Animations}"
                          SelectedItem="{Binding Animation.SelectedAnimation, Mode=TwoWay}"
                          IsVisible="{Binding Animation.HasAnimations}">
                  <ComboBox.ItemTemplate>
                    <DataTemplate>
                      <TextBlock Text="{Binding Name}" FontSize="11" />
                    </DataTemplate>
                  </ComboBox.ItemTemplate>
                </ComboBox>
                <Button Classes="tool" Content="Assign Animation…" HorizontalAlignment="Left"
                        Command="{Binding AssignAnimationCommand}" />

                <StackPanel Orientation="Horizontal" Spacing="4" IsVisible="{Binding Animation.HasClip}">
                  <Button Classes="tool" Content="◀|" Command="{Binding Animation.StepBackCommand}" />
                  <Button Classes="tool" Content="Play / Pause" Command="{Binding Animation.TogglePlayCommand}" />
                  <Button Classes="tool" Content="|▶" Command="{Binding Animation.StepForwardCommand}" />
                  <CheckBox Content="Loop" IsChecked="{Binding Animation.Loop}" VerticalAlignment="Center" FontSize="11" />
                </StackPanel>
                <Slider Minimum="0" Maximum="{Binding Animation.Duration}" Value="{Binding Animation.Time, Mode=TwoWay}"
                        IsVisible="{Binding Animation.HasClip}" />
                <TextBlock Text="{Binding Animation.TimeText}" Foreground="{DynamicResource ReyTextDimBrush}"
                           FontFamily="Cascadia Mono, Consolas, monospace" FontSize="11" IsVisible="{Binding Animation.HasClip}" />
                <StackPanel Orientation="Horizontal" Spacing="6" IsVisible="{Binding Animation.HasClip}">
                  <TextBlock Text="Speed" Foreground="{DynamicResource ReyTextDimBrush}" FontSize="11" VerticalAlignment="Center" />
                  <Slider Minimum="0.1" Maximum="2" Value="{Binding Animation.Speed, Mode=TwoWay}" Width="130" />
                  <TextBlock Text="{Binding Animation.Speed, StringFormat='{}{0:0.0}x'}" Foreground="{DynamicResource ReyTextBrush}" FontSize="11" VerticalAlignment="Center" />
                </StackPanel>
              </StackPanel>

              <!-- mapgeo stats -->
              <StackPanel Spacing="8" IsVisible="{Binding MapGeoInspector.HasMap}">
                <Border Height="1" Background="{DynamicResource ReyBorderBrush}" />
                <TextBlock Text="MAP GEOMETRY" Foreground="{DynamicResource ReyTextDimBrush}" FontSize="11" FontWeight="SemiBold" />
                <TextBlock Text="{Binding MapGeoInspector.Stats}" Foreground="{DynamicResource ReyTextDimBrush}"
                           FontFamily="Cascadia Mono, Consolas, monospace" FontSize="11" TextWrapping="Wrap" />
                <TextBlock Text="{Binding MapGeoInspector.Warnings}" Foreground="{DynamicResource ReyAccent2Brush}"
                           FontSize="11" TextWrapping="Wrap" IsVisible="{Binding MapGeoInspector.HasWarnings}" />
              </StackPanel>

                  </StackPanel>
                </TabItem>

                <!-- MATERIALS TAB -->
                <TabItem FontSize="12" IsVisible="{Binding HasMaterialData}">
                  <TabItem.Header><TextBlock Text="Materials" FontSize="12" /></TabItem.Header>
                  <ScrollViewer MaxHeight="680">
                    <StackPanel Spacing="8" Margin="0,8,4,0">
                      <TextBlock Text="{Binding MaterialEditor.Summary}" Foreground="{DynamicResource ReyTextBrush}" FontSize="12" FontWeight="SemiBold" />
                      <Border Background="{DynamicResource ReyPanelAltBrush}" CornerRadius="4" Padding="6,4">
                        <StackPanel Spacing="2">
                          <TextBlock Text="SHADER BINDING" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource ReyTextDimBrush}" />
                          <TextBlock Text="{Binding ShaderDbStatus}" FontSize="11" Foreground="{DynamicResource ReyTextDimBrush}" TextWrapping="Wrap" />
                          <TextBlock Text="The sampler slots below are the material's bound textures (required samplers). Switch the viewport to 'Riot Approx' to preview." FontSize="10" Foreground="{DynamicResource ReyTextDimBrush}" TextWrapping="Wrap" />
                        </StackPanel>
                      </Border>
                      <Border Background="{DynamicResource ReyPanelAltBrush}" CornerRadius="4" Padding="6" IsVisible="{Binding MaterialEditor.HasUnresolved}">
                        <TextBlock Text="⚠ Some texture paths don't resolve in this WAD — see the ⚠ slots below." Foreground="#FFB454" FontSize="11" TextWrapping="Wrap" />
                      </Border>
                      <TextBox Watermark="Search materials / textures…" Text="{Binding MaterialEditor.Search}" FontSize="11" Padding="4,2" />
                      <StackPanel Orientation="Horizontal" Spacing="10">
                        <CheckBox Content="Only unresolved" IsChecked="{Binding MaterialEditor.OnlyUnresolved}" FontSize="11" />
                        <Ellipse Width="7" Height="7" Fill="{DynamicResource ReyAccent2Brush}" VerticalAlignment="Center" IsVisible="{Binding MaterialEditor.IsDirty}" ToolTip.Tip="Unsaved edits" />
                      </StackPanel>
                      <StackPanel Orientation="Horizontal" Spacing="4">
                        <Button Classes="tool" Content="Apply (preview)" Command="{Binding MaterialEditor.ApplyCommand}" />
                        <Button Classes="tool" Content="Save To Override" Command="{Binding MaterialEditor.SaveCommand}" />
                        <Button Classes="tool" Content="Revert All" Command="{Binding MaterialEditor.RevertAllCommand}" />
                      </StackPanel>

                      <ItemsControl ItemsSource="{Binding MaterialEditor.Materials}">
                        <ItemsControl.ItemTemplate>
                          <DataTemplate>
                            <Border IsVisible="{Binding IsVisible}" Background="{DynamicResource ReyBgBrush}" CornerRadius="4" Padding="8" Margin="0,0,0,6">
                              <StackPanel Spacing="5">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                  <TextBlock Text="{Binding Name}" Foreground="{DynamicResource ReyTextBrush}" FontSize="12" FontWeight="SemiBold" TextWrapping="Wrap" />
                                  <Ellipse Width="7" Height="7" Fill="{DynamicResource ReyAccent2Brush}" VerticalAlignment="Center" IsVisible="{Binding IsDirty}" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                  <TextBlock Text="{Binding ShaderName}" Foreground="{DynamicResource ReyTextDimBrush}" FontSize="10" VerticalAlignment="Center" />
                                  <TextBlock Text="{Binding AssignedTo, StringFormat='→ {0}'}" Foreground="{DynamicResource ReyAccentBrush}" FontSize="10" VerticalAlignment="Center" IsVisible="{Binding HasAssignment}" />
                                </StackPanel>

                                <!-- M32: preview profile (features + UV transform) -->
                                <Border Background="{DynamicResource ReyPanelAltBrush}" CornerRadius="3" Padding="6,4">
                                  <StackPanel Spacing="2">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                      <Border Background="{DynamicResource ReyAccentBrush}" CornerRadius="3" Padding="5,1">
                                        <TextBlock Text="{Binding ProfileLabel}" Foreground="#08221E" FontSize="9" FontWeight="SemiBold" />
                                      </Border>
                                      <TextBlock Text="{Binding FeatureSummary}" Foreground="{DynamicResource ReyTextDimBrush}" FontSize="10" VerticalAlignment="Center" />
                                      <Border Background="#4D8A5AF0" CornerRadius="3" Padding="5,1" VerticalAlignment="Center" IsVisible="{Binding UsesSpecular}">
                                        <TextBlock Text="SPECULAR" Foreground="{DynamicResource ReyTextBrush}" FontSize="8" FontWeight="SemiBold" />
                                      </Border>
                                      <TextBlock Text="⚠ profile unresolved" Foreground="#FFB454" FontSize="9" VerticalAlignment="Center" IsVisible="{Binding ProfileUnresolved}" />
                                    </StackPanel>
                                    <TextBlock Text="{Binding UvTransformText}" Foreground="{DynamicResource ReyTextDimBrush}" FontSize="10" />
                                    <TextBlock Text="{Binding UvSourceText}" Foreground="{DynamicResource ReyAccentBrush}" FontSize="9" IsVisible="{Binding HasUvSource}" />
                                  </StackPanel>
                                </Border>

                                <StackPanel Orientation="Horizontal" Spacing="4">
                                  <Button Classes="tool" Content="Copy name" Command="{Binding CopyNameCommand}" />
                                  <Button Classes="tool" Content="Revert material" Command="{Binding RevertCommand}" />
                                  <Button Classes="tool" Content="+ Add Sampler" Command="{Binding AddSamplerCommand}" IsVisible="{Binding CanEditSamplers}" />
                                </StackPanel>

                                <ItemsControl ItemsSource="{Binding Slots}">
                                  <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                      <StackPanel Spacing="2" Margin="0,4,0,0">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                          <TextBlock Text="{Binding SamplerName}" Foreground="{DynamicResource ReyTextDimBrush}" FontSize="10" MinWidth="110" VerticalAlignment="Center" />
                                          <Ellipse Width="6" Height="6" Fill="{DynamicResource ReyAccentBrush}" VerticalAlignment="Center" IsVisible="{Binding IsDiffuse}" ToolTip.Tip="Diffuse" />
                                          <TextBlock Text="⚠" Foreground="#FFB454" FontSize="11" VerticalAlignment="Center" IsVisible="{Binding Unresolved}" ToolTip.Tip="Path not found in this WAD" />
                                          <Ellipse Width="6" Height="6" Fill="{DynamicResource ReyAccent2Brush}" VerticalAlignment="Center" IsVisible="{Binding IsDirty}" />
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Spacing="3">
                                          <TextBox Text="{Binding EditedPath}" MinWidth="250" FontSize="10" Padding="4,1" FontFamily="Cascadia Mono, Consolas, monospace">
                                            <TextBox.KeyBindings><KeyBinding Gesture="Enter" Command="{Binding ApplyCommand}" /></TextBox.KeyBindings>
                                          </TextBox>
                                          <Button Content="✓" Command="{Binding ApplyCommand}" FontSize="10" Padding="5,0" ToolTip.Tip="Apply path" />
                                          <Button Content="↺" Command="{Binding RevertCommand}" FontSize="10" Padding="5,0" ToolTip.Tip="Revert" />
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                          <Button Classes="tool" Content="Preview" Command="{Binding PreviewCommand}" />
                                          <Button Classes="tool" Content="Open" Command="{Binding OpenCommand}" />
                                          <Button Classes="tool" Content="Copy" Command="{Binding CopyPathCommand}" />
                                          <Button Classes="tool" Content="Replace Texture…" Command="{Binding ReplaceCommand}" />
                                          <Button Classes="tool" Content="✕" Command="{Binding RemoveCommand}" IsVisible="{Binding CanRemove}" ToolTip.Tip="Remove this sampler" />
                                        </StackPanel>
                                        <Border Background="{DynamicResource ReyBgBrush}" CornerRadius="3" Padding="3" HorizontalAlignment="Left" IsVisible="{Binding HasThumbnail}">
                                          <Image Source="{Binding Thumbnail}" Stretch="Uniform" MaxHeight="96" MaxWidth="96" />
                                        </Border>
                                      </StackPanel>
                                    </DataTemplate>
                                  </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <Expander Header="Parameters" IsVisible="{Binding HasParameters}" FontSize="11" Margin="0,4,0,0">
                                  <ItemsControl ItemsSource="{Binding Parameters}">
                                    <ItemsControl.ItemTemplate>
                                      <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Spacing="4" Margin="0,2,0,0">
                                          <TextBlock Text="{Binding Name}" Foreground="{DynamicResource ReyTextDimBrush}" FontSize="10" MinWidth="110" VerticalAlignment="Center" />
                                          <TextBox Text="{Binding EditedText}" MinWidth="150" FontSize="10" Padding="4,1" IsEnabled="{Binding IsEditable}" FontFamily="Cascadia Mono, Consolas, monospace">
                                            <TextBox.KeyBindings><KeyBinding Gesture="Enter" Command="{Binding ApplyCommand}" /></TextBox.KeyBindings>
                                          </TextBox>
                                          <Button Content="✓" Command="{Binding ApplyCommand}" FontSize="10" Padding="5,0" />
                                          <Button Content="↺" Command="{Binding RevertCommand}" FontSize="10" Padding="5,0" />
                                          <Ellipse Width="6" Height="6" Fill="{DynamicResource ReyAccent2Brush}" VerticalAlignment="Center" IsVisible="{Binding IsDirty}" />
                                          <TextBlock Text="{Binding ErrorText}" Foreground="#FF6B6B" FontSize="9" VerticalAlignment="Center" IsVisible="{Binding HasError}" />
                                        </StackPanel>
                                      </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                  </ItemsControl>
                                </Expander>
                              </StackPanel>
                            </Border>
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                    </StackPanel>
                  </ScrollViewer>
                </TabItem>

                <!-- RAW BIN TREE TAB -->
                <TabItem FontSize="12" IsVisible="{Binding BinEditor.HasBin}">
                  <TabItem.Header><TextBlock Text="Raw BIN Tree" FontSize="12" /></TabItem.Header>

              <!-- bin editor (M7) -->
              <StackPanel Spacing="6" Margin="0,8,0,0" IsVisible="{Binding BinEditor.HasBin}">
                <Border Height="1" Background="{DynamicResource ReyBorderBrush}" />
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <TextBlock Text="BIN EDITOR" Foreground="{DynamicResource ReyTextDimBrush}" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center" />
                  <Ellipse Width="7" Height="7" Fill="{DynamicResource ReyAccent2Brush}" VerticalAlignment="Center"
                           IsVisible="{Binding BinEditor.IsDirty}" ToolTip.Tip="Unsaved edits" />
                </StackPanel>
                <TextBlock Text="{Binding BinEditor.Summary}" Foreground="{DynamicResource ReyTextDimBrush}" FontSize="11" />
                <TextBox Watermark="Filter field names…" Text="{Binding BinEditor.Filter}" FontSize="11" Padding="4,2" />
                <StackPanel Orientation="Horizontal" Spacing="4">
                  <Button Classes="tool" Content="Revert File" Command="{Binding BinEditor.RevertFileCommand}" />
                  <Button Classes="tool" Content="Save To Override" Command="{Binding SaveBinToOverrideCommand}" />
                  <Button Classes="tool" Content="Export BIN…" Command="{Binding ExportEditedBinCommand}" />
                </StackPanel>
                <TreeView ItemsSource="{Binding BinEditor.Roots}" Background="Transparent" BorderThickness="0" MaxHeight="560">
                  <TreeView.ItemTemplate>
                    <TreeDataTemplate ItemsSource="{Binding Children}">
                      <StackPanel Orientation="Horizontal" Spacing="6" IsVisible="{Binding IsVisible}">
                        <TextBlock Text="{Binding Name}" Foreground="{DynamicResource ReyTextBrush}"
                                   FontFamily="Cascadia Mono, Consolas, monospace" FontSize="11" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding TypeName}" Foreground="{DynamicResource ReyTextDimBrush}"
                                   FontSize="10" VerticalAlignment="Center" IsVisible="{Binding IsBranch}" />
                        <!-- editable primitive -->
                        <StackPanel Orientation="Horizontal" Spacing="3" IsVisible="{Binding IsEditable}">
                          <TextBox Text="{Binding EditedText}" MinWidth="150" FontSize="11" Padding="4,1"
                                   FontFamily="Cascadia Mono, Consolas, monospace">
                            <TextBox.KeyBindings>
                              <KeyBinding Gesture="Enter" Command="{Binding ApplyCommand}" />
                            </TextBox.KeyBindings>
                          </TextBox>
                          <Button Content="✓" Command="{Binding ApplyCommand}" FontSize="10" Padding="5,0" ToolTip.Tip="Apply edit" />
                          <Button Content="↺" Command="{Binding RevertCommand}" FontSize="10" Padding="5,0" ToolTip.Tip="Revert field" />
                          <Ellipse Width="7" Height="7" Fill="{DynamicResource ReyAccent2Brush}" VerticalAlignment="Center" IsVisible="{Binding IsDirty}" />
                          <TextBlock Text="{Binding ErrorText}" Foreground="#FF6B6B" FontSize="10" VerticalAlignment="Center" IsVisible="{Binding HasError}" />
                        </StackPanel>
                        <!-- read-only leaf value -->
                        <TextBlock Text="{Binding OriginalText}" Foreground="{DynamicResource ReyAccentBrush}"
                                   FontFamily="Cascadia Mono, Consolas, monospace" FontSize="11" VerticalAlignment="Center"
                                   IsVisible="{Binding IsReadOnlyValue}" />
                        <StackPanel.ContextMenu>
                          <ContextMenu>
                            <MenuItem Header="Copy Field Path" Command="{Binding CopyPathCommand}" />
                            <MenuItem Header="Copy Field Hash" Command="{Binding CopyHashCommand}" />
                            <MenuItem Header="Copy Value" Command="{Binding CopyValueCommand}" />
                          </ContextMenu>
                        </StackPanel.ContextMenu>
                      </StackPanel>
                    </TreeDataTemplate>
                  </TreeView.ItemTemplate>
                </TreeView>
              </StackPanel>
                </TabItem>
              </TabControl>
            </StackPanel>
          </ScrollViewer>
        </DockPanel>
      </Border>

    </Grid>
  </DockPanel>
</Window>
