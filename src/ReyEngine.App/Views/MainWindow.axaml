<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:ReyEngine.App.Views"
        xmlns:vm="clr-namespace:ReyEngine.App.ViewModels"
        xmlns:conv="clr-namespace:ReyEngine.App.Converters"
        x:Class="ReyEngine.App.Views.MainWindow"
        Title="{Binding Title}"
        Width="1500" Height="900"
        MinWidth="1000" MinHeight="640"
        Background="{DynamicResource ReyBgBrush}"
        Foreground="{DynamicResource ReyTextBrush}"
        FontFamily="Inter, Segoe UI, sans-serif"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="PreferSystemChrome"
        ExtendClientAreaTitleBarHeightHint="-1">

  <Window.Resources>
    <conv:LogLevelToBrushConverter x:Key="LevelToBrush" />
    <conv:BoolToBrushConverter x:Key="SelectionHighlight" TrueBrush="#3336E2C2" FalseBrush="Transparent" />
    <conv:BoolToBrushConverter x:Key="ActiveTabUnderline" TrueBrush="#36E2C2" FalseBrush="Transparent" />
    <conv:BoolToBrushConverter x:Key="ActiveTabBg" TrueBrush="#1A36E2C2" FalseBrush="Transparent" />
  </Window.Resources>

  <DockPanel>

    <!-- ============ TOP APP BAR (M39: custom title bar — brand + menu + project) ============ -->
    <Grid DockPanel.Dock="Top" ColumnDefinitions="Auto,Auto,*,Auto" Background="{DynamicResource ReyHeaderBrush}"
          MinHeight="32" PointerPressed="OnTitleBarPointerPressed">
      <Image x:Name="LogoImage" Grid.Column="0" Height="24" Margin="10,3,6,3"
             VerticalAlignment="Center" ToolTip.Tip="ReyEngine" />
      <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="7" VerticalAlignment="Center" Margin="0,0,14,0">
        <TextBlock Text="REYENGINE" FontSize="13" FontWeight="Bold" LetterSpacing="1.5"
                   Foreground="{DynamicResource ReyTextBrightBrush}" VerticalAlignment="Center" />
        <Border Width="1" Height="12" Background="{DynamicResource ReyBorderAccentBrush}" VerticalAlignment="Center" />
        <TextBlock Text="PROJECT KALISTA" FontSize="9" FontWeight="SemiBold" LetterSpacing="2"
                   Foreground="{DynamicResource ReyAccentBrush}" VerticalAlignment="Center" />
      </StackPanel>
      <!-- right margin clears the native caption buttons overlaid on the extended client area -->
      <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="4" Margin="10,0,150,0" VerticalAlignment="Center">
        <TextBlock Text="{Binding Title}" FontSize="11"
                   Foreground="{DynamicResource ReyTextDimBrush}" VerticalAlignment="Center"
                   TextTrimming="CharacterEllipsis" MaxWidth="380" ToolTip.Tip="Active project (* = unsaved changes)" />
        <Button Classes="icon" Content="⚙" FontSize="14" Command="{Binding OpenSettingsCommand}"
                ToolTip.Tip="Preferences — keybinds &amp; camera (Ctrl+,)" />
      </StackPanel>
    <Menu Grid.Column="2" Background="Transparent">
      <MenuItem Header="_File">
        <MenuItem Header="Open Project Folder…" Command="{Binding OpenProjectFolderCommand}" />
        <MenuItem Header="Open Recent" ItemsSource="{Binding RecentProjectList}"
                  IsEnabled="{Binding HasRecentProjects}">
          <MenuItem.ItemContainerTheme>
            <ControlTheme TargetType="MenuItem">
              <Setter Property="Header" Value="{Binding Name}" />
              <Setter Property="Command" Value="{Binding OpenCommand}" />
              <Setter Property="ToolTip.Tip" Value="{Binding Path}" />
            </ControlTheme>
          </MenuItem.ItemContainerTheme>
        </MenuItem>
        <MenuItem Header="New Project…" Command="{Binding NewProjectCommand}" />
        <MenuItem Header="Open Project…" Command="{Binding OpenProjectCommand}" />
        <MenuItem Header="Save Project" Command="{Binding SaveProjectCommand}" />
        <MenuItem Header="Save Project As…" Command="{Binding SaveProjectAsCommand}" />
        <Separator />
        <MenuItem Header="Open WAD (inspect)…" Command="{Binding OpenWadCommand}" />
        <MenuItem Header="Export Selected…" Command="{Binding ExportSelectedCommand}" />
        <Separator />
        <MenuItem Header="Exit" Command="{Binding ExitCommand}" />
      </MenuItem>
      <MenuItem Header="_Edit">
        <MenuItem Header="{Binding UndoLabel}" Command="{Binding UndoCommand}" IsEnabled="{Binding CanUndo}" InputGesture="Ctrl+Z" />
        <MenuItem Header="{Binding RedoLabel}" Command="{Binding RedoCommand}" IsEnabled="{Binding CanRedo}" InputGesture="Ctrl+Y" />
        <Separator />
        <MenuItem Header="Clear Console" Command="{Binding ClearConsoleCommand}" />
        <Separator />
        <MenuItem Header="Preferences…" Command="{Binding OpenSettingsCommand}" InputGesture="Ctrl+," />
      </MenuItem>
      <MenuItem Header="_View">
        <MenuItem Header="Reload WAD" Command="{Binding ReloadWadCommand}" />
      </MenuItem>
      <MenuItem Header="_Tools">
        <MenuItem Header="Sync Hashes (CommunityDragon)" Command="{Binding SyncHashesCommand}" />
        <MenuItem Header="Reload Local Hashes" Command="{Binding ReloadLocalHashesCommand}" />
        <Separator />
        <MenuItem Header="Hash Lookup" Command="{Binding HashLookupCommand}" />
        <MenuItem Header="Assign Skeleton…" Command="{Binding AssignSkeletonCommand}" />
        <MenuItem Header="Assign Animation…" Command="{Binding AssignAnimationCommand}" />
        <MenuItem Header="Scan Riot Shaders" Command="{Binding ScanRiotShadersCommand}" />
        <MenuItem Header="Export Shader Dump…" Command="{Binding ExportShaderDumpCommand}" />
        <MenuItem Header="Map Material Diagnostics" Command="{Binding MapMaterialDiagnosticsCommand}"
                  ToolTip.Tip="Scan the loaded map's bins + mapgeo and write an honest diagnostics report (classes, unknown fields, lighting/lightmap/visibility) to .reyengine/reports/" />
        <MenuItem Header="Open in Particle Editor" Command="{Binding OpenActiveInParticleEditorCommand}"
                  ToolTip.Tip="Open the active document's .bin in the Particle Editor (works for skin bins and map materials.bin that contain VFX systems)" />
        <MenuItem Header="Build Package" Command="{Binding BuildPackageCommand}" />
      </MenuItem>
      <MenuItem Header="_Project">
        <MenuItem Header="Build Package" Command="{Binding BuildPackageCommand}" />
        <MenuItem Header="Open Build Folder" Command="{Binding OpenBuildFolderCommand}" />
        <Separator />
        <MenuItem Header="Export .fantome…" Command="{Binding ExportFantomeCommand}" />
        <Separator />
        <MenuItem Header="Project Settings…" Command="{Binding OpenProjectSettingsCommand}" />
        <MenuItem Header="Manage Riot References…" Command="{Binding ManageRiotReferencesCommand}" />
        <MenuItem Header="Set Game Folder…" Command="{Binding SetGameFolderCommand}" />
        <MenuItem Header="Sync Hashes" Command="{Binding SyncHashesCommand}" />
      </MenuItem>
      <MenuItem Header="_Help">
        <MenuItem Header="Preferences…" Command="{Binding OpenSettingsCommand}" InputGesture="Ctrl+," />
        <Separator />
        <MenuItem Header="About ReyEngine" IsEnabled="False" />
      </MenuItem>
    </Menu>
    </Grid>

    <!-- ============ MAIN TOOLBAR (M39: icon + text, grouped) ============ -->
    <Border DockPanel.Dock="Top"
            Background="{DynamicResource ReyHeaderBrush}"
            BorderBrush="{DynamicResource ReyBorderBrush}"
            BorderThickness="0,1,0,1" Padding="8,5">
      <StackPanel Orientation="Horizontal">
        <!-- assets -->
        <Button Classes="tool" Command="{Binding OpenWadCommand}" ToolTip.Tip="Open a WAD archive for inspection">
          <StackPanel Orientation="Horizontal" Spacing="5"><TextBlock Text="📥" FontSize="11"/><TextBlock Text="Import"/></StackPanel>
        </Button>
        <Button Classes="tool" Command="{Binding ExportSelectedCommand}" ToolTip.Tip="Export the selected asset to disk">
          <StackPanel Orientation="Horizontal" Spacing="5"><TextBlock Text="📤" FontSize="11"/><TextBlock Text="Export"/></StackPanel>
        </Button>
        <Button Classes="tool" Command="{Binding ReloadWadCommand}" ToolTip.Tip="Reload the current WAD/project content">
          <StackPanel Orientation="Horizontal" Spacing="5"><TextBlock Text="⟳" FontSize="12"/><TextBlock Text="Reload"/></StackPanel>
        </Button>
        <Border Width="1" Height="18" Background="{DynamicResource ReyBorderBrush}" Margin="5,0" VerticalAlignment="Center" />
        <!-- data -->
        <Button Classes="tool" Command="{Binding SyncHashesCommand}" ToolTip.Tip="Sync hash tables from CommunityDragon">
          <StackPanel Orientation="Horizontal" Spacing="5"><TextBlock Text="⇅" FontSize="11"/><TextBlock Text="Sync Hashes"/></StackPanel>
        </Button>
        <Button Classes="tool" Command="{Binding ShaderPreviewCommand}" ToolTip.Tip="Riot shader inspection / preview">
          <StackPanel Orientation="Horizontal" Spacing="5"><TextBlock Text="✦" FontSize="11"/><TextBlock Text="Shaders"/></StackPanel>
        </Button>
        <Border Width="1" Height="18" Background="{DynamicResource ReyBorderBrush}" Margin="5,0" VerticalAlignment="Center" />
        <!-- build / ship -->
        <Button Classes="primary" Command="{Binding BuildPackageCommand}" ToolTip.Tip="Build the mod package (repack + validate)">
          <StackPanel Orientation="Horizontal" Spacing="5"><TextBlock Text="📦" FontSize="11"/><TextBlock Text="Build Package"/></StackPanel>
        </Button>
        <Button Classes="tool" Command="{Binding ExportFantomeCommand}" ToolTip.Tip="Export the mod as a .fantome package">
          <StackPanel Orientation="Horizontal" Spacing="5"><TextBlock Text="👻" FontSize="11"/><TextBlock Text=".fantome"/></StackPanel>
        </Button>
        <Border Width="1" Height="18" Background="{DynamicResource ReyBorderBrush}" Margin="5,0" VerticalAlignment="Center" />
        <!-- hash lookup -->
        <TextBox Width="230" VerticalAlignment="Center" Margin="0,0,4,0"
                 Watermark="path or string to hash…"
                 Text="{Binding HashInput, Mode=TwoWay}" />
        <Button Classes="tool" Command="{Binding HashLookupCommand}" ToolTip.Tip="Resolve a path or hash">
          <StackPanel Orientation="Horizontal" Spacing="5"><TextBlock Text="🔎" FontSize="11"/><TextBlock Text="Hash Lookup"/></StackPanel>
        </Button>
      </StackPanel>
    </Border>

    <!-- ============ INSPECTION-MODE BANNER (M11) ============ -->
    <Border DockPanel.Dock="Top" Background="#2A2113" BorderBrush="#FFB454" BorderThickness="0,0,0,1"
            Padding="10,4" IsVisible="{Binding InspectionMode}">
      <TextBlock Text="🔍 Single-WAD inspection mode — open a project folder (File ▸ Open Project Folder) to edit and build mods."
                 Foreground="#FFD9A0" FontSize="11" />
    </Border>

    <!-- ============ STATUS BAR (M39) ============ -->
    <Border DockPanel.Dock="Bottom"
            Background="{DynamicResource ReyHeaderBrush}"
            BorderBrush="{DynamicResource ReyBorderBrush}"
            BorderThickness="0,1,0,0" Padding="10,3">
      <DockPanel>
        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="8">
          <TextBlock Text="{Binding SelectionStatus}" Foreground="{DynamicResource ReyAccentBrush}" FontSize="11" VerticalAlignment="Center"
                     IsVisible="{Binding SelectionStatus, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
          <Border Width="1" Height="11" Background="{DynamicResource ReyBorderBrush}" VerticalAlignment="Center" />
          <TextBlock Text="REYENGINE · PROJECT KALISTA" FontSize="9" LetterSpacing="1.2" FontWeight="SemiBold"
                     Foreground="{DynamicResource ReyTextDimBrush}" VerticalAlignment="Center" />
        </StackPanel>
        <TextBlock Text="{Binding Status}" Foreground="{DynamicResource ReyTextDimBrush}" FontSize="11" VerticalAlignment="Center"
                   TextTrimming="CharacterEllipsis" />
      </DockPanel>
    </Border>

    <!-- ============ MAIN AREA ============ -->
    <Grid ColumnDefinitions="290,4,*,4,360">

      <!-- LEFT: MAP CONTENT (scene outliner — visibility, layer tree, transform, mesh details;
           the redundant .mapgeo list was retired, maps open from the Content Browser + tabs) -->
      <Border Grid.Column="0" Background="{DynamicResource ReyPanelBrush}">
        <DockPanel>
          <TextBlock Classes="panelHeader" DockPanel.Dock="Top" Text="MAP CONTENT" />
          <views:MapOutlinerView />
        </DockPanel>
      </Border>

      <GridSplitter Grid.Column="1" Background="{DynamicResource ReyBorderBrush}" />

      <!-- CENTER: Viewport + Content Browser (top block) · Console (bottom).
           Nesting the viewport + browser means the console splitter trades height with the VIEWPORT,
           not the content browser (M43 fix). -->
      <Grid Grid.Column="2" RowDefinitions="*,4,170">
      <Grid Grid.Row="0" RowDefinitions="*,4,300">
        <Border Grid.Row="0" Background="{DynamicResource ReyBgBrush}">
          <DockPanel>
            <!-- Document / viewport tabs (M33): the loaded map stays alive while other assets are inspected -->
            <Border DockPanel.Dock="Top" Background="{DynamicResource ReyHeaderBrush}"
                    BorderBrush="{DynamicResource ReyBorderBrush}" BorderThickness="0,0,0,1"
                    IsVisible="{Binding ActiveDocument, Converter={x:Static ObjectConverters.IsNotNull}}">
              <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                <ItemsControl ItemsSource="{Binding Documents}">
                  <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate><StackPanel Orientation="Horizontal" /></ItemsPanelTemplate>
                  </ItemsControl.ItemsPanel>
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <!-- M39: document tab — translucent cyan when active + accent underline -->
                      <Border Margin="2,3,0,0" CornerRadius="4,4,0,0" ClipToBounds="True"
                              Background="{Binding IsActive, Converter={StaticResource ActiveTabBg}}">
                        <DockPanel>
                          <Border DockPanel.Dock="Bottom" Height="2" CornerRadius="1"
                                  Background="{Binding IsActive, Converter={StaticResource ActiveTabUnderline}}" />
                          <StackPanel Orientation="Horizontal" Margin="8,4,4,3" Spacing="4">
                            <Button Background="Transparent" BorderThickness="0" Padding="0"
                                    Command="{Binding $parent[ItemsControl].DataContext.ActivateDocumentCommand}" CommandParameter="{Binding}"
                                    ToolTip.Tip="{Binding Title}">
                              <StackPanel Orientation="Horizontal" Spacing="5">
                                <TextBlock Text="{Binding Glyph}" FontSize="11" VerticalAlignment="Center" />
                                <TextBlock Text="{Binding Title}" FontSize="11" VerticalAlignment="Center"
                                           MaxWidth="150" TextTrimming="CharacterEllipsis"
                                           Foreground="{DynamicResource ReyTextBrush}" />
                                <Ellipse Width="6" Height="6" Fill="{DynamicResource ReyAccent2Brush}" VerticalAlignment="Center" IsVisible="{Binding IsDirty}"
                                         ToolTip.Tip="Unsaved changes" />
                              </StackPanel>
                            </Button>
                            <Button Classes="icon" Content="✕" FontSize="10"
                                    Command="{Binding $parent[ItemsControl].DataContext.CloseDocumentCommand}" CommandParameter="{Binding}"
                                    ToolTip.Tip="Close tab" />
                          </StackPanel>
                        </DockPanel>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </ScrollViewer>
            </Border>
          <Grid>
            <views:ViewportControl x:Name="Viewport"
                Mesh="{Binding CurrentMesh}"
                ModelTextures="{Binding CurrentModelTextures}"
                ModelMaskTextures="{Binding CurrentModelMaskTextures}"
                ModelGradientTextures="{Binding CurrentModelGradientTextures}"
                ModelEmissiveTextures="{Binding CurrentModelEmissiveTextures}"
                ModelMatCapTextures="{Binding CurrentModelMatCapTextures}"
                ModelMatCapMaskTextures="{Binding CurrentModelMatCapMaskTextures}"
                ModelLightmapTextures="{Binding CurrentModelLightmapTextures}"
                ModelSubmeshVisible="{Binding CurrentModelSubmeshVisible}"
                ModelSubmeshMaterials="{Binding CurrentModelSubmeshMaterials}"
                MeshVerticesRevision="{Binding MeshVerticesRevision}"
                SelectionBoxes="{Binding SelectionBoxes}"
                GroupBoundsMin="{Binding GroupBoundsMin}"
                GroupBoundsMax="{Binding GroupBoundsMax}"
                GizmoPivot="{Binding GizmoPivot}"
                GizmoMode="{Binding TransformMode}"
                GizmoAxes="{Binding GizmoAxes}"
                Skeleton="{Binding CurrentSkeleton}"
                AnimationClip="{Binding CurrentAnimation}"
                AnimationTime="{Binding AnimationTime}"
                Wireframe="{Binding ShowWireframe}"
                ShowBones="{Binding ShowBones}"
                ShowBounds="{Binding ShowBounds}"
                CullBackfaces="{Binding CullBackfaces}"
                ParticleMarkers="{Binding ParticleMarkers}"
                SelectedParticlePosition="{Binding SelectedParticleMarker}"
                PropMarkers="{Binding PropMarkers}"
                ProbeMarkers="{Binding ProbeMarkers}"
                PropMeshes="{Binding CurrentPropMeshes}"
                ParticlePlayback="{Binding CurrentParticlePlayback}"
                AnimateWater="{Binding HasFlowmapWater}"
                LightmapScale="{Binding CurrentLightmapScale}"
                FocusPoint="{Binding ParticleFocusPoint}"
                PreviewMode="{Binding PreviewMode}" />

            <!-- transparent surface that forwards pointer input to the viewport camera -->
            <Border x:Name="ViewportInput" Background="Transparent"
                    Focusable="True"
                    PointerPressed="OnViewportPointerPressed"
                    PointerMoved="OnViewportPointerMoved"
                    PointerReleased="OnViewportPointerReleased"
                    PointerWheelChanged="OnViewportPointerWheel"
                    KeyDown="OnViewportKeyDown"
                    KeyUp="OnViewportKeyUp" />

            <!-- view toggles (above the input surface so they stay clickable) -->
            <StackPanel Orientation="Horizontal" Spacing="4" Margin="10"
                        HorizontalAlignment="Right" VerticalAlignment="Top">
              <Button Classes="tool" Content="↶" FontSize="13" Padding="7,2" Command="{Binding UndoCommand}"
                      IsEnabled="{Binding CanUndo}" ToolTip.Tip="{Binding UndoLabel}" />
              <Button Classes="tool" Content="↷" FontSize="13" Padding="7,2" Command="{Binding RedoCommand}"
                      IsEnabled="{Binding CanRedo}" ToolTip.Tip="{Binding RedoLabel}" />
              <ComboBox SelectedIndex="{Binding PreviewMode}" FontSize="11" MinWidth="120" VerticalAlignment="Center"
                        ToolTip.Tip="Preview shading mode">
                <ComboBoxItem>Basic</ComboBoxItem>
                <ComboBoxItem>Riot Approx</ComboBoxItem>
                <ComboBoxItem>Debug · Base</ComboBoxItem>
                <ComboBoxItem>Debug · Alpha</ComboBoxItem>
                <ComboBoxItem>Debug · Normals</ComboBoxItem>
                <ComboBoxItem>Debug · Mask</ComboBoxItem>
                <ComboBoxItem>Debug · Emissive</ComboBoxItem>
                <ComboBoxItem>Debug · MatCap</ComboBoxItem>
                <ComboBoxItem>Debug · UV Checker</ComboBoxItem>
                <ComboBoxItem>Debug · Specular</ComboBoxItem>
                <ComboBoxItem>Debug · Vertex Color</ComboBoxItem>
                <ComboBoxItem>Debug · Lightmap</ComboBoxItem>
                <ComboBoxItem>Debug · Face Orientation</ComboBoxItem>
                <ComboBoxItem>Debug · Two-Sided</ComboBoxItem>
                <ComboBoxItem>Debug · Mirrored</ComboBoxItem>
              </ComboBox>
              <ToggleButton Classes="vp" Content="◫ Wire" IsChecked="{Binding ShowWireframe}" ToolTip.Tip="Wireframe overlay" />
              <ToggleButton Classes="vp" Content="◪ Cull" IsChecked="{Binding CullBackfaces}"
                            ToolTip.Tip="Respect each material's cullEnable (single-sided materials cull backfaces; cullEnable=false renders two-sided with flipped-normal lighting). Off = force everything two-sided." />
              <ToggleButton Classes="vp" Content="🦴 Bones" IsChecked="{Binding ShowBones}" ToolTip.Tip="Show skeleton bones" />
              <ToggleButton Classes="vp" Content="▣ Bounds" IsChecked="{Binding ShowBounds}" ToolTip.Tip="Show bounding boxes" />
              <ToggleButton Classes="vp" Content="✧ Particles" IsChecked="{Binding ShowParticles}"
                            IsVisible="{Binding HasParticles}"
                            ToolTip.Tip="Show placed particle-system markers (MapParticle)" />
              <Button Classes="tool" Content="⛶ Frame" Click="OnFrameClick" FontSize="11" Padding="8,3" Margin="0"
                      ToolTip.Tip="Frame the camera on the loaded content" />
            </StackPanel>

            <Border Classes="glass" Padding="9,4"
                    HorizontalAlignment="Left" VerticalAlignment="Top" Margin="10" IsHitTestVisible="False">
              <StackPanel Orientation="Horizontal" Spacing="7">
                <TextBlock Text="VIEWPORT" FontSize="9" FontWeight="SemiBold" LetterSpacing="1.5"
                           Foreground="{DynamicResource ReyAccentBrush}" VerticalAlignment="Center" />
                <Border Width="1" Height="10" Background="{DynamicResource ReyBorderAccentBrush}" VerticalAlignment="Center" />
                <TextBlock Text="LMB orbit · Shift+LMB pan · wheel zoom"
                           FontSize="10" Foreground="{DynamicResource ReyTextDimBrush}" VerticalAlignment="Center" />
              </StackPanel>
            </Border>

            <!-- M42: transform gizmo tools (Move/Rotate/Scale · Local/World · Snap) -->
            <Border Classes="glass" Padding="4,3" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="10,46,0,0"
                    IsVisible="{Binding MapGeoInspector.HasMap}">
              <StackPanel Orientation="Horizontal" Spacing="3">
                <ToggleButton Classes="vp" Content="✥ Move" IsChecked="{Binding IsMoveMode, Mode=OneWay}"
                              Command="{Binding SetTransformModeCommand}" CommandParameter="0" ToolTip.Tip="Move gizmo (translate along an axis)" />
                <ToggleButton Classes="vp" Content="⟳ Rotate" IsChecked="{Binding IsRotateMode, Mode=OneWay}"
                              Command="{Binding SetTransformModeCommand}" CommandParameter="1" ToolTip.Tip="Rotate gizmo (drag a ring — horizontal drag = degrees)" />
                <ToggleButton Classes="vp" Content="⇲ Scale" IsChecked="{Binding IsScaleMode, Mode=OneWay}"
                              Command="{Binding SetTransformModeCommand}" CommandParameter="2" ToolTip.Tip="Scale gizmo (drag an axis handle out/in)" />
                <Border Width="1" Height="14" Background="{DynamicResource ReyBorderAccentBrush}" Margin="3,0" VerticalAlignment="Center" />
                <ToggleButton Classes="vp" Content="{Binding GizmoSpaceLabel}" IsChecked="{Binding GizmoLocalSpace}"
                              MinWidth="52" ToolTip.Tip="Gizmo axes: World or the mesh's Local space" />
                <ToggleButton Classes="vp" Content="⊞ Snap" IsChecked="{Binding SnapEnabled}"
                              ToolTip.Tip="Snap to increments — 100u move · 15° rotate · 0.25× scale" />
              </StackPanel>
            </Border>
          </Grid>
          </DockPanel>
        </Border>

        <GridSplitter Grid.Row="1" Background="{DynamicResource ReyBorderBrush}" />

        <!-- CONTENT BROWSER (Unreal/Windows-style: folder tree + tiles) -->
        <Border Grid.Row="2" Background="{DynamicResource ReyPanelBrush}">
          <DockPanel>
            <Grid DockPanel.Dock="Top" ColumnDefinitions="Auto,Auto,*,Auto,Auto,Auto,Auto">
              <TextBlock Classes="panelHeader" Text="CONTENT BROWSER" VerticalAlignment="Center" />
              <Button Grid.Column="1" Classes="tool" Content="↑ Up" Margin="6,4"
                      Command="{Binding ContentBrowser.GoUpCommand}" IsEnabled="{Binding ContentBrowser.CanGoUp}" />
              <!-- M43: clickable breadcrumb path -->
              <Border Grid.Column="2" Background="{DynamicResource ReyPanelAltBrush}" CornerRadius="4"
                      Padding="4,1" Margin="2,4" VerticalAlignment="Center">
                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                  <StackPanel Orientation="Horizontal" Spacing="0">
                    <Button Classes="icon" Content="⌂" FontSize="12" Command="{Binding ContentBrowser.NavigateCrumbCommand}"
                            CommandParameter="{x:Null}" ToolTip.Tip="Project root" />
                    <ItemsControl ItemsSource="{Binding ContentBrowser.Breadcrumbs}">
                      <ItemsControl.ItemsPanel><ItemsPanelTemplate><StackPanel Orientation="Horizontal" Spacing="0" /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                      <ItemsControl.ItemTemplate>
                        <DataTemplate>
                          <StackPanel Orientation="Horizontal" Spacing="0">
                            <TextBlock Text="›" Foreground="{DynamicResource ReyTextDimBrush}" VerticalAlignment="Center" FontSize="11" Margin="1,0" />
                            <Button Classes="icon" Content="{Binding Name}" FontSize="11"
                                    Command="{Binding $parent[ItemsControl].DataContext.ContentBrowser.NavigateCrumbCommand}"
                                    CommandParameter="{Binding}" />
                          </StackPanel>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </StackPanel>
                </ScrollViewer>
              </Border>
              <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="3" VerticalAlignment="Center" Margin="6,0,2,0">
                <TextBlock Text="{Binding ContentBrowser.ItemCount, StringFormat='{}{0} items'}"
                           VerticalAlignment="Center" FontSize="10" Foreground="{DynamicResource ReyTextDimBrush}" />
                <TextBlock Text="(capped)" VerticalAlignment="Center" FontSize="10" Foreground="{DynamicResource ReyWarningBrush}"
                           IsVisible="{Binding ContentBrowser.SearchTruncated}" ToolTip.Tip="Too many matches — showing the first 4000. Narrow the search or filter." />
              </StackPanel>
              <ComboBox Grid.Column="4" ItemsSource="{Binding ContentBrowser.TypeFilters}" SelectedItem="{Binding ContentBrowser.TypeFilter}"
                        FontSize="11" MinWidth="98" Margin="2,4" ToolTip.Tip="Filter by asset type" />
              <ToggleButton Grid.Column="5" Classes="vp" Content="☰" FontSize="12" Padding="8,3" Margin="2,4"
                            IsChecked="{Binding ContentBrowser.ListView}" ToolTip.Tip="Toggle grid / list view" />
              <TextBox Grid.Column="6" Width="150" Watermark="🔎 Search…" Text="{Binding ContentBrowser.Filter}"
                       FontSize="11" Margin="4,4,8,4" Padding="6,2" />
            </Grid>
            <Grid ColumnDefinitions="200,4,*">
              <TreeView Grid.Column="0" ItemsSource="{Binding ContentBrowser.FolderRoots}"
                        SelectedItem="{Binding ContentBrowser.SelectedFolder, Mode=TwoWay}"
                        Background="Transparent" BorderThickness="0">
                <TreeView.ItemTemplate>
                  <TreeDataTemplate ItemsSource="{Binding Folders}">
                    <StackPanel Orientation="Horizontal" Spacing="5">
                      <TextBlock Text="{Binding Icon}" FontSize="12" VerticalAlignment="Center" />
                      <TextBlock Text="{Binding Name}" FontSize="12" Foreground="{DynamicResource ReyTextBrush}" VerticalAlignment="Center" />
                    </StackPanel>
                  </TreeDataTemplate>
                </TreeView.ItemTemplate>
              </TreeView>
              <GridSplitter Grid.Column="1" Background="{DynamicResource ReyBorderBrush}" />
              <DockPanel Grid.Column="2">
                <!-- M50: the materials quick-list was removed from the Content Browser — selecting a
                     .materials.bin/skin .bin now opens the INSPECTOR's Materials tab (right panel). -->
                <Grid>
                <ScrollViewer Padding="6,4" IsVisible="{Binding !ContentBrowser.ListView}">
                <ItemsControl ItemsSource="{Binding ContentBrowser.Items}">
                  <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
                  </ItemsControl.ItemsPanel>
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Button Width="94" Height="86" Margin="4" Padding="2" Background="Transparent" CornerRadius="5"
                              Command="{Binding $parent[ItemsControl].DataContext.ContentBrowser.OpenCommand}"
                              CommandParameter="{Binding}" ToolTip.Tip="{Binding Name}">
                        <Button.ContextMenu>
                          <ContextMenu>
                            <MenuItem Header="Copy Asset To Project" Command="{Binding $parent[Window].DataContext.CopyAssetToProjectCommand}" />
                            <MenuItem Header="Replace Selected Asset…" Command="{Binding $parent[Window].DataContext.ReplaceSelectedCommand}" />
                            <MenuItem Header="Revert Asset" Command="{Binding $parent[Window].DataContext.RevertSelectedCommand}" />
                            <Separator />
                            <MenuItem Header="Export…" Command="{Binding $parent[Window].DataContext.ExportSelectedCommand}" />
                            <MenuItem Header="Copy Resolved Path" Command="{Binding $parent[Window].DataContext.CopyResolvedPathCommand}" />
                            <MenuItem Header="Copy Hash" Command="{Binding $parent[Window].DataContext.CopyHashCommand}" />
                          </ContextMenu>
                        </Button.ContextMenu>
                        <!-- M39: Unreal-style asset tile — thumb card + type badge + status icons -->
                        <StackPanel>
                          <Border Background="{DynamicResource ReyPanelAltBrush}" BorderBrush="{DynamicResource ReyBorderSoftBrush}"
                                  BorderThickness="1" CornerRadius="5" Width="66" Height="46" HorizontalAlignment="Center" ClipToBounds="True">
                            <Grid>
                              <Image Source="{Binding Thumbnail}" Stretch="UniformToFill" IsVisible="{Binding HasThumbnail}" />
                              <TextBlock Text="{Binding Icon}" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"
                                         IsVisible="{Binding !HasThumbnail}" />
                              <Border Classes="badge accent" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,2,2"
                                      Padding="3,0" IsVisible="{Binding Kind, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                <TextBlock Text="{Binding Kind}" FontSize="7" />
                              </Border>
                              <TextBlock Text="🔒" FontSize="9" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="3,2,0,0"
                                         IsVisible="{Binding IsReadOnly}" ToolTip.Tip="Read-only Riot reference" />
                            </Grid>
                          </Border>
                          <StackPanel Orientation="Horizontal" Spacing="2" HorizontalAlignment="Center" Margin="0,3,0,0">
                            <TextBlock Text="⚠" FontSize="8" Foreground="{DynamicResource ReyWarningBrush}" VerticalAlignment="Center"
                                       IsVisible="{Binding HasConflict}" ToolTip.Tip="Conflicts with another mount" />
                            <Ellipse Width="6" Height="6" VerticalAlignment="Center" Fill="{DynamicResource ReyAccent2Brush}"
                                     IsVisible="{Binding IsModified}" ToolTip.Tip="Modified in this project" />
                            <TextBlock Text="{Binding Name}" FontSize="9" Foreground="{DynamicResource ReyTextBrush}"
                                       TextTrimming="CharacterEllipsis" MaxWidth="78" VerticalAlignment="Center" />
                          </StackPanel>
                        </StackPanel>
                      </Button>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
                </ScrollViewer>

                <!-- M43: compact list view (alternative to the tile grid) -->
                <ScrollViewer Padding="4,2" IsVisible="{Binding ContentBrowser.ListView}">
                  <ItemsControl ItemsSource="{Binding ContentBrowser.Items}">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate>
                        <Button HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Background="Transparent"
                                BorderThickness="0" CornerRadius="3" Padding="6,3"
                                Command="{Binding $parent[ItemsControl].DataContext.ContentBrowser.OpenCommand}"
                                CommandParameter="{Binding}" ToolTip.Tip="{Binding Name}">
                          <Button.ContextMenu>
                            <ContextMenu>
                              <MenuItem Header="Copy Asset To Project" Command="{Binding $parent[Window].DataContext.CopyAssetToProjectCommand}" />
                              <MenuItem Header="Replace Selected Asset…" Command="{Binding $parent[Window].DataContext.ReplaceSelectedCommand}" />
                              <MenuItem Header="Revert Asset" Command="{Binding $parent[Window].DataContext.RevertSelectedCommand}" />
                              <Separator />
                              <MenuItem Header="Export…" Command="{Binding $parent[Window].DataContext.ExportSelectedCommand}" />
                              <MenuItem Header="Copy Resolved Path" Command="{Binding $parent[Window].DataContext.CopyResolvedPathCommand}" />
                              <MenuItem Header="Copy Hash" Command="{Binding $parent[Window].DataContext.CopyHashCommand}" />
                            </ContextMenu>
                          </Button.ContextMenu>
                          <Grid ColumnDefinitions="Auto,32,*,Auto,Auto">
                            <TextBlock Grid.Column="0" Text="{Binding Icon}" FontSize="14" VerticalAlignment="Center" Margin="0,0,6,0" />
                            <Border Grid.Column="1" Classes="badge accent" VerticalAlignment="Center" Padding="3,0"
                                    IsVisible="{Binding Kind, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                              <TextBlock Text="{Binding Kind}" FontSize="7" />
                            </Border>
                            <TextBlock Grid.Column="2" Text="{Binding Name}" FontSize="11" Foreground="{DynamicResource ReyTextBrush}"
                                       TextTrimming="CharacterEllipsis" VerticalAlignment="Center" Margin="6,0" />
                            <TextBlock Grid.Column="3" Text="🔒" FontSize="9" VerticalAlignment="Center" Margin="2,0"
                                       IsVisible="{Binding IsReadOnly}" ToolTip.Tip="Read-only Riot reference" />
                            <Ellipse Grid.Column="4" Width="6" Height="6" VerticalAlignment="Center" Margin="4,0" Fill="{DynamicResource ReyAccent2Brush}"
                                     IsVisible="{Binding IsModified}" ToolTip.Tip="Modified in this project" />
                          </Grid>
                        </Button>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </ScrollViewer>
                </Grid>
              </DockPanel>
            </Grid>
          </DockPanel>
        </Border>
      </Grid>

        <GridSplitter Grid.Row="1" Background="{DynamicResource ReyBorderBrush}" />

        <Border Grid.Row="2" Background="{DynamicResource ReyPanelBrush}">
          <DockPanel>
            <Grid DockPanel.Dock="Top" ColumnDefinitions="Auto,*,Auto">
              <TextBlock Classes="panelHeader" Text="CONSOLE · IMPORT LOG" />
              <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center" Margin="8,0">
                <StackPanel Orientation="Horizontal" Spacing="3"><Ellipse Width="6" Height="6" Fill="{DynamicResource ReyTextDimBrush}" VerticalAlignment="Center"/><TextBlock Text="info" FontSize="9" Foreground="{DynamicResource ReyTextDimBrush}"/></StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="3"><Ellipse Width="6" Height="6" Fill="{DynamicResource ReySuccessBrush}" VerticalAlignment="Center"/><TextBlock Text="success" FontSize="9" Foreground="{DynamicResource ReyTextDimBrush}"/></StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="3"><Ellipse Width="6" Height="6" Fill="{DynamicResource ReyWarningBrush}" VerticalAlignment="Center"/><TextBlock Text="warning" FontSize="9" Foreground="{DynamicResource ReyTextDimBrush}"/></StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="3"><Ellipse Width="6" Height="6" Fill="{DynamicResource ReyErrorBrush}" VerticalAlignment="Center"/><TextBlock Text="error" FontSize="9" Foreground="{DynamicResource ReyTextDimBrush}"/></StackPanel>
              </StackPanel>
              <Button Grid.Column="2" Classes="tool" Content="🗑 Clear"
                      Command="{Binding ClearConsoleCommand}" Margin="0,4,8,0" FontSize="11" />
            </Grid>
            <ListBox Classes="console" ItemsSource="{Binding Console.Entries}"
                     Background="Transparent" BorderThickness="0" Padding="6,0">
              <ListBox.ItemTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding}"
                             FontFamily="Cascadia Mono, Consolas, monospace" FontSize="12"
                             Foreground="{Binding Level, Converter={StaticResource LevelToBrush}}" />
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>
          </DockPanel>
        </Border>
      </Grid>

      <GridSplitter Grid.Column="3" Background="{DynamicResource ReyBorderBrush}" />

      <!-- RIGHT: Inspector -->
      <Border Grid.Column="4" Background="{DynamicResource ReyPanelBrush}">
        <DockPanel>
          <TextBlock Classes="panelHeader" DockPanel.Dock="Top" Text="INSPECTOR" />
          <ScrollViewer>
            <StackPanel Margin="10" Spacing="8">
              <!-- M50: Unity-style scene-object sections (Transform / Mesh Details / Particle / Placeable)
                   for the outliner/viewport selection — moved here from the left outliner -->
              <views:SceneObjectInspectorView />

              <!-- M39: asset identity card — name + type badge + source/modified status -->
              <Border Classes="card">
                <StackPanel Spacing="6">
                  <TextBlock Text="{Binding Inspector.Title}" Foreground="{DynamicResource ReyTextBrightBrush}"
                             FontSize="14" FontWeight="SemiBold" TextWrapping="Wrap" />
                  <StackPanel Orientation="Horizontal" Spacing="6">
                    <Border Classes="badge outline">
                      <TextBlock Text="{Binding Inspector.Subtitle}" />
                    </Border>
                    <Border Classes="badge violet" IsVisible="{Binding Inspector.IsModified}">
                      <TextBlock Text="MODIFIED" />
                    </Border>
                  </StackPanel>
                  <TextBlock Text="{Binding Inspector.AssetStatus}" FontSize="11"
                             Foreground="{DynamicResource ReyTextDimBrush}" TextWrapping="Wrap" />
                  <TextBlock Text="{Binding Inspector.AssetSource}" FontSize="10"
                             Foreground="{DynamicResource ReyAccent2Brush}" IsVisible="{Binding Inspector.IsModified}" TextWrapping="Wrap" />
                </StackPanel>
              </Border>

              <!-- texture preview -->
              <Border Background="{DynamicResource ReyBgBrush}" CornerRadius="4" Padding="8"
                      IsVisible="{Binding Inspector.HasPreview}">
                <Image Source="{Binding Inspector.PreviewImage}" Stretch="Uniform" MaxHeight="340" />
              </Border>

              <TextBlock Text="{Binding Inspector.Details}" Foreground="{DynamicResource ReyTextDimBrush}"
                         FontFamily="Cascadia Mono, Consolas, monospace" FontSize="11" TextWrapping="Wrap" />

              <!-- note (e.g. bin placeholder) -->
              <Border Background="{DynamicResource ReyPanelAltBrush}" CornerRadius="4" Padding="8"
                      IsVisible="{Binding Inspector.HasNote}">
                <TextBlock Text="{Binding Inspector.Note}" Foreground="{DynamicResource ReyAccent2Brush}"
                           FontSize="11" TextWrapping="Wrap" />
              </Border>

              <!-- INSPECTOR TABS (M8): Overview / Materials / Raw BIN Tree -->
              <TabControl SelectedIndex="{Binding InspectorTab}" IsVisible="{Binding HasInspectorBody}" Padding="0" Margin="0,4,0,0">
                <TabItem FontSize="12">
                  <TabItem.Header><TextBlock Text="Overview" FontSize="12" /></TabItem.Header>
                  <StackPanel Spacing="10" Margin="0,8,0,0">

              <!-- mesh stats (SKN) -->
              <Border Classes="card" IsVisible="{Binding MeshInspector.HasMesh}">
                <StackPanel Spacing="7">
                  <TextBlock Classes="cardTitle" Text="MESH" />
                  <TextBlock Classes="mono" Text="{Binding MeshInspector.Stats}" />
                  <TextBlock Text="{Binding MeshInspector.SkeletonStatus}" Foreground="{DynamicResource ReyAccentBrush}" FontSize="11" />
                  <Button Classes="tool" Content="Assign Skeleton…" HorizontalAlignment="Left"
                          Command="{Binding AssignSkeletonCommand}" />
                  <TextBlock Text="Submeshes / materials" Foreground="{DynamicResource ReyTextDimBrush}" FontSize="11" />
                  <TextBlock Classes="mono" Text="{Binding MeshInspector.SubMeshes}"
                             Foreground="{DynamicResource ReyTextBrush}" TextWrapping="Wrap" />
                </StackPanel>
              </Border>

              <!-- animation -->
              <Border Classes="card" IsVisible="{Binding MeshInspector.HasMesh}">
              <StackPanel Spacing="6">
                <TextBlock Classes="cardTitle" Text="ANIMATION" />
                <TextBlock Text="{Binding Animation.SkeletonStatus}" Foreground="{DynamicResource ReyAccentBrush}" FontSize="11" />

                <ComboBox HorizontalAlignment="Stretch" PlaceholderText="Select animation…"
                          ItemsSource="{Binding Animation.Animations}"
                          SelectedItem="{Binding Animation.SelectedAnimation, Mode=TwoWay}"
                          IsVisible="{Binding Animation.HasAnimations}">
                  <ComboBox.ItemTemplate>
                    <DataTemplate>
                      <TextBlock Text="{Binding Name}" FontSize="11" />
                    </DataTemplate>
                  </ComboBox.ItemTemplate>
                </ComboBox>
                <Button Classes="tool" Content="Assign Animation…" HorizontalAlignment="Left"
                        Command="{Binding AssignAnimationCommand}" />

                <StackPanel Orientation="Horizontal" Spacing="4" IsVisible="{Binding Animation.HasClip}">
                  <Button Classes="tool" Content="◀|" Command="{Binding Animation.StepBackCommand}" />
                  <Button Classes="tool" Content="Play / Pause" Command="{Binding Animation.TogglePlayCommand}" />
                  <Button Classes="tool" Content="|▶" Command="{Binding Animation.StepForwardCommand}" />
                  <CheckBox Content="Loop" IsChecked="{Binding Animation.Loop}" VerticalAlignment="Center" FontSize="11" />
                </StackPanel>
                <Slider Minimum="0" Maximum="{Binding Animation.Duration}" Value="{Binding Animation.Time, Mode=TwoWay}"
                        IsVisible="{Binding Animation.HasClip}" />
                <TextBlock Text="{Binding Animation.TimeText}" Foreground="{DynamicResource ReyTextDimBrush}"
                           FontFamily="Cascadia Mono, Consolas, monospace" FontSize="11" IsVisible="{Binding Animation.HasClip}" />
                <StackPanel Orientation="Horizontal" Spacing="6" IsVisible="{Binding Animation.HasClip}">
                  <TextBlock Text="Speed" Foreground="{DynamicResource ReyTextDimBrush}" FontSize="11" VerticalAlignment="Center" />
                  <Slider Minimum="0.1" Maximum="2" Value="{Binding Animation.Speed, Mode=TwoWay}" Width="130" />
                  <TextBlock Text="{Binding Animation.Speed, StringFormat='{}{0:0.0}x'}" Foreground="{DynamicResource ReyTextBrush}" FontSize="11" VerticalAlignment="Center" />
                </StackPanel>
              </StackPanel>
              </Border>

              <!-- champion VFX (M37) — play the loaded skin's effects at the model -->
              <Border Classes="card" IsVisible="{Binding HasChampionVfx}">
              <StackPanel Spacing="6">
                <Grid ColumnDefinitions="*,Auto">
                  <TextBlock Classes="cardTitle" Grid.Column="0" Text="CHAMPION VFX" VerticalAlignment="Center" />
                  <Button Grid.Column="1" Classes="tool" Content="⏹ Stop" Command="{Binding StopChampionVfxCommand}" FontSize="10" Padding="8,1" />
                </Grid>
                <TextBlock Text="Select an effect to play it at the model origin." Foreground="{DynamicResource ReyTextDimBrush}" FontSize="10" TextWrapping="Wrap" />
                <ListBox ItemsSource="{Binding ChampionVfxSystems}" SelectedItem="{Binding SelectedChampionVfx, Mode=TwoWay}"
                         MaxHeight="220" Background="Transparent" FontSize="11">
                  <ListBox.ItemTemplate>
                    <DataTemplate>
                      <TextBlock Text="{Binding Display}" TextTrimming="CharacterEllipsis" />
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>
              </StackPanel>
              </Border>

              <!-- mapgeo stats -->
              <Border Classes="card" IsVisible="{Binding MapGeoInspector.HasMap}">
              <StackPanel Spacing="7">
                <TextBlock Classes="cardTitle" Text="MAP GEOMETRY" />
                <TextBlock Classes="mono" Text="{Binding MapGeoInspector.Stats}" TextWrapping="Wrap" />
                <TextBlock Text="{Binding MapGeoInspector.Warnings}" Foreground="{DynamicResource ReyAccent2Brush}"
                           FontSize="11" TextWrapping="Wrap" IsVisible="{Binding MapGeoInspector.HasWarnings}" />
              </StackPanel>
              </Border>

                  </StackPanel>
                </TabItem>

                <!-- MATERIALS TAB -->
                <TabItem FontSize="12" IsVisible="{Binding HasMaterialData}">
                  <TabItem.Header><TextBlock Text="Materials" FontSize="12" /></TabItem.Header>
                  <ScrollViewer MaxHeight="680">
                    <StackPanel Spacing="8" Margin="0,8,4,0">
                      <TextBlock Text="{Binding MaterialEditor.Summary}" Foreground="{DynamicResource ReyTextBrush}" FontSize="12" FontWeight="SemiBold" />
                      <Border Background="{DynamicResource ReyPanelAltBrush}" CornerRadius="4" Padding="6,4">
                        <StackPanel Spacing="2">
                          <TextBlock Text="SHADER BINDING" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource ReyTextDimBrush}" />
                          <TextBlock Text="{Binding ShaderDbStatus}" FontSize="11" Foreground="{DynamicResource ReyTextDimBrush}" TextWrapping="Wrap" />
                          <TextBlock Text="The sampler slots below are the material's bound textures (required samplers). Switch the viewport to 'Riot Approx' to preview." FontSize="10" Foreground="{DynamicResource ReyTextDimBrush}" TextWrapping="Wrap" />
                        </StackPanel>
                      </Border>
                      <Border Background="{DynamicResource ReyPanelAltBrush}" CornerRadius="4" Padding="6" IsVisible="{Binding MaterialEditor.HasUnresolved}">
                        <TextBlock Text="⚠ Some texture paths don't resolve in this WAD — see the ⚠ slots below." Foreground="#FFB454" FontSize="11" TextWrapping="Wrap" />
                      </Border>
                      <TextBox Watermark="Search materials / textures…" Text="{Binding MaterialEditor.Search}" FontSize="11" Padding="4,2" />
                      <StackPanel Orientation="Horizontal" Spacing="10">
                        <CheckBox Content="Only unresolved" IsChecked="{Binding MaterialEditor.OnlyUnresolved}" FontSize="11" />
                        <Ellipse Width="7" Height="7" Fill="{DynamicResource ReyAccent2Brush}" VerticalAlignment="Center" IsVisible="{Binding MaterialEditor.IsDirty}" ToolTip.Tip="Unsaved edits" />
                      </StackPanel>
                      <StackPanel Orientation="Horizontal" Spacing="4">
                        <Button Classes="tool" Content="Apply (preview)" Command="{Binding MaterialEditor.ApplyCommand}" />
                        <Button Classes="tool" Content="Save To Override" Command="{Binding MaterialEditor.SaveCommand}" />
                        <Button Classes="tool" Content="Revert All" Command="{Binding MaterialEditor.RevertAllCommand}" />
                      </StackPanel>

                      <ItemsControl ItemsSource="{Binding MaterialEditor.Materials}">
                        <ItemsControl.ItemTemplate>
                          <DataTemplate>
                            <Border IsVisible="{Binding IsVisible}" Background="{DynamicResource ReyBgBrush}" CornerRadius="4" Padding="8" Margin="0,0,0,6">
                              <StackPanel Spacing="5">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                  <TextBlock Text="{Binding Name}" Foreground="{DynamicResource ReyTextBrush}" FontSize="12" FontWeight="SemiBold" TextWrapping="Wrap" />
                                  <Ellipse Width="7" Height="7" Fill="{DynamicResource ReyAccent2Brush}" VerticalAlignment="Center" IsVisible="{Binding IsDirty}" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                  <TextBlock Text="{Binding ShaderName}" Foreground="{DynamicResource ReyTextDimBrush}" FontSize="10" VerticalAlignment="Center" />
                                  <TextBlock Text="{Binding AssignedTo, StringFormat='→ {0}'}" Foreground="{DynamicResource ReyAccentBrush}" FontSize="10" VerticalAlignment="Center" IsVisible="{Binding HasAssignment}" />
                                </StackPanel>

                                <!-- M32: preview profile (features + UV transform) -->
                                <Border Background="{DynamicResource ReyPanelAltBrush}" CornerRadius="3" Padding="6,4">
                                  <StackPanel Spacing="2">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                      <Border Background="{DynamicResource ReyAccentBrush}" CornerRadius="3" Padding="5,1">
                                        <TextBlock Text="{Binding ProfileLabel}" Foreground="#08221E" FontSize="9" FontWeight="SemiBold" />
                                      </Border>
                                      <TextBlock Text="{Binding FeatureSummary}" Foreground="{DynamicResource ReyTextDimBrush}" FontSize="10" VerticalAlignment="Center" />
                                      <Border Background="#4D8A5AF0" CornerRadius="3" Padding="5,1" VerticalAlignment="Center" IsVisible="{Binding UsesSpecular}">
                                        <TextBlock Text="SPECULAR" Foreground="{DynamicResource ReyTextBrush}" FontSize="8" FontWeight="SemiBold" />
                                      </Border>
                                      <TextBlock Text="⚠ profile unresolved" Foreground="#FFB454" FontSize="9" VerticalAlignment="Center" IsVisible="{Binding ProfileUnresolved}" />
                                    </StackPanel>
                                    <TextBlock Text="{Binding UvTransformText}" Foreground="{DynamicResource ReyTextDimBrush}" FontSize="10" />
                                    <TextBlock Text="{Binding UvSourceText}" Foreground="{DynamicResource ReyAccentBrush}" FontSize="9" IsVisible="{Binding HasUvSource}" />
                                    <TextBlock Text="{Binding RenderModeLabel, StringFormat='Blend: {0}'}" Foreground="{DynamicResource ReyTextDimBrush}" FontSize="10" />
                                    <!-- M34 render state (read-only, from technique/pass) -->
                                    <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto" Margin="0,3,0,0">
                                      <TextBlock Grid.Row="0" Grid.Column="0" Text="Cull Enabled" Foreground="{DynamicResource ReyTextDimBrush}" FontSize="9" Margin="0,0,10,0" />
                                      <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding CullEnabledText}" Foreground="{DynamicResource ReyTextBrush}" FontSize="9" />
                                      <TextBlock Grid.Row="1" Grid.Column="0" Text="Blend Enabled" Foreground="{DynamicResource ReyTextDimBrush}" FontSize="9" Margin="0,0,10,0" />
                                      <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding BlendEnabledText}" Foreground="{DynamicResource ReyTextBrush}" FontSize="9" />
                                      <TextBlock Grid.Row="2" Grid.Column="0" Text="Depth Write" Foreground="{DynamicResource ReyTextDimBrush}" FontSize="9" Margin="0,0,10,0" />
                                      <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding DepthWriteText}" Foreground="{DynamicResource ReyTextBrush}" FontSize="9" />
                                      <TextBlock Grid.Row="3" Grid.Column="0" Text="Alpha Cutout" Foreground="{DynamicResource ReyTextDimBrush}" FontSize="9" Margin="0,0,10,0" />
                                      <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding AlphaCutoutText}" Foreground="{DynamicResource ReyTextBrush}" FontSize="9" />
                                      <TextBlock Grid.Row="4" Grid.Column="0" Text="Two-Sided Lighting" Foreground="{DynamicResource ReyTextDimBrush}" FontSize="9" Margin="0,0,10,0" />
                                      <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding TwoSidedText}" Foreground="{DynamicResource ReyTextBrush}" FontSize="9" />
                                    </Grid>
                                  </StackPanel>
                                </Border>

                                <StackPanel Orientation="Horizontal" Spacing="4">
                                  <Button Classes="tool" Content="Copy name" Command="{Binding CopyNameCommand}" />
                                  <Button Classes="tool" Content="Revert material" Command="{Binding RevertCommand}" />
                                  <Button Classes="tool" Content="+ Add Sampler" Command="{Binding AddSamplerCommand}" IsVisible="{Binding CanEditSamplers}" />
                                </StackPanel>

                                <ItemsControl ItemsSource="{Binding Slots}">
                                  <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                      <StackPanel Spacing="2" Margin="0,4,0,0">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                          <TextBlock Text="{Binding SamplerName}" Foreground="{DynamicResource ReyTextDimBrush}" FontSize="10" MinWidth="110" VerticalAlignment="Center" />
                                          <Ellipse Width="6" Height="6" Fill="{DynamicResource ReyAccentBrush}" VerticalAlignment="Center" IsVisible="{Binding IsDiffuse}" ToolTip.Tip="Diffuse" />
                                          <TextBlock Text="⚠" Foreground="#FFB454" FontSize="11" VerticalAlignment="Center" IsVisible="{Binding Unresolved}" ToolTip.Tip="Path not found in this WAD" />
                                          <Ellipse Width="6" Height="6" Fill="{DynamicResource ReyAccent2Brush}" VerticalAlignment="Center" IsVisible="{Binding IsDirty}" />
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Spacing="3">
                                          <TextBox Text="{Binding EditedPath}" MinWidth="250" FontSize="10" Padding="4,1" FontFamily="Cascadia Mono, Consolas, monospace">
                                            <TextBox.KeyBindings><KeyBinding Gesture="Enter" Command="{Binding ApplyCommand}" /></TextBox.KeyBindings>
                                          </TextBox>
                                          <Button Content="✓" Command="{Binding ApplyCommand}" FontSize="10" Padding="5,0" ToolTip.Tip="Apply path" />
                                          <Button Content="↺" Command="{Binding RevertCommand}" FontSize="10" Padding="5,0" ToolTip.Tip="Revert" />
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                          <Button Classes="tool" Content="Preview" Command="{Binding PreviewCommand}" />
                                          <Button Classes="tool" Content="Open" Command="{Binding OpenCommand}" />
                                          <Button Classes="tool" Content="Copy" Command="{Binding CopyPathCommand}" />
                                          <Button Classes="tool" Content="Replace Texture…" Command="{Binding ReplaceCommand}" />
                                          <Button Classes="tool" Content="✕" Command="{Binding RemoveCommand}" IsVisible="{Binding CanRemove}" ToolTip.Tip="Remove this sampler" />
                                        </StackPanel>
                                        <Border Background="{DynamicResource ReyBgBrush}" CornerRadius="3" Padding="3" HorizontalAlignment="Left" IsVisible="{Binding HasThumbnail}">
                                          <Image Source="{Binding Thumbnail}" Stretch="Uniform" MaxHeight="96" MaxWidth="96" />
                                        </Border>
                                      </StackPanel>
                                    </DataTemplate>
                                  </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <Expander Header="Parameters" IsVisible="{Binding HasParameters}" FontSize="11" Margin="0,4,0,0">
                                  <ItemsControl ItemsSource="{Binding Parameters}">
                                    <ItemsControl.ItemTemplate>
                                      <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Spacing="4" Margin="0,2,0,0">
                                          <TextBlock Text="{Binding Name}" Foreground="{DynamicResource ReyTextDimBrush}" FontSize="10" MinWidth="110" VerticalAlignment="Center" />
                                          <TextBox Text="{Binding EditedText}" MinWidth="150" FontSize="10" Padding="4,1" IsEnabled="{Binding IsEditable}" FontFamily="Cascadia Mono, Consolas, monospace">
                                            <TextBox.KeyBindings><KeyBinding Gesture="Enter" Command="{Binding ApplyCommand}" /></TextBox.KeyBindings>
                                          </TextBox>
                                          <Button Content="✓" Command="{Binding ApplyCommand}" FontSize="10" Padding="5,0" />
                                          <Button Content="↺" Command="{Binding RevertCommand}" FontSize="10" Padding="5,0" />
                                          <Ellipse Width="6" Height="6" Fill="{DynamicResource ReyAccent2Brush}" VerticalAlignment="Center" IsVisible="{Binding IsDirty}" />
                                          <TextBlock Text="{Binding ErrorText}" Foreground="#FF6B6B" FontSize="9" VerticalAlignment="Center" IsVisible="{Binding HasError}" />
                                        </StackPanel>
                                      </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                  </ItemsControl>
                                </Expander>
                              </StackPanel>
                            </Border>
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                    </StackPanel>
                  </ScrollViewer>
                </TabItem>

                <!-- RAW BIN TREE TAB -->
                <TabItem FontSize="12" IsVisible="{Binding BinEditor.HasBin}">
                  <TabItem.Header><TextBlock Text="Raw BIN Tree" FontSize="12" /></TabItem.Header>

              <!-- bin editor (M7) -->
              <StackPanel Spacing="6" Margin="0,8,0,0" IsVisible="{Binding BinEditor.HasBin}">
                <Border Height="1" Background="{DynamicResource ReyBorderBrush}" />
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <TextBlock Text="BIN EDITOR" Foreground="{DynamicResource ReyTextDimBrush}" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center" />
                  <Ellipse Width="7" Height="7" Fill="{DynamicResource ReyAccent2Brush}" VerticalAlignment="Center"
                           IsVisible="{Binding BinEditor.IsDirty}" ToolTip.Tip="Unsaved edits" />
                </StackPanel>
                <TextBlock Text="{Binding BinEditor.Summary}" Foreground="{DynamicResource ReyTextDimBrush}" FontSize="11" />
                <TextBox Watermark="Filter field names…" Text="{Binding BinEditor.Filter}" FontSize="11" Padding="4,2" />
                <StackPanel Orientation="Horizontal" Spacing="4">
                  <Button Classes="tool" Content="Revert File" Command="{Binding BinEditor.RevertFileCommand}" />
                  <Button Classes="tool" Content="Save To Override" Command="{Binding SaveBinToOverrideCommand}" />
                  <Button Classes="tool" Content="Export BIN…" Command="{Binding ExportEditedBinCommand}" />
                </StackPanel>
                <TreeView ItemsSource="{Binding BinEditor.Roots}" Background="Transparent" BorderThickness="0" MaxHeight="560">
                  <TreeView.ItemTemplate>
                    <TreeDataTemplate ItemsSource="{Binding Children}">
                      <StackPanel Orientation="Horizontal" Spacing="6" IsVisible="{Binding IsVisible}">
                        <TextBlock Text="{Binding Name}" Foreground="{DynamicResource ReyTextBrush}"
                                   FontFamily="Cascadia Mono, Consolas, monospace" FontSize="11" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding TypeName}" Foreground="{DynamicResource ReyTextDimBrush}"
                                   FontSize="10" VerticalAlignment="Center" IsVisible="{Binding IsBranch}" />
                        <!-- editable primitive -->
                        <StackPanel Orientation="Horizontal" Spacing="3" IsVisible="{Binding IsEditable}">
                          <TextBox Text="{Binding EditedText}" MinWidth="150" FontSize="11" Padding="4,1"
                                   FontFamily="Cascadia Mono, Consolas, monospace">
                            <TextBox.KeyBindings>
                              <KeyBinding Gesture="Enter" Command="{Binding ApplyCommand}" />
                            </TextBox.KeyBindings>
                          </TextBox>
                          <Button Content="✓" Command="{Binding ApplyCommand}" FontSize="10" Padding="5,0" ToolTip.Tip="Apply edit" />
                          <Button Content="↺" Command="{Binding RevertCommand}" FontSize="10" Padding="5,0" ToolTip.Tip="Revert field" />
                          <Ellipse Width="7" Height="7" Fill="{DynamicResource ReyAccent2Brush}" VerticalAlignment="Center" IsVisible="{Binding IsDirty}" />
                          <TextBlock Text="{Binding ErrorText}" Foreground="#FF6B6B" FontSize="10" VerticalAlignment="Center" IsVisible="{Binding HasError}" />
                        </StackPanel>
                        <!-- read-only leaf value -->
                        <TextBlock Text="{Binding OriginalText}" Foreground="{DynamicResource ReyAccentBrush}"
                                   FontFamily="Cascadia Mono, Consolas, monospace" FontSize="11" VerticalAlignment="Center"
                                   IsVisible="{Binding IsReadOnlyValue}" />
                        <StackPanel.ContextMenu>
                          <ContextMenu>
                            <MenuItem Header="Copy Field Path" Command="{Binding CopyPathCommand}" />
                            <MenuItem Header="Copy Field Hash" Command="{Binding CopyHashCommand}" />
                            <MenuItem Header="Copy Value" Command="{Binding CopyValueCommand}" />
                          </ContextMenu>
                        </StackPanel.ContextMenu>
                      </StackPanel>
                    </TreeDataTemplate>
                  </TreeView.ItemTemplate>
                </TreeView>
              </StackPanel>
                </TabItem>
              </TabControl>
            </StackPanel>
          </ScrollViewer>
        </DockPanel>
      </Border>

    </Grid>
  </DockPanel>
</Window>
