<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:ReyEngine.App.Views"
        xmlns:conv="clr-namespace:ReyEngine.App.Converters"
        x:Class="ReyEngine.App.Views.MainWindow"
        Title="{Binding Title}"
        Width="1500" Height="900"
        MinWidth="1000" MinHeight="640"
        Background="{DynamicResource ReyBgBrush}"
        Foreground="{DynamicResource ReyTextBrush}"
        FontFamily="Inter, Segoe UI, sans-serif">

  <Window.Resources>
    <conv:LogLevelToBrushConverter x:Key="LevelToBrush" />
  </Window.Resources>

  <DockPanel>

    <!-- ============ TOP MENU ============ -->
    <Menu DockPanel.Dock="Top" Background="{DynamicResource ReyHeaderBrush}">
      <MenuItem Header="_File">
        <MenuItem Header="New Project…" Command="{Binding NewProjectCommand}" />
        <MenuItem Header="Open Project…" Command="{Binding OpenProjectCommand}" />
        <MenuItem Header="Save Project" Command="{Binding SaveProjectCommand}" />
        <MenuItem Header="Save Project As…" Command="{Binding SaveProjectAsCommand}" />
        <Separator />
        <MenuItem Header="Open WAD…" Command="{Binding OpenWadCommand}" />
        <MenuItem Header="Export Selected…" Command="{Binding ExportSelectedCommand}" />
        <Separator />
        <MenuItem Header="Exit" Command="{Binding ExitCommand}" />
      </MenuItem>
      <MenuItem Header="_Edit">
        <MenuItem Header="Clear Console" Command="{Binding ClearConsoleCommand}" />
      </MenuItem>
      <MenuItem Header="_View">
        <MenuItem Header="Reload WAD" Command="{Binding ReloadWadCommand}" />
      </MenuItem>
      <MenuItem Header="_Tools">
        <MenuItem Header="Sync Hashes (CommunityDragon)" Command="{Binding SyncHashesCommand}" />
        <MenuItem Header="Reload Local Hashes" Command="{Binding ReloadLocalHashesCommand}" />
        <Separator />
        <MenuItem Header="Hash Lookup" Command="{Binding HashLookupCommand}" />
        <MenuItem Header="Assign Skeleton…" Command="{Binding AssignSkeletonCommand}" />
        <MenuItem Header="Assign Animation…" Command="{Binding AssignAnimationCommand}" />
        <MenuItem Header="Shader Preview" Command="{Binding ShaderPreviewCommand}" />
        <MenuItem Header="Build Package" Command="{Binding BuildPackageCommand}" />
      </MenuItem>
      <MenuItem Header="_Project">
        <MenuItem Header="Build Package" Command="{Binding BuildPackageCommand}" />
        <MenuItem Header="Open Build Folder" Command="{Binding OpenBuildFolderCommand}" />
        <Separator />
        <MenuItem Header="Reload WAD" Command="{Binding ReloadWadCommand}" />
      </MenuItem>
      <MenuItem Header="_Help">
        <MenuItem Header="About ReyEngine" IsEnabled="False" />
      </MenuItem>
    </Menu>

    <!-- ============ TOOLBAR ============ -->
    <Border DockPanel.Dock="Top"
            Background="{DynamicResource ReyHeaderBrush}"
            BorderBrush="{DynamicResource ReyBorderBrush}"
            BorderThickness="0,1,0,1" Padding="8,6">
      <StackPanel Orientation="Horizontal">
        <Button Classes="tool" Content="Import" Command="{Binding OpenWadCommand}" />
        <Button Classes="tool" Content="Export" Command="{Binding ExportSelectedCommand}" />
        <Button Classes="tool" Content="Reload WAD" Command="{Binding ReloadWadCommand}" />
        <Button Classes="tool" Content="Sync Hashes" Command="{Binding SyncHashesCommand}" />
        <Button Classes="tool" Content="Build Package" Command="{Binding BuildPackageCommand}" />
        <Button Classes="tool" Content="Shader Preview" Command="{Binding ShaderPreviewCommand}" />
        <Border Width="1" Background="{DynamicResource ReyBorderBrush}" Margin="6,2" />
        <TextBox Width="240" VerticalAlignment="Center" Margin="0,0,4,0"
                 Watermark="path or string to hash"
                 Text="{Binding HashInput, Mode=TwoWay}" />
        <Button Classes="tool" Content="Hash Lookup" Command="{Binding HashLookupCommand}" />
      </StackPanel>
    </Border>

    <!-- ============ STATUS BAR ============ -->
    <Border DockPanel.Dock="Bottom"
            Background="{DynamicResource ReyHeaderBrush}"
            BorderBrush="{DynamicResource ReyBorderBrush}"
            BorderThickness="0,1,0,0" Padding="10,4">
      <TextBlock Text="{Binding Status}" Foreground="{DynamicResource ReyTextDimBrush}" FontSize="11" />
    </Border>

    <!-- ============ MAIN AREA ============ -->
    <Grid ColumnDefinitions="290,4,*,4,360">

      <!-- LEFT: Asset Browser / WAD Explorer -->
      <Border Grid.Column="0" Background="{DynamicResource ReyPanelBrush}">
        <DockPanel>
          <TextBlock Classes="panelHeader" DockPanel.Dock="Top" Text="ASSET BROWSER · WAD EXPLORER" />
          <TreeView ItemsSource="{Binding RootNodes}"
                    SelectedItem="{Binding SelectedNode, Mode=TwoWay}"
                    Background="Transparent" BorderThickness="0">
            <TreeView.ItemTemplate>
              <TreeDataTemplate ItemsSource="{Binding Children}">
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <StackPanel.ContextMenu>
                    <ContextMenu>
                      <MenuItem Header="Replace Selected Asset…" Command="{Binding $parent[TreeView].DataContext.ReplaceSelectedCommand}" />
                      <MenuItem Header="Import New Asset…" Command="{Binding $parent[TreeView].DataContext.ImportNewAssetCommand}" />
                      <MenuItem Header="Revert Asset" Command="{Binding $parent[TreeView].DataContext.RevertSelectedCommand}" />
                      <Separator />
                      <MenuItem Header="Export Original…" Command="{Binding $parent[TreeView].DataContext.ExportSelectedCommand}" />
                      <MenuItem Header="Export Modified…" Command="{Binding $parent[TreeView].DataContext.ExportModifiedCommand}" />
                      <Separator />
                      <MenuItem Header="Copy Resolved Path" Command="{Binding $parent[TreeView].DataContext.CopyResolvedPathCommand}" />
                      <MenuItem Header="Copy Hash" Command="{Binding $parent[TreeView].DataContext.CopyHashCommand}" />
                      <MenuItem Header="Assign Skeleton…" Command="{Binding $parent[TreeView].DataContext.AssignSkeletonCommand}" />
                    </ContextMenu>
                  </StackPanel.ContextMenu>
                  <Border Background="{DynamicResource ReyPanelAltBrush}" CornerRadius="3"
                          Padding="4,1" MinWidth="36" VerticalAlignment="Center">
                    <TextBlock Text="{Binding Kind}" FontSize="9"
                               Foreground="{DynamicResource ReyAccentBrush}" HorizontalAlignment="Center" />
                  </Border>
                  <TextBlock Text="{Binding Name}" Foreground="{DynamicResource ReyTextBrush}"
                             FontSize="12" VerticalAlignment="Center" />
                  <Ellipse Width="7" Height="7" VerticalAlignment="Center"
                           Fill="{DynamicResource ReyAccent2Brush}" IsVisible="{Binding IsModified}" />
                </StackPanel>
              </TreeDataTemplate>
            </TreeView.ItemTemplate>
          </TreeView>
        </DockPanel>
      </Border>

      <GridSplitter Grid.Column="1" Background="{DynamicResource ReyBorderBrush}" />

      <!-- CENTER: Viewport + Console -->
      <Grid Grid.Column="2" RowDefinitions="*,4,210">
        <Border Grid.Row="0" Background="{DynamicResource ReyBgBrush}">
          <Grid>
            <views:ViewportControl x:Name="Viewport"
                Mesh="{Binding CurrentMesh}"
                ModelTextures="{Binding CurrentModelTextures}"
                Skeleton="{Binding CurrentSkeleton}"
                AnimationClip="{Binding CurrentAnimation}"
                AnimationTime="{Binding AnimationTime}"
                Wireframe="{Binding ShowWireframe}"
                ShowBones="{Binding ShowBones}"
                ShowBounds="{Binding ShowBounds}" />

            <!-- transparent surface that forwards pointer input to the viewport camera -->
            <Border x:Name="ViewportInput" Background="Transparent"
                    PointerPressed="OnViewportPointerPressed"
                    PointerMoved="OnViewportPointerMoved"
                    PointerReleased="OnViewportPointerReleased"
                    PointerWheelChanged="OnViewportPointerWheel" />

            <!-- view toggles (above the input surface so they stay clickable) -->
            <StackPanel Orientation="Horizontal" Spacing="4" Margin="10"
                        HorizontalAlignment="Right" VerticalAlignment="Top">
              <ToggleButton Content="Wireframe" IsChecked="{Binding ShowWireframe}" FontSize="11" Padding="8,3" />
              <ToggleButton Content="Bones" IsChecked="{Binding ShowBones}" FontSize="11" Padding="8,3" />
              <ToggleButton Content="Bounds" IsChecked="{Binding ShowBounds}" FontSize="11" Padding="8,3" />
              <Button Content="Frame" Click="OnFrameClick" FontSize="11" Padding="8,3" />
            </StackPanel>

            <Border Background="#66000000" CornerRadius="4" Padding="8,3"
                    HorizontalAlignment="Left" VerticalAlignment="Top" Margin="10" IsHitTestVisible="False">
              <TextBlock Text="VIEWPORT  ·  LMB orbit · Shift+LMB pan · wheel zoom"
                         FontSize="10" Foreground="{DynamicResource ReyTextDimBrush}" />
            </Border>
          </Grid>
        </Border>

        <GridSplitter Grid.Row="1" Background="{DynamicResource ReyBorderBrush}" />

        <Border Grid.Row="2" Background="{DynamicResource ReyPanelBrush}">
          <DockPanel>
            <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto">
              <TextBlock Classes="panelHeader" Text="CONSOLE · IMPORT LOG" />
              <Button Grid.Column="1" Classes="tool" Content="Clear"
                      Command="{Binding ClearConsoleCommand}" Margin="0,4,8,0" />
            </Grid>
            <ListBox Classes="console" ItemsSource="{Binding Console.Entries}"
                     Background="Transparent" BorderThickness="0" Padding="6,0">
              <ListBox.ItemTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding}"
                             FontFamily="Cascadia Mono, Consolas, monospace" FontSize="12"
                             Foreground="{Binding Level, Converter={StaticResource LevelToBrush}}" />
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>
          </DockPanel>
        </Border>
      </Grid>

      <GridSplitter Grid.Column="3" Background="{DynamicResource ReyBorderBrush}" />

      <!-- RIGHT: Inspector -->
      <Border Grid.Column="4" Background="{DynamicResource ReyPanelBrush}">
        <DockPanel>
          <TextBlock Classes="panelHeader" DockPanel.Dock="Top" Text="INSPECTOR" />
          <ScrollViewer>
            <StackPanel Margin="12" Spacing="10">
              <TextBlock Text="{Binding Inspector.Title}" Foreground="{DynamicResource ReyTextBrush}"
                         FontSize="15" FontWeight="SemiBold" TextWrapping="Wrap" />
              <Border Background="{DynamicResource ReyPanelAltBrush}" CornerRadius="3"
                      Padding="6,2" HorizontalAlignment="Left">
                <TextBlock Text="{Binding Inspector.Subtitle}" Foreground="{DynamicResource ReyAccentBrush}" FontSize="11" />
              </Border>

              <!-- project asset status -->
              <StackPanel Orientation="Horizontal" Spacing="6">
                <Ellipse Width="8" Height="8" VerticalAlignment="Center"
                         Fill="{DynamicResource ReyAccent2Brush}" IsVisible="{Binding Inspector.IsModified}" />
                <TextBlock Text="{Binding Inspector.AssetStatus}" FontSize="11"
                           Foreground="{DynamicResource ReyTextDimBrush}" VerticalAlignment="Center" />
              </StackPanel>
              <TextBlock Text="{Binding Inspector.AssetSource}" FontSize="10"
                         Foreground="{DynamicResource ReyAccent2Brush}" IsVisible="{Binding Inspector.IsModified}" />

              <!-- texture preview -->
              <Border Background="{DynamicResource ReyBgBrush}" CornerRadius="4" Padding="8"
                      IsVisible="{Binding Inspector.HasPreview}">
                <Image Source="{Binding Inspector.PreviewImage}" Stretch="Uniform" MaxHeight="340" />
              </Border>

              <TextBlock Text="{Binding Inspector.Details}" Foreground="{DynamicResource ReyTextDimBrush}"
                         FontFamily="Cascadia Mono, Consolas, monospace" FontSize="11" TextWrapping="Wrap" />

              <!-- note (e.g. bin placeholder) -->
              <Border Background="{DynamicResource ReyPanelAltBrush}" CornerRadius="4" Padding="8"
                      IsVisible="{Binding Inspector.HasNote}">
                <TextBlock Text="{Binding Inspector.Note}" Foreground="{DynamicResource ReyAccent2Brush}"
                           FontSize="11" TextWrapping="Wrap" />
              </Border>

              <!-- mesh stats (SKN) -->
              <StackPanel Spacing="8" IsVisible="{Binding MeshInspector.HasMesh}">
                <Border Height="1" Background="{DynamicResource ReyBorderBrush}" />
                <TextBlock Text="MESH" Foreground="{DynamicResource ReyTextDimBrush}" FontSize="11" FontWeight="SemiBold" />
                <TextBlock Text="{Binding MeshInspector.Stats}" Foreground="{DynamicResource ReyTextDimBrush}"
                           FontFamily="Cascadia Mono, Consolas, monospace" FontSize="11" />
                <TextBlock Text="{Binding MeshInspector.SkeletonStatus}" Foreground="{DynamicResource ReyAccentBrush}" FontSize="11" />
                <Button Classes="tool" Content="Assign Skeleton…" HorizontalAlignment="Left"
                        Command="{Binding AssignSkeletonCommand}" />
                <TextBlock Text="Submeshes / materials" Foreground="{DynamicResource ReyTextDimBrush}" FontSize="11" />
                <TextBlock Text="{Binding MeshInspector.SubMeshes}" Foreground="{DynamicResource ReyTextBrush}"
                           FontFamily="Cascadia Mono, Consolas, monospace" FontSize="11" TextWrapping="Wrap" />
              </StackPanel>

              <!-- animation -->
              <StackPanel Spacing="6" IsVisible="{Binding MeshInspector.HasMesh}">
                <Border Height="1" Background="{DynamicResource ReyBorderBrush}" />
                <TextBlock Text="ANIMATION" Foreground="{DynamicResource ReyTextDimBrush}" FontSize="11" FontWeight="SemiBold" />
                <TextBlock Text="{Binding Animation.SkeletonStatus}" Foreground="{DynamicResource ReyAccentBrush}" FontSize="11" />

                <ComboBox HorizontalAlignment="Stretch" PlaceholderText="Select animation…"
                          ItemsSource="{Binding Animation.Animations}"
                          SelectedItem="{Binding Animation.SelectedAnimation, Mode=TwoWay}"
                          IsVisible="{Binding Animation.HasAnimations}">
                  <ComboBox.ItemTemplate>
                    <DataTemplate>
                      <TextBlock Text="{Binding Name}" FontSize="11" />
                    </DataTemplate>
                  </ComboBox.ItemTemplate>
                </ComboBox>
                <Button Classes="tool" Content="Assign Animation…" HorizontalAlignment="Left"
                        Command="{Binding AssignAnimationCommand}" />

                <StackPanel Orientation="Horizontal" Spacing="4" IsVisible="{Binding Animation.HasClip}">
                  <Button Classes="tool" Content="◀|" Command="{Binding Animation.StepBackCommand}" />
                  <Button Classes="tool" Content="Play / Pause" Command="{Binding Animation.TogglePlayCommand}" />
                  <Button Classes="tool" Content="|▶" Command="{Binding Animation.StepForwardCommand}" />
                  <CheckBox Content="Loop" IsChecked="{Binding Animation.Loop}" VerticalAlignment="Center" FontSize="11" />
                </StackPanel>
                <Slider Minimum="0" Maximum="{Binding Animation.Duration}" Value="{Binding Animation.Time, Mode=TwoWay}"
                        IsVisible="{Binding Animation.HasClip}" />
                <TextBlock Text="{Binding Animation.TimeText}" Foreground="{DynamicResource ReyTextDimBrush}"
                           FontFamily="Cascadia Mono, Consolas, monospace" FontSize="11" IsVisible="{Binding Animation.HasClip}" />
                <StackPanel Orientation="Horizontal" Spacing="6" IsVisible="{Binding Animation.HasClip}">
                  <TextBlock Text="Speed" Foreground="{DynamicResource ReyTextDimBrush}" FontSize="11" VerticalAlignment="Center" />
                  <Slider Minimum="0.1" Maximum="2" Value="{Binding Animation.Speed, Mode=TwoWay}" Width="130" />
                  <TextBlock Text="{Binding Animation.Speed, StringFormat='{}{0:0.0}x'}" Foreground="{DynamicResource ReyTextBrush}" FontSize="11" VerticalAlignment="Center" />
                </StackPanel>
              </StackPanel>

              <!-- mapgeo stats -->
              <StackPanel Spacing="8" IsVisible="{Binding MapGeoInspector.HasMap}">
                <Border Height="1" Background="{DynamicResource ReyBorderBrush}" />
                <TextBlock Text="MAP GEOMETRY" Foreground="{DynamicResource ReyTextDimBrush}" FontSize="11" FontWeight="SemiBold" />
                <TextBlock Text="{Binding MapGeoInspector.Stats}" Foreground="{DynamicResource ReyTextDimBrush}"
                           FontFamily="Cascadia Mono, Consolas, monospace" FontSize="11" TextWrapping="Wrap" />
                <TextBlock Text="{Binding MapGeoInspector.Warnings}" Foreground="{DynamicResource ReyAccent2Brush}"
                           FontSize="11" TextWrapping="Wrap" IsVisible="{Binding MapGeoInspector.HasWarnings}" />
              </StackPanel>

              <!-- bin property tree -->
              <StackPanel Spacing="6" IsVisible="{Binding HasBinTree}">
                <Border Height="1" Background="{DynamicResource ReyBorderBrush}" />
                <TextBlock Text="BIN PROPERTIES" Foreground="{DynamicResource ReyTextDimBrush}" FontSize="11" FontWeight="SemiBold" />
                <TreeView ItemsSource="{Binding BinTreeRoots}" Background="Transparent" BorderThickness="0" MaxHeight="520">
                  <TreeView.ItemTemplate>
                    <TreeDataTemplate ItemsSource="{Binding Children}">
                      <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Text="{Binding Name}" Foreground="{DynamicResource ReyTextBrush}"
                                   FontFamily="Cascadia Mono, Consolas, monospace" FontSize="11" />
                        <TextBlock Text="{Binding Value}" Foreground="{DynamicResource ReyAccentBrush}"
                                   FontFamily="Cascadia Mono, Consolas, monospace" FontSize="11" />
                      </StackPanel>
                    </TreeDataTemplate>
                  </TreeView.ItemTemplate>
                </TreeView>
              </StackPanel>
            </StackPanel>
          </ScrollViewer>
        </DockPanel>
      </Border>

    </Grid>
  </DockPanel>
</Window>
