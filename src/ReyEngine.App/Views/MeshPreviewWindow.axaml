<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:ReyEngine.App.Views"
        xmlns:vm="clr-namespace:ReyEngine.App.ViewModels"
        x:Class="ReyEngine.App.Views.MeshPreviewWindow"
        x:DataType="vm:MeshPreviewViewModel"
        Title="ReyEngine — Model Preview" Width="980" Height="760"
        WindowStartupLocation="CenterOwner"
        ExtendClientAreaToDecorationsHint="True"
        Background="{DynamicResource ReyBgBrush}">
  <!-- M50: character/mesh preview in its own window; the main viewport stays on the map -->
  <DockPanel>
    <views:ReyTitleBar DockPanel.Dock="Top" />
    <Border DockPanel.Dock="Top" Background="{DynamicResource ReyHeaderBrush}"
            BorderBrush="{DynamicResource ReyBorderBrush}" BorderThickness="0,0,0,1" Padding="8,5">
      <DockPanel>
        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
          <ToggleButton Classes="vp" Content="🗺 Map" IsChecked="{Binding BackgroundVisible}"
                        IsVisible="{Binding HasBackground}" ToolTip.Tip="{Binding BackgroundMapName, StringFormat='Backdrop: {0}'}" />
          <ToggleButton Classes="vp" Content="▦ Grid" IsChecked="{Binding ShowGrid}" ToolTip.Tip="Show the reference grid" />
          <ToggleButton Classes="vp" Content="🔊 SFX" IsChecked="{Binding SfxEnabled}" ToolTip.Tip="Play the clip's sound events (like in-game)" />
          <ToggleButton Classes="vp" Content="⌗ Wire" IsChecked="{Binding Wireframe}" />
          <ToggleButton Classes="vp" Content="🦴 Bones" IsChecked="{Binding ShowBones}" />
          <ToggleButton Classes="vp" Content="✂ Cull" IsChecked="{Binding CullBackfaces}" />
        </StackPanel>
        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
          <TextBlock Text="🧊 MODEL" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource ReyAccentBrush}" VerticalAlignment="Center" />
          <TextBlock Text="{Binding Title}" FontSize="11" VerticalAlignment="Center" />
          <TextBlock Text="{Binding Stats}" FontSize="10" Opacity="0.6" VerticalAlignment="Center" />
        </StackPanel>
      </DockPanel>
    </Border>
    <!-- M55: right panel — animation playback + champion VFX -->
    <Border DockPanel.Dock="Right" Width="250" Background="{DynamicResource ReyPanelBrush}"
            BorderBrush="{DynamicResource ReyBorderBrush}" BorderThickness="1,0,0,0">
      <ScrollViewer>
        <StackPanel Margin="10" Spacing="8">
          <!-- M90: model scale — size the champion against the map backdrop -->
          <Border Classes="card">
            <StackPanel Spacing="4">
              <Grid ColumnDefinitions="*,Auto">
                <TextBlock Classes="cardTitle" Grid.Column="0" Text="MODEL" VerticalAlignment="Center" />
                <Button Grid.Column="1" Classes="tool" Content="1×" FontSize="10" Padding="6,1"
                        Command="{Binding ResetModelScaleCommand}" ToolTip.Tip="Reset scale" />
              </Grid>
              <StackPanel Orientation="Horizontal" Spacing="6">
                <TextBlock Text="Scale" Foreground="{DynamicResource ReyTextDimBrush}" FontSize="11" VerticalAlignment="Center" Width="42" />
                <Slider Minimum="0.1" Maximum="5" Value="{Binding ModelScale, Mode=TwoWay}" Width="120" />
                <TextBlock Text="{Binding ModelScale, StringFormat='{}{0:0.00}×'}" FontSize="11" VerticalAlignment="Center" />
              </StackPanel>
            </StackPanel>
          </Border>

          <Border Classes="card">
            <StackPanel Spacing="6">
              <TextBlock Classes="cardTitle" Text="ANIMATION" />
              <TextBlock Text="{Binding Animation.SkeletonStatus}" Foreground="{DynamicResource ReyAccentBrush}" FontSize="11" />
              <ComboBox HorizontalAlignment="Stretch" PlaceholderText="Select animation…"
                        ItemsSource="{Binding Animation.Animations}"
                        SelectedItem="{Binding Animation.SelectedAnimation, Mode=TwoWay}"
                        IsVisible="{Binding Animation.HasAnimations}">
                <ComboBox.ItemTemplate>
                  <DataTemplate><TextBlock Text="{Binding Name}" FontSize="11" /></DataTemplate>
                </ComboBox.ItemTemplate>
              </ComboBox>
              <!-- M84 fix: the Loop checkbox overflowed the 250px panel and was cut off — compact ⟳ toggle -->
              <StackPanel Orientation="Horizontal" Spacing="4" IsVisible="{Binding Animation.HasClip}">
                <Button Classes="tool" Content="◀|" Command="{Binding Animation.StepBackCommand}" />
                <Button Classes="tool" Content="Play / Pause" Command="{Binding Animation.TogglePlayCommand}" />
                <Button Classes="tool" Content="|▶" Command="{Binding Animation.StepForwardCommand}" />
                <ToggleButton Classes="vp" Content="⟳" IsChecked="{Binding Animation.Loop}" ToolTip.Tip="Loop playback" />
              </StackPanel>
              <Slider Minimum="0" Maximum="{Binding Animation.Duration}" Value="{Binding Animation.Time, Mode=TwoWay}"
                      IsVisible="{Binding Animation.HasClip}" />
              <TextBlock Text="{Binding Animation.TimeText}" Foreground="{DynamicResource ReyTextDimBrush}"
                         FontFamily="Cascadia Mono, Consolas, monospace" FontSize="11" IsVisible="{Binding Animation.HasClip}" />
              <StackPanel Orientation="Horizontal" Spacing="6" IsVisible="{Binding Animation.HasClip}">
                <TextBlock Text="Speed" Foreground="{DynamicResource ReyTextDimBrush}" FontSize="11" VerticalAlignment="Center" />
                <Slider Minimum="0.1" Maximum="2" Value="{Binding Animation.Speed, Mode=TwoWay}" Width="110" />
                <TextBlock Text="{Binding Animation.Speed, StringFormat='{}{0:0.0}x'}" FontSize="11" VerticalAlignment="Center" />
              </StackPanel>
            </StackPanel>
          </Border>

          <!-- M89: NVR map backdrop tuning — move the map, boost its lights, tune baked ground shading -->
          <Border Classes="card" IsVisible="{Binding HasBackground}">
            <StackPanel Spacing="6">
              <Grid ColumnDefinitions="*,Auto">
                <TextBlock Classes="cardTitle" Grid.Column="0" Text="MAP BACKDROP" VerticalAlignment="Center" />
                <ToggleButton Grid.Column="1" Classes="vp" Content="Show" FontSize="10" Padding="6,1"
                              IsChecked="{Binding BackgroundVisible}" />
              </Grid>
              <TextBlock Text="{Binding BackgroundMapName, StringFormat='Map: {0}'}"
                         Foreground="{DynamicResource ReyTextDimBrush}" FontSize="11" />

              <TextBlock Text="Move map (world units)" Foreground="{DynamicResource ReyTextDimBrush}" FontSize="11" Margin="0,2,0,0" />
              <StackPanel Orientation="Horizontal" Spacing="6">
                <TextBlock Text="X" VerticalAlignment="Center" FontSize="11" Width="12" />
                <NumericUpDown Width="182" Value="{Binding BackgroundOffsetX}" Increment="50" FormatString="0" FontSize="11" />
              </StackPanel>
              <StackPanel Orientation="Horizontal" Spacing="6">
                <TextBlock Text="Y" VerticalAlignment="Center" FontSize="11" Width="12" />
                <NumericUpDown Width="182" Value="{Binding BackgroundOffsetY}" Increment="20" FormatString="0" FontSize="11" />
              </StackPanel>
              <StackPanel Orientation="Horizontal" Spacing="6">
                <TextBlock Text="Z" VerticalAlignment="Center" FontSize="11" Width="12" />
                <NumericUpDown Width="182" Value="{Binding BackgroundOffsetZ}" Increment="50" FormatString="0" FontSize="11" />
              </StackPanel>
              <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,2,0,0">
                <TextBlock Text="Rotate" Foreground="{DynamicResource ReyTextDimBrush}" FontSize="11" VerticalAlignment="Center" Width="42" />
                <Slider Minimum="0" Maximum="360" Value="{Binding BackgroundRotation, Mode=TwoWay}" Width="120" />
                <TextBlock Text="{Binding BackgroundRotation, StringFormat='{}{0:0}°'}" FontSize="11" VerticalAlignment="Center" />
              </StackPanel>
              <Button Classes="tool" Content="Reset position" Command="{Binding ResetBackgroundOffsetCommand}" HorizontalAlignment="Stretch" />

              <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,4,0,0">
                <TextBlock Text="Light" Foreground="{DynamicResource ReyTextDimBrush}" FontSize="11" VerticalAlignment="Center" Width="42" />
                <Slider Minimum="0" Maximum="8" Value="{Binding BackgroundLightIntensity, Mode=TwoWay}" Width="120" />
                <TextBlock Text="{Binding BackgroundLightIntensity, StringFormat='{}{0:0.0}'}" FontSize="11" VerticalAlignment="Center" />
              </StackPanel>
              <StackPanel Orientation="Horizontal" Spacing="6">
                <TextBlock Text="Bright" Foreground="{DynamicResource ReyTextDimBrush}" FontSize="11" VerticalAlignment="Center" Width="42" />
                <Slider Minimum="0" Maximum="2" Value="{Binding BackgroundBrightness, Mode=TwoWay}" Width="120" />
                <TextBlock Text="{Binding BackgroundBrightness, StringFormat='{}{0:0.00}'}" FontSize="11" VerticalAlignment="Center" />
              </StackPanel>
              <StackPanel Orientation="Horizontal" Spacing="6">
                <TextBlock Text="Ground" Foreground="{DynamicResource ReyTextDimBrush}" FontSize="11" VerticalAlignment="Center" Width="42" />
                <Slider Minimum="0" Maximum="8" Value="{Binding BackgroundVertexLight, Mode=TwoWay}" Width="120" />
                <TextBlock Text="{Binding BackgroundVertexLight, StringFormat='{}{0:0.0}'}" FontSize="11" VerticalAlignment="Center" />
              </StackPanel>
            </StackPanel>
          </Border>

          <!-- M84: per-submesh visibility (user request) — toggle any of the model's submeshes -->
          <Border Classes="card" IsVisible="{Binding HasSubmeshes}">
            <StackPanel Spacing="4">
              <Grid ColumnDefinitions="*,Auto,Auto,Auto">
                <TextBlock Classes="cardTitle" Grid.Column="0" Text="SUBMESHES" VerticalAlignment="Center" />
                <ToggleButton Classes="vp" Grid.Column="1" Content="Auto" FontSize="10" Padding="6,1" Margin="0,0,4,0"
                              IsChecked="{Binding AutoSubmeshVisibility}"
                              ToolTip.Tip="AUTO: apply the game's visibility (skin bin initial-hide + the playing clip's show/hide lists). Off = manual control." />
                <Button Classes="icon" Grid.Column="2" Content="All" FontSize="10" Command="{Binding ShowAllSubmeshesCommand}" />
                <Button Classes="icon" Grid.Column="3" Content="None" FontSize="10" Command="{Binding HideAllSubmeshesCommand}" />
              </Grid>
              <ItemsControl ItemsSource="{Binding Submeshes}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <CheckBox Content="{Binding Name}" IsChecked="{Binding IsVisible}" FontSize="11" Margin="0,1" />
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </Border>

          <Border Classes="card" IsVisible="{Binding HasVfx}">
            <StackPanel Spacing="6">
              <TextBlock Classes="cardTitle" Text="CHAMPION VFX" />
              <ComboBox HorizontalAlignment="Stretch" PlaceholderText="Play effect…"
                        ItemsSource="{Binding VfxSystems}"
                        SelectedItem="{Binding SelectedVfx, Mode=TwoWay}">
                <ComboBox.ItemTemplate>
                  <DataTemplate><TextBlock Text="{Binding Name}" FontSize="11" TextTrimming="CharacterEllipsis" /></DataTemplate>
                </ComboBox.ItemTemplate>
              </ComboBox>
              <Button Classes="tool" Content="⏹ Stop VFX" Command="{Binding StopVfxCommand}" HorizontalAlignment="Left" />
            </StackPanel>
          </Border>
        </StackPanel>
      </ScrollViewer>
    </Border>

    <Grid>
      <views:ViewportControl x:Name="PreviewViewport"
                             Mesh="{Binding Mesh}"
                             Skeleton="{Binding Skeleton}"
                             ModelTextures="{Binding Textures}"
                             AnimationClip="{Binding CurrentAnimation}"
                             AnimationTime="{Binding AnimationTime}"
                             ParticlePlayback="{Binding Playback}"
                             ShowBones="{Binding ShowBones}"
                             Wireframe="{Binding Wireframe}"
                             CullBackfaces="{Binding CullBackfaces}"
                             ModelSubmeshVisible="{Binding SubmeshVisible}"
                             ModelScale="{Binding ModelScale}"
                             BackgroundMesh="{Binding BackgroundMesh}"
                             BackgroundTextures="{Binding BackgroundTextures}"
                             BackgroundBlendTextures="{Binding BackgroundBlendTextures}"
                             BackgroundColor1Textures="{Binding BackgroundColor1Textures}"
                             BackgroundColor2Textures="{Binding BackgroundColor2Textures}"
                             BackgroundColor3Textures="{Binding BackgroundColor3Textures}"
                             BackgroundVisible="{Binding BackgroundVisible}"
                             BackgroundOffset="{Binding BackgroundOffset}"
                             BackgroundRotation="{Binding BackgroundRotation}"
                             BackgroundVertexLight="{Binding BackgroundVertexLight}"
                             BackgroundBrightness="{Binding BackgroundBrightness}"
                             ShowGrid="{Binding ShowGrid}"
                             DynamicLights="{Binding BackgroundLights}"
                             DynamicLightsEnabled="{Binding BackgroundLightsEnabled}"
                             DynamicLightIntensity="{Binding BackgroundLightIntensity}"
                             ShowLightMarkers="False" />
      <Border x:Name="PreviewInput" Background="Transparent" />
      <TextBlock Text="LMB orbit · MMB pan · wheel zoom" FontSize="9" Opacity="0.35"
                 Margin="8,6" HorizontalAlignment="Left" VerticalAlignment="Top" IsHitTestVisible="False" />
    </Grid>
  </DockPanel>
</Window>
