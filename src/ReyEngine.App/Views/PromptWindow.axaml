<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="ReyEngine.App.Views.PromptWindow"
        Width="440" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        Background="{DynamicResource ReyBgBrush}"
        Foreground="{DynamicResource ReyTextBrush}"
        FontFamily="Inter, Segoe UI, sans-serif">

  <!-- M74: minimal modal prompt — confirm (message + OK/Cancel) or text input (rename etc.) -->
  <StackPanel Margin="22,18" Spacing="12">
    <TextBlock x:Name="MessageText" FontSize="12.5" TextWrapping="Wrap" LineHeight="18" />
    <TextBox x:Name="InputBox" FontSize="12.5" IsVisible="False" />
    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right" Margin="0,6,0,0">
      <Button Classes="tool" Content="Cancel" Click="OnCancel" Padding="16,6" />
      <Button x:Name="OkButton" Classes="primary" Content="OK" Click="OnOk" Padding="20,6" />
    </StackPanel>
  </StackPanel>
</Window>
