<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:ReyEngine.App.Views"
        xmlns:vm="clr-namespace:ReyEngine.App.ViewModels"
        x:Class="ReyEngine.App.Views.FirstRunWindow"
        x:DataType="vm:FirstRunViewModel"
        Title="ReyEngine — Setup"
        Width="640" Height="700"
        WindowStartupLocation="CenterOwner"
        ExtendClientAreaToDecorationsHint="True"
        Background="{DynamicResource ReyBgBrush}"
        Foreground="{DynamicResource ReyTextBrush}"
        FontFamily="Inter, Segoe UI, sans-serif">

  <!-- M93: first-run setup — get a fresh install fully working with a few clicks -->
  <DockPanel>
    <local:ReyTitleBar DockPanel.Dock="Top" />

    <Border DockPanel.Dock="Top" Padding="24,18,24,8">
      <StackPanel Spacing="4">
        <TextBlock Text="Welcome to ReyEngine" FontSize="20" FontWeight="Bold"
                   Foreground="{DynamicResource ReyTextBrightBrush}" />
        <TextBlock Text="Let's set everything up. Each step is optional and can be re-run later from Help ▸ Setup Wizard."
                   FontSize="12" Foreground="{DynamicResource ReyTextDimBrush}" TextWrapping="Wrap" />
      </StackPanel>
    </Border>

    <Border DockPanel.Dock="Bottom" BorderBrush="{DynamicResource ReyBorderSoftBrush}"
            BorderThickness="0,1,0,0" Padding="24,12">
      <Grid ColumnDefinitions="*,Auto">
        <TextBlock Grid.Column="0" Text="You can change all of this later in Settings."
                   FontSize="11" Foreground="{DynamicResource ReyTextDimBrush}" VerticalAlignment="Center" />
        <Button Grid.Column="1" Classes="success" Content="✓ Done — start using ReyEngine"
                Command="{Binding FinishCommand}" />
      </Grid>
    </Border>

    <ScrollViewer Padding="24,8,24,12">
      <StackPanel Spacing="12">

        <!-- 1 · game install -->
        <Border Classes="settingsCard">
          <StackPanel Spacing="8">
            <TextBlock Classes="settingsTitle" Text="1 · LEAGUE OF LEGENDS INSTALL" />
            <TextBlock Text="{Binding GameStatus}" FontSize="12" TextWrapping="Wrap"
                       Foreground="{DynamicResource ReyTextBrush}" />
          </StackPanel>
        </Border>

        <!-- 2 · hashes -->
        <Border Classes="settingsCard">
          <StackPanel Spacing="8">
            <TextBlock Classes="settingsTitle" Text="2 · FILE-NAME HASHES  (recommended)" />
            <TextBlock Text="{Binding HashStatus}" FontSize="12" TextWrapping="Wrap"
                       Foreground="{DynamicResource ReyTextBrush}" />
            <Button Content="⬇ Download hashes (CommunityDragon)"
                    Command="{Binding DownloadHashesCommand}"
                    IsEnabled="{Binding !HashBusy}" IsVisible="{Binding !HashOk}" />
          </StackPanel>
        </Border>

        <!-- 3 · audio decoder -->
        <Border Classes="settingsCard">
          <StackPanel Spacing="8">
            <TextBlock Classes="settingsTitle" Text="3 · AUDIO DECODER  (vgmstream)" />
            <TextBlock Text="{Binding AudioStatus}" FontSize="12" TextWrapping="Wrap"
                       Foreground="{DynamicResource ReyTextBrush}" />
            <Button Content="⬇ Download vgmstream"
                    Command="{Binding DownloadVgmstreamCommand}"
                    IsEnabled="{Binding !AudioBusy}" IsVisible="{Binding !AudioOk}" />
          </StackPanel>
        </Border>

        <!-- 4 · Dominion map -->
        <Border Classes="settingsCard">
          <StackPanel Spacing="8">
            <TextBlock Classes="settingsTitle" Text="4 · DOMINION PREVIEW MAP  (optional)" />
            <TextBlock Text="{Binding MapStatus}" FontSize="12" TextWrapping="Wrap"
                       Foreground="{DynamicResource ReyTextBrush}" />
            <Button Content="⬇ Download Dominion map (Map8)"
                    Command="{Binding DownloadMapCommand}"
                    IsEnabled="{Binding !MapBusy}" IsVisible="{Binding !MapOk}" />
          </StackPanel>
        </Border>

      </StackPanel>
    </ScrollViewer>
  </DockPanel>
</Window>
