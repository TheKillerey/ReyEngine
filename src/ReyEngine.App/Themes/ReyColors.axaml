<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- ============================================================================
       ReyEngine · PROJECT KALISTA palette (M39)
       Deep navy/charcoal surfaces, cyan/teal primary accent, violet secondary.
       All views consume these via DynamicResource — change here, restyle everywhere.
       ============================================================================ -->

  <!-- surfaces -->
  <Color x:Key="ReyBg">#0A0D13</Color>            <!-- window / viewport backdrop -->
  <Color x:Key="ReyPanel">#10151F</Color>          <!-- side panels -->
  <Color x:Key="ReyPanelAlt">#141C29</Color>       <!-- nested cards / inputs -->
  <Color x:Key="ReyHeader">#0C111A</Color>         <!-- header / toolbar / status -->
  <Color x:Key="ReyCard">#111826</Color>           <!-- inspector cards -->
  <Color x:Key="ReyGlass">#CC0D1320</Color>        <!-- translucent HUD overlays -->

  <!-- lines -->
  <Color x:Key="ReyBorder">#1E2A3A</Color>
  <Color x:Key="ReyBorderSoft">#16202E</Color>
  <Color x:Key="ReyBorderAccent">#2E4A55</Color>   <!-- cyan-tinted panel edge -->

  <!-- accents -->
  <Color x:Key="ReyAccent">#36E2C2</Color>
  <Color x:Key="ReyAccentHover">#5FF0D6</Color>
  <Color x:Key="ReyAccentDeep">#0E5F52</Color>
  <Color x:Key="ReyOnAccent">#06201B</Color>       <!-- text on cyan fills -->
  <Color x:Key="ReyAccent2">#6C5CE7</Color>
  <Color x:Key="ReyAccent2Hover">#8B7CF7</Color>

  <!-- signals -->
  <Color x:Key="ReyWarning">#FFB454</Color>
  <Color x:Key="ReyError">#FF6B6B</Color>
  <Color x:Key="ReySuccess">#4CE27A</Color>

  <!-- text -->
  <Color x:Key="ReyTextBright">#E9EFF8</Color>
  <Color x:Key="ReyText">#C7D0DD</Color>
  <Color x:Key="ReyTextDim">#6A7686</Color>

  <!-- selection / hover fills (translucent cyan) -->
  <Color x:Key="ReySelection">#3336E2C2</Color>
  <Color x:Key="ReyHover">#1A36E2C2</Color>

  <!-- brushes -->
  <SolidColorBrush x:Key="ReyBgBrush" Color="{StaticResource ReyBg}" />
  <SolidColorBrush x:Key="ReyPanelBrush" Color="{StaticResource ReyPanel}" />
  <SolidColorBrush x:Key="ReyPanelAltBrush" Color="{StaticResource ReyPanelAlt}" />
  <SolidColorBrush x:Key="ReyHeaderBrush" Color="{StaticResource ReyHeader}" />
  <SolidColorBrush x:Key="ReyCardBrush" Color="{StaticResource ReyCard}" />
  <SolidColorBrush x:Key="ReyGlassBrush" Color="{StaticResource ReyGlass}" />
  <SolidColorBrush x:Key="ReyBorderBrush" Color="{StaticResource ReyBorder}" />
  <SolidColorBrush x:Key="ReyBorderSoftBrush" Color="{StaticResource ReyBorderSoft}" />
  <SolidColorBrush x:Key="ReyBorderAccentBrush" Color="{StaticResource ReyBorderAccent}" />
  <SolidColorBrush x:Key="ReyAccentBrush" Color="{StaticResource ReyAccent}" />
  <SolidColorBrush x:Key="ReyAccentHoverBrush" Color="{StaticResource ReyAccentHover}" />
  <SolidColorBrush x:Key="ReyAccentDeepBrush" Color="{StaticResource ReyAccentDeep}" />
  <SolidColorBrush x:Key="ReyOnAccentBrush" Color="{StaticResource ReyOnAccent}" />
  <SolidColorBrush x:Key="ReyAccent2Brush" Color="{StaticResource ReyAccent2}" />
  <SolidColorBrush x:Key="ReyAccent2HoverBrush" Color="{StaticResource ReyAccent2Hover}" />
  <SolidColorBrush x:Key="ReyWarningBrush" Color="{StaticResource ReyWarning}" />
  <SolidColorBrush x:Key="ReyErrorBrush" Color="{StaticResource ReyError}" />
  <SolidColorBrush x:Key="ReySuccessBrush" Color="{StaticResource ReySuccess}" />
  <SolidColorBrush x:Key="ReyTextBrightBrush" Color="{StaticResource ReyTextBright}" />
  <SolidColorBrush x:Key="ReyTextBrush" Color="{StaticResource ReyText}" />
  <SolidColorBrush x:Key="ReyTextDimBrush" Color="{StaticResource ReyTextDim}" />
  <SolidColorBrush x:Key="ReySelectionBrush" Color="{StaticResource ReySelection}" />
  <SolidColorBrush x:Key="ReyHoverBrush" Color="{StaticResource ReyHover}" />

  <!-- ============================================================================
       Fluent theme tint: steer Avalonia's built-in controls (selection highlights,
       sliders, checkboxes, menus, inputs, combo dropdowns) onto the Kalista palette.
       ============================================================================ -->
  <Color x:Key="SystemAccentColor">#36E2C2</Color>
  <Color x:Key="SystemAccentColorDark1">#26C4A8</Color>
  <Color x:Key="SystemAccentColorDark2">#1AA78F</Color>
  <Color x:Key="SystemAccentColorDark3">#0E8A75</Color>
  <Color x:Key="SystemAccentColorLight1">#5FF0D6</Color>
  <Color x:Key="SystemAccentColorLight2">#8AF6E3</Color>
  <Color x:Key="SystemAccentColorLight3">#B5FBEF</Color>

  <SolidColorBrush x:Key="TextControlBackground" Color="{StaticResource ReyPanelAlt}" />
  <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="{StaticResource ReyPanelAlt}" />
  <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="{StaticResource ReyPanelAlt}" />
  <SolidColorBrush x:Key="TextControlBorderBrush" Color="{StaticResource ReyBorder}" />
  <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="{StaticResource ReyBorderAccent}" />
  <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="{StaticResource ReyAccent}" />
  <SolidColorBrush x:Key="TextControlForeground" Color="{StaticResource ReyText}" />
  <SolidColorBrush x:Key="TextControlForegroundFocused" Color="{StaticResource ReyTextBright}" />
  <SolidColorBrush x:Key="TextControlPlaceholderForeground" Color="{StaticResource ReyTextDim}" />
  <SolidColorBrush x:Key="TextControlSelectionHighlightColor" Color="{StaticResource ReySelection}" />

  <SolidColorBrush x:Key="ComboBoxBackground" Color="{StaticResource ReyPanelAlt}" />
  <SolidColorBrush x:Key="ComboBoxBackgroundPointerOver" Color="{StaticResource ReyPanelAlt}" />
  <SolidColorBrush x:Key="ComboBoxBorderBrush" Color="{StaticResource ReyBorder}" />
  <SolidColorBrush x:Key="ComboBoxBorderBrushPointerOver" Color="{StaticResource ReyBorderAccent}" />
  <SolidColorBrush x:Key="ComboBoxDropDownBackground" Color="{StaticResource ReyPanelAlt}" />
  <SolidColorBrush x:Key="ComboBoxDropDownBorderBrush" Color="{StaticResource ReyBorder}" />

  <SolidColorBrush x:Key="MenuFlyoutPresenterBackground" Color="{StaticResource ReyPanelAlt}" />
  <SolidColorBrush x:Key="MenuFlyoutPresenterBorderBrush" Color="{StaticResource ReyBorder}" />

  <SolidColorBrush x:Key="TabItemHeaderSelectedPipeFill" Color="{StaticResource ReyAccent}" />
  <SolidColorBrush x:Key="TabItemHeaderForegroundSelected" Color="{StaticResource ReyAccent}" />

  <SolidColorBrush x:Key="ButtonBackground" Color="{StaticResource ReyPanelAlt}" />
  <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="{StaticResource ReyBorder}" />
  <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="{StaticResource ReyBorderSoft}" />
  <SolidColorBrush x:Key="ButtonForeground" Color="{StaticResource ReyText}" />
  <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="{StaticResource ReyTextBright}" />
  <SolidColorBrush x:Key="ButtonBorderBrush" Color="{StaticResource ReyBorder}" />

  <SolidColorBrush x:Key="ToggleButtonBackgroundChecked" Color="{StaticResource ReyAccentDeep}" />
  <SolidColorBrush x:Key="ToggleButtonBackgroundCheckedPointerOver" Color="{StaticResource ReyAccentDeep}" />
  <SolidColorBrush x:Key="ToggleButtonForegroundChecked" Color="{StaticResource ReyAccentHover}" />

  <SolidColorBrush x:Key="ScrollBarThumbFill" Color="{StaticResource ReyBorder}" />
  <SolidColorBrush x:Key="ScrollBarThumbFillPointerOver" Color="{StaticResource ReyBorderAccent}" />
  <SolidColorBrush x:Key="ScrollBarThumbBackgroundColor" Color="{StaticResource ReyBorder}" />

</ResourceDictionary>
